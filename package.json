{
  "name": "awcms-mini",
  "version": "0.23.5",
  "private": true,
  "description": "AWCMS-Mini — Modular Monolith Standard (Bun + Astro foundation skeleton)",
  "license": "MIT",
  "author": "AhliWeb",
  "homepage": "https://github.com/ahliweb/awcms-mini#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahliweb/awcms-mini.git"
  },
  "bugs": {
    "url": "https://github.com/ahliweb/awcms-mini/issues"
  },
  "keywords": [
    "modular-monolith",
    "bun",
    "astro",
    "postgresql",
    "multi-tenant",
    "rbac",
    "abac",
    "rls",
    "offline-first",
    "standard"
  ],
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun --bun astro dev",
    "build": "bun --bun astro build",
    "preview": "bun --bun astro preview",
    "start": "bun ./dist/server/entry.mjs",
    "db:migrate": "bun scripts/db-migrate.ts",
    "api:spec:check": "bun scripts/api-spec-check.ts",
    "openapi:bundle": "bun scripts/openapi-bundle.ts",
    "api:docs:generate": "bun scripts/api-docs-generate.ts",
    "api:docs:check": "bun scripts/api-docs-check.ts",
    "db:pool:health": "bun scripts/db-pool-health.ts",
    "sync:objects:dispatch": "bun scripts/object-sync-dispatch.ts",
    "logs:audit:purge": "bun scripts/audit-log-purge.ts",
    "analytics:rollup": "bun scripts/visitor-analytics-rollup.ts",
    "analytics:purge": "bun scripts/visitor-analytics-purge.ts",
    "form-drafts:purge": "bun scripts/form-draft-purge.ts",
    "blog:publish:scheduled": "bun scripts/blog-scheduled-publish.ts",
    "email:dispatch": "bun scripts/email-dispatch.ts",
    "email:provider:health": "bun scripts/email-provider-health.ts",
    "email:templates:seed-defaults": "bun scripts/email-templates-seed-defaults.ts",
    "modules:sync": "bun scripts/modules-sync.ts",
    "modules:dag:check": "bun scripts/validate-module-graph.ts",
    "i18n:extract": "bun scripts/i18n-extract.ts",
    "i18n:pot:check": "bun scripts/i18n-pot-check.ts",
    "i18n:parity:check": "bun scripts/i18n-parity-check.ts",
    "security:readiness": "bun scripts/security-readiness.ts",
    "config:validate": "bun scripts/validate-env.ts",
    "config:docs:check": "bun scripts/config-docs-check.ts",
    "logging:lint:check": "bun scripts/logging-lint-check.ts",
    "production:preflight": "bun scripts/production-preflight.ts",
    "github:snapshot:refresh": "bun scripts/github-snapshot-refresh.ts",
    "changesets:policy:check": "bun scripts/changeset-policy-check.ts",
    "release:verify": "bun scripts/release-verify.ts",
    "lint": "prettier --check \"**/*.md\" \"**/*.{json,yml,yaml}\" \"**/*.{ts,mjs,astro}\"",
    "format": "prettier --write \"**/*.md\" \"**/*.{json,yml,yaml}\" \"**/*.{ts,mjs,astro}\"",
    "check:docs": "bun scripts/check-docs.mjs",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:e2e": "bun --bun playwright test",
    "test:e2e:install": "bun --bun playwright install --with-deps chromium",
    "check": "bun run lint && bun run check:docs && bun run api:spec:check && bun run api:docs:check && bun run modules:dag:check && bun run i18n:pot:check && bun run i18n:parity:check && bun run config:docs:check && bun run logging:lint:check && bun run typecheck && bun run test && bun run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "changeset:tag": "changeset tag"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "astro": "^7.0.0"
  }
}
