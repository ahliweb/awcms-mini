{
  "name": "awcms-mini",
  "version": "0.0.3",
  "private": true,
  "description": "AWCMS-Mini — Modular Monolith Standard (Bun + Astro foundation skeleton)",
  "license": "MIT",
  "author": "AhliWeb",
  "homepage": "https://github.com/ahliweb/awcms-mini#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahliweb/awcms-mini.git"
  },
  "bugs": {
    "url": "https://github.com/ahliweb/awcms-mini/issues"
  },
  "keywords": [
    "modular-monolith",
    "bun",
    "astro",
    "postgresql",
    "multi-tenant",
    "rbac",
    "abac",
    "rls",
    "offline-first",
    "standard"
  ],
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun --bun astro dev",
    "build": "bun --bun astro build",
    "preview": "bun --bun astro preview",
    "start": "bun --bun astro preview --host 0.0.0.0",
    "db:migrate": "bun scripts/db-migrate.ts",
    "lint": "prettier --check \"**/*.md\" \"**/*.{json,yml,yaml}\"",
    "format": "prettier --write \"**/*.md\" \"**/*.{json,yml,yaml}\"",
    "check:docs": "bun scripts/check-docs.mjs",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "check": "bun run lint && bun run check:docs && bun run typecheck && bun run test && bun run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "changeset:tag": "changeset tag"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "astro": "^7.0.0"
  }
}
