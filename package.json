{
  "name": "awcms-mini",
  "version": "0.0.0",
  "private": true,
  "description": "AWCMS-Mini — base modular monolith standard (Bun + Astro + PostgreSQL) untuk semua aplikasi AhliWeb (contoh domain: AWPOS)",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "bun ./dist/server/entry.mjs",
    "typecheck": "astro check",
    "test": "bun test tests/",
    "lint": "prettier --check \"*.md\" \"docs/**/*.md\" package.json",
    "format": "prettier --write \"*.md\" \"docs/**/*.md\" package.json",
    "db:migrate": "bun scripts/db-migrate.ts",
    "db:migrate:status": "bun scripts/db-migrate.ts status",
    "db:pool:health": "bun scripts/db-pool-health.ts",
    "api:spec:check": "bun scripts/api-spec-check.ts",
    "api:contract:test": "bun scripts/api-contract-test.ts",
    "security:readiness": "bun scripts/security-readiness.ts",
    "production:preflight": "bun scripts/production-preflight.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "changeset:tag": "changeset tag"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "astro": "^7.0.6",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@changesets/cli": "^2.27.9",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "yaml": "^2.8.0"
  }
}
