{
  "name": "awcms-mini",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "node ./scripts/run-with-local-env.mjs astro dev",
    "build": "node ./scripts/run-with-local-env.mjs astro build",
    "build:node": "MINI_RUNTIME_TARGET=node astro build",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "audit:coolify": "node ./scripts/audit-coolify-posture.mjs",
    "audit:coolify-postgres": "node ./scripts/audit-coolify-postgres.mjs",
    "audit:coolify-server-ssh": "node ./scripts/audit-coolify-server-ssh.mjs",
    "audit:coolify-token": "node ./scripts/audit-coolify-token.mjs",
    "audit:database-role": "node ./scripts/audit-database-role.mjs",
    "coolify:mcp": "node ./scripts/coolify-mcp.mjs",
    "deploy:cloudflare": "node ./scripts/deploy-cloudflare.mjs",
    "smoke:deployed-runtime-health": "node ./scripts/smoke-deployed-runtime-health.mjs",
    "smoke:cloudflare-admin": "node ./scripts/smoke-cloudflare-admin.mjs",
    "verify:live-runtime": "node ./scripts/verify-live-runtime.mjs",
    "check": "pnpm check:secret-hygiene && pnpm typecheck && pnpm test:unit && pnpm build && pnpm lint",
    "check:secret-hygiene": "node ./scripts/check-secret-hygiene.mjs",
    "lint": "pnpm prettier --check README.md DOCS_INDEX.md REQUIREMENTS.md SECURITY.md AGENTS.md docs/**/*.md package.json",
    "format": "pnpm prettier --write README.md DOCS_INDEX.md REQUIREMENTS.md SECURITY.md AGENTS.md docs/**/*.md package.json",
    "typecheck": "node ./scripts/run-with-local-env.mjs astro check",
    "test:unit": "node --test tests/unit/**/*.test.mjs",
    "healthcheck": "node ./scripts/healthcheck.mjs",
    "db:migrate": "node ./scripts/db-migrate.mjs latest",
    "db:migrate:down": "node ./scripts/db-migrate.mjs down",
    "db:migrate:status": "node ./scripts/db-migrate.mjs status",
    "db:migrate:emdash:status": "node ./scripts/db-migrate.mjs emdash-status",
    "db:migrate:emdash:verify": "node ./scripts/db-migrate.mjs emdash-verify",
    "db:migrate:emdash:repair": "node ./scripts/db-migrate.mjs emdash-repair",
    "db:seed:administrative-regions": "node ./scripts/db-seed-administrative-regions.mjs",
    "start:api": "node ./server/index.mjs",
    "dev:api": "NODE_ENV=development node --watch ./server/index.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/node": "^10.0.5",
    "@astrojs/react": "^5.0.3",
    "astro": "^6.1.10",
    "better-sqlite3": "^12.9.0",
    "emdash": "0.8.0",
    "jose": "^6.2.3",
    "kysely": "^0.28.16",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.6",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.84.1"
  },
  "pnpm": {
    "overrides": {
      "kysely": "0.28.16"
    },
    "patchedDependencies": {
      "emdash@0.8.0": "patches/emdash@0.8.0.patch"
    }
  }
}
