{
  "name": "awcms-mini",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun ./scripts/run-with-local-env.mjs astro dev",
    "build": "bun ./scripts/run-with-local-env.mjs astro build",
    "build:node": "MINI_RUNTIME_TARGET=node astro build",
    "preview": "astro preview",
    "start": "bun ./dist/server/entry.mjs",
    "audit:coolify": "bun ./scripts/audit-coolify-posture.mjs",
    "audit:coolify-postgres": "bun ./scripts/audit-coolify-postgres.mjs",
    "audit:coolify-server-ssh": "bun ./scripts/audit-coolify-server-ssh.mjs",
    "audit:coolify-token": "bun ./scripts/audit-coolify-token.mjs",
    "audit:coolify-backup": "bun ./scripts/audit-coolify-backup.mjs",
    "coolify:backup-setup": "bun ./scripts/backup-coolify-setup.mjs",
    "audit:database-role": "bun ./scripts/audit-database-role.mjs",
    "coolify:mcp": "bun ./scripts/coolify-mcp.mjs",
    "deploy:cloudflare": "bun ./scripts/deploy-cloudflare.mjs",
    "smoke:deployed-runtime-health": "bun ./scripts/smoke-deployed-runtime-health.mjs",
    "smoke:cloudflare-admin": "bun ./scripts/smoke-cloudflare-admin.mjs",
    "verify:live-runtime": "bun ./scripts/verify-live-runtime.mjs",
    "check:emdash-drift": "bun ./scripts/check-emdash-drift.mjs",
    "check:rls-coverage": "bun ./scripts/check-rls-coverage.mjs",
    "check:plugin-manifests": "bun ./scripts/check-plugin-manifests.mjs",
    "check": "bun run check:secret-hygiene && bun run check:plugin-manifests && bun run typecheck && bun run test:unit && bun run build && bun run lint",
    "check:secret-hygiene": "bun ./scripts/check-secret-hygiene.mjs",
    "lint": "bunx prettier --check README.md DOCS_INDEX.md REQUIREMENTS.md SECURITY.md AGENTS.md docs/**/*.md package.json",
    "format": "bunx prettier --write README.md DOCS_INDEX.md REQUIREMENTS.md SECURITY.md AGENTS.md docs/**/*.md package.json",
    "typecheck": "bun ./scripts/run-with-local-env.mjs astro check",
    "test:unit": "bun test tests/unit/",
    "healthcheck": "bun ./scripts/healthcheck.mjs",
    "db:migrate": "bun ./scripts/db-migrate.mjs latest",
    "db:migrate:down": "bun ./scripts/db-migrate.mjs down",
    "db:migrate:status": "bun ./scripts/db-migrate.mjs status",
    "db:migrate:emdash:status": "bun ./scripts/db-migrate.mjs emdash-status",
    "db:migrate:emdash:verify": "bun ./scripts/db-migrate.mjs emdash-verify",
    "db:migrate:emdash:repair": "bun ./scripts/db-migrate.mjs emdash-repair",
    "db:seed:administrative-regions": "bun ./scripts/db-seed-administrative-regions.mjs",
    "start:api": "bun ./server/index.mjs",
    "dev:api": "NODE_ENV=development bun --watch ./server/index.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.2.2",
    "@astrojs/node": "^10.0.5",
    "@astrojs/react": "^5.0.4",
    "@hono/node-server": "^1.17.3",
    "astro": "^6.1.10",
    "emdash": "0.9.0",
    "hono": "^4.7.10",
    "jose": "^6.2.3",
    "kysely": "^0.28.16",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.6",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.84.1"
  },
  "overrides": {
    "kysely": "0.28.16"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "esbuild",
    "sharp",
    "workerd"
  ]
}
