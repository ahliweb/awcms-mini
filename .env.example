# AWCMS-Mini — environment reference (lihat docs/awcms-mini/18_configuration_env_reference.md)
# Semua secret hanya dari environment; .env di-ignore, file ini hanya placeholder.

# Inti
APP_ENV=development
APP_URL=http://localhost:4321
APP_TIMEZONE=Asia/Jakarta
APP_DEFAULT_LOCALE=id
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://awcms:awcms_password@localhost:5432/awcms_mini
DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_PGBOUNCER=false

# Auth
AUTH_JWT_SECRET=change-me-in-production
AUTH_SESSION_TTL_MIN=120
AUTH_COOKIE_SECURE=true
AUTH_LOGIN_MAX_ATTEMPTS=5

# Sync / node (offline-first, opsional)
AWCMS_NODE_ID=local-dev-node
AWCMS_SYNC_ENABLED=false
AWCMS_SYNC_HMAC_SECRET=change-me
AWCMS_SYNC_MAX_SKEW_SEC=300

# Storage
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage
R2_ENABLED=false
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# Provider opsional (default off — tidak boleh jadi dependency transaksi)
STARSENDER_ENABLED=false
# STARSENDER_API_KEY=
MAILKETING_ENABLED=false
# MAILKETING_API_TOKEN=
AI_ANALYST_ENABLED=false
# AI_PROVIDER_API_KEY=
# AI_MODEL=
