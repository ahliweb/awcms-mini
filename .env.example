# AWCMS Mini — Environment Variables Example
#
# Copy this file to `.env` for local development.
# Keep local-only operator secrets in `.env.local` or `.env.<environment>.local`.
# Keep production secrets in Coolify Environment Variables (locked secrets).
# Never commit real secrets to source control.
#
# Architecture: Cloudflare Pages frontend → Hono backend on Coolify VPS → PostgreSQL Docker
# Cloudflare Hyperdrive is NOT used. See docs/process/no-hyperdrive-adr.md.

# ---------------------------------------------------------------------------
# Core Backend
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=3000

# Public-facing frontend URL (Cloudflare Pages)
SITE_URL=https://example.com

# Backend API base URL (this service, Hono on Coolify VPS)
API_BASE_URL=https://api.example.com

# Optional dedicated admin hostname. Keep blank if using a single host.
# ADMIN_SITE_URL=https://admin.example.com
ADMIN_ENTRY_PATH=/_emdash/

# ---------------------------------------------------------------------------
# PostgreSQL (Docker service on the same VPS, internal Docker network)
# In production the hostname is `postgres` (internal Docker network).
# For local dev, use localhost with a mapped port.
# ---------------------------------------------------------------------------

DATABASE_URL=postgresql://awcms_mini_dev:replace_with_password@localhost:5432/awcms_mini_dev
DATABASE_TRANSPORT=direct
DATABASE_CONNECT_TIMEOUT_MS=10000

# Production example:
# DATABASE_URL=postgresql://awcms_mini_app:strong_password@postgres:5432/awcms_mini

# ---------------------------------------------------------------------------
# Application Secrets
# Store all production values as Coolify locked secrets.
# ---------------------------------------------------------------------------

APP_SECRET=replace_with_strong_app_secret

# JWT / session signing
JWT_SECRET=replace_with_strong_jwt_secret
SESSION_SECRET=replace_with_strong_session_secret
PASSWORD_PEPPER=replace_with_strong_password_pepper

# TOTP encryption key for 2FA secret storage (32-byte base64 or hex string)
MINI_TOTP_ENCRYPTION_KEY=replace_with_32_byte_totp_encryption_key
TWO_FACTOR_ISSUER=AWCMS Mini
TWO_FACTOR_RECOVERY_CODE_PEPPER=replace_with_strong_secret

# ---------------------------------------------------------------------------
# Cloudflare R2 — accessed from Hono backend via S3-compatible API
# NOT via Cloudflare Worker bindings in this architecture.
# ---------------------------------------------------------------------------

CLOUDFLARE_ACCOUNT_ID=replace_with_cloudflare_account_id
R2_ACCESS_KEY_ID=replace_with_r2_access_key
R2_SECRET_ACCESS_KEY=replace_with_r2_secret_key
R2_BUCKET_NAME=awcms-mini
R2_PUBLIC_BASE_URL=https://assets.example.com

# Upload policy
R2_MAX_UPLOAD_BYTES=5242880
R2_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Legacy binding name retained for code compatibility.
R2_MEDIA_BUCKET_BINDING=MEDIA_BUCKET
R2_MEDIA_BUCKET_NAME=awcms-mini

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
EDGE_API_ALLOWED_ORIGINS=https://example.com
EDGE_API_MAX_BODY_BYTES=16384

# ---------------------------------------------------------------------------
# Cloudflare Turnstile
# Turnstile enforcement activates when TURNSTILE_SECRET_KEY is configured.
# Verify tokens only on the backend. Never expose the secret key to the frontend.
# ---------------------------------------------------------------------------

TURNSTILE_SITE_KEY=replace_with_turnstile_site_key
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret_key
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Optional: comma-separated expected hostnames for Siteverify validation.
# Defaults to hostnames derived from SITE_URL and ADMIN_SITE_URL when omitted.
# TURNSTILE_EXPECTED_HOSTNAMES=example.com,www.example.com

# ---------------------------------------------------------------------------
# Edge API (versioned JWT API)
# ---------------------------------------------------------------------------

EDGE_API_JWT_SECRET=replace_with_dedicated_edge_api_jwt_secret
# EDGE_API_JWT_ISSUER=https://api.example.com/api/v1
# EDGE_API_JWT_AUDIENCE=awcms-mini-edge-api
EDGE_API_ACCESS_TOKEN_TTL_SECONDS=900
EDGE_API_REFRESH_TOKEN_TTL_SECONDS=2592000

# ---------------------------------------------------------------------------
# Trusted proxy mode
# Use `cloudflare` when Cloudflare proxies requests to the VPS.
# ---------------------------------------------------------------------------

TRUSTED_PROXY_MODE=cloudflare
MINI_RUNTIME_TARGET=node

# ---------------------------------------------------------------------------
# OpenAPI / Swagger Documentation
# Disable Swagger UI in production if API docs should be private.
# ---------------------------------------------------------------------------

OPENAPI_ENABLED=true
OPENAPI_JSON_PATH=/openapi.json
SWAGGER_UI_ENABLED=true
SWAGGER_UI_PATH=/docs

# ---------------------------------------------------------------------------
# Mailketing — Email API Sender (backend-only)
# Keep API keys in Coolify locked secrets. Never expose to frontend.
# ---------------------------------------------------------------------------

MAILKETING_ENABLED=false
MAILKETING_API_BASE_URL=https://api.mailketing.example
MAILKETING_API_KEY=replace_with_mailketing_api_key
MAILKETING_SENDER_EMAIL=noreply@example.com
MAILKETING_SENDER_NAME=AWCMS Mini
MAILKETING_WEBHOOK_SECRET=replace_if_supported
MAILKETING_TIMEOUT_MS=10000
MAILKETING_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Starsender — WhatsApp API Sender (backend-only)
# Keep API keys in Coolify locked secrets. Never expose to frontend.
# ---------------------------------------------------------------------------

STARSENDER_ENABLED=false
STARSENDER_API_BASE_URL=https://api.starsender.example
STARSENDER_API_KEY=replace_with_starsender_api_key
STARSENDER_DEVICE_ID=replace_with_starsender_device_id_if_required
STARSENDER_DEFAULT_COUNTRY_CODE=62
STARSENDER_WEBHOOK_SECRET=replace_if_supported
STARSENDER_TIMEOUT_MS=10000
STARSENDER_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------

NOTIFICATION_RATE_LIMIT_PER_MINUTE=60
NOTIFICATION_RETRY_ENABLED=true
NOTIFICATION_DEFAULT_PROVIDER_EMAIL=mailketing
NOTIFICATION_DEFAULT_PROVIDER_WHATSAPP=starsender

# ---------------------------------------------------------------------------
# Coolify operator automation (keep in .env.local, not committed)
# ---------------------------------------------------------------------------

# COOLIFY_BASE_URL=https://app.coolify.io
# COOLIFY_ACCESS_TOKEN=replace_with_local_only_coolify_token

# ---------------------------------------------------------------------------
# Cloudflare operator automation (keep in .env.local, not committed)
# ---------------------------------------------------------------------------

# CLOUDFLARE_API_TOKEN=replace_with_local_only_cloudflare_api_token
# CLOUDFLARE_TUNNEL_ID=replace_with_cloudflare_tunnel_id
# CLOUDFLARE_TUNNEL_NAME=replace_with_cloudflare_tunnel_name

# ---------------------------------------------------------------------------
# Healthcheck posture assertions (optional, for rollout verification only)
# ---------------------------------------------------------------------------

# HEALTHCHECK_EXPECT_DATABASE_TRANSPORT=direct
# HEALTHCHECK_EXPECT_DATABASE_HOSTNAME=postgres
# HEALTHCHECK_EXPECT_DATABASE_SSLMODE=require

# ---------------------------------------------------------------------------
# Frontend (Cloudflare Pages) — public-only variables
# These belong in the Cloudflare Pages environment settings, not the backend.
# PUBLIC_API_BASE_URL=https://api.example.com
# PUBLIC_SITE_CODE=main
# PUBLIC_APP_ENV=production
# PUBLIC_TURNSTILE_SITE_KEY=replace_with_turnstile_site_key
# ---------------------------------------------------------------------------
