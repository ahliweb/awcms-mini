# Inti
APP_ENV=development
APP_URL=http://localhost:4321
APP_TIMEZONE=Asia/Jakarta
APP_DEFAULT_LOCALE=id
LOG_LEVEL=info

# Database — two-role model (RLS enforcement, see sql/013 + migration notes):
#   * The running APP connects as the least-privilege `awcms_mini_app` role in
#     DATABASE_URL below. FORCE'd row-level security is enforced for this role
#     (a superuser/owner would bypass RLS, defeating tenant isolation).
#   * MIGRATIONS need DDL/GRANT rights the app role lacks — run them as the
#     privileged owner/superuser with a separate URL, e.g.:
#       DATABASE_URL=postgres://awcms-mini:awcms_mini_password@localhost:5432/awcms-mini bun run db:migrate
#   docker-compose wires both automatically (a `migrate` service runs as the
#   superuser; deploy/postgres/10-create-app-role.sh creates the app role). For
#   bare-metal/systemd, create the role once, then migrate as the superuser:
#     CREATE ROLE awcms_mini_app LOGIN PASSWORD '...';
#   See docs/awcms-mini/deployment-profiles.md §Model dua-peran basis data.
DATABASE_URL=postgres://awcms_mini_app:awcms_mini_app_password@localhost:5432/awcms-mini
# Password for the least-privilege app role. The docker-compose db init script
# uses it to create the role; it must match the password in DATABASE_URL above.
# Change it for any real deployment (secret — never a real value in git).
AWCMS_MINI_APP_DB_PASSWORD=awcms_mini_app_password
DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_PGBOUNCER=false

# Auth
AUTH_JWT_SECRET=change-me-in-production
AUTH_SESSION_TTL_MIN=120
AUTH_COOKIE_SECURE=false
AUTH_LOGIN_MAX_ATTEMPTS=5
# Source-scoped (client IP + tenant) volumetric rate limit on POST
# /api/v1/auth/login (Issue #437), complementary to AUTH_LOGIN_MAX_ATTEMPTS's
# per-identity lockout above — bounds request volume/cross-identity
# enumeration from a single source. Keep well above AUTH_LOGIN_MAX_ATTEMPTS
# so a legitimate user retrying their own password never trips this first.
AUTH_LOGIN_RATE_LIMIT_MAX=20
AUTH_LOGIN_RATE_LIMIT_WINDOW_SEC=60

# Sync
AWCMS_MINI_NODE_ID=local-dev-node
AWCMS_MINI_SYNC_ENABLED=false
AWCMS_MINI_SYNC_HMAC_SECRET=change-me
AWCMS_MINI_SYNC_MAX_SKEW_SEC=300

# Storage
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage
# Timeout (ms) for a single object-storage upload attempt made by the
# internal dispatcher (`bun run sync:objects:dispatch`, Issue #436) — bounds
# how long one call to the provider can hang before being treated as a
# failure and handed to the normal retry/backoff schedule.
OBJECT_SYNC_UPLOAD_TIMEOUT_MS=10000
R2_ENABLED=false
# Wajib diisi hanya bila R2_ENABLED=true (doc 18 §Referensi environment
# variable "bila R2"); dibiarkan commented-out di sini karena tidak
# dibutuhkan selama R2 off — jangan isi dengan kredensial asli di file ini.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# Provider eksternal opsional (default off) — base tidak menetapkan provider
# tertentu; aplikasi turunan menambah flag provider-nya sendiri di sini
# (lihat contoh domain retail/POS di doc 18 §Provider CRM/AI analyst).
