# Copy reviewed non-secret defaults into `.env` for local development.
# Keep local-only operator secrets such as Cloudflare and Coolify tokens in
# `.env.local`, and keep production values in Cloudflare-managed or CI/CD-managed
# server-only secret storage.

# PostgreSQL connection string used by the EmDash runtime.
# Update this for the intended deployment target. For production, this is expected
# to point at the remote PostgreSQL instance on the VPS.
DATABASE_URL=postgres://awcms_mini_dev:<password>@localhost:55432/awcms_mini_dev
DATABASE_CONNECT_TIMEOUT_MS=10000
# Production example shape:
# DATABASE_URL=postgres://awcms_mini_app:<password>@id1.ahlikoding.com:5432/awcms_mini?sslmode=verify-full
# DATABASE_CONNECT_TIMEOUT_MS=10000
# Current operator inventory: PostgreSQL VPS IP `202.10.45.224`, reviewed SSL hostname `id1.ahlikoding.com`.
# If hostname validation is not ready yet, use a reviewed interim SSL mode and
# track the follow-on hardening work explicitly.

# Database transport selection.
# The reviewed Cloudflare production path currently uses Hyperdrive.
# Local build and typecheck wrappers derive the required local Hyperdrive
# connection string from DATABASE_URL so credentials stay in env files.
DATABASE_TRANSPORT=hyperdrive
HYPERDRIVE_BINDING=HYPERDRIVE
# Optional explicit local override when you do not want to derive it from DATABASE_URL:
# CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgres://awcms_mini_dev:<password>@localhost:55432/awcms_mini_dev

# Runtime target for Astro adapter selection.
# Use `cloudflare` for the supported production baseline.
MINI_RUNTIME_TARGET=cloudflare

# Cloudflare operator token for non-interactive Wrangler automation.
# Keep the live token in `.env.local`, CI/CD secret storage, or another
# environment-managed secret store. Do not commit the live token.
# Tunnel rollout commands require a token with Account > Cloudflare Tunnel > Edit.
# DNS rollout steps require zone DNS edit/read permission for the target zone.
# Access rollout steps require the relevant Cloudflare Access/Zero Trust read/edit scopes.
# CLOUDFLARE_API_TOKEN=replace-with-local-only-cloudflare-api-token

# Coolify MCP operator-local settings.
# Keep the live access token in `.env.local`, not in tracked files.
COOLIFY_BASE_URL=https://app.coolify.io
# COOLIFY_ACCESS_TOKEN=replace-with-local-only-coolify-token

# Optional runtime healthcheck posture assertions for rollout verification.
# Keep these unset for normal local development unless you intentionally want
# `pnpm healthcheck` to fail when the runtime points at a different reviewed target.
# HEALTHCHECK_EXPECT_DATABASE_TRANSPORT=direct
# HEALTHCHECK_EXPECT_DATABASE_HOSTNAME=id1.ahlikoding.com
# HEALTHCHECK_EXPECT_DATABASE_SSLMODE=verify-full
# HEALTHCHECK_EXPECT_HYPERDRIVE_BINDING=HYPERDRIVE

# Dedicated key for TOTP secret encryption in Mini.
# Production deployments should set an explicit strong value.
MINI_TOTP_ENCRYPTION_KEY=replace-with-a-strong-secret

# Shared application secret.
# Mini falls back to this for TOTP encryption only when MINI_TOTP_ENCRYPTION_KEY
# is not set. Production deployments should still prefer a dedicated
# MINI_TOTP_ENCRYPTION_KEY value.
APP_SECRET=replace-with-a-strong-app-secret

# Cloudflare Turnstile public and secret keys.
# Turnstile enforcement activates when TURNSTILE_SECRET_KEY is configured.
TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret-key

# Optional explicit hostname check for Siteverify results.
# Defaults to the hostnames parsed from SITE_URL and ADMIN_SITE_URL when omitted.
# TURNSTILE_EXPECTED_HOSTNAME=cms.example.com
# TURNSTILE_EXPECTED_HOSTNAMES=awcms-mini.ahlikoding.com
# Compatibility example when a dedicated admin hostname is still enabled:
# TURNSTILE_EXPECTED_HOSTNAMES=awcms-mini.ahlikoding.com,awcms-mini-admin.ahlikoding.com

# Cloudflare R2 media/object storage baseline.
# Keep the bucket private by default and bind it to the Worker through Wrangler.
R2_MEDIA_BUCKET_BINDING=MEDIA_BUCKET
# Operator-facing bucket name for the deployed R2 binding.
R2_MEDIA_BUCKET_NAME=awcms-mini-s3
R2_MAX_UPLOAD_BYTES=5242880
R2_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Versioned edge API baseline.
# Leave EDGE_API_ALLOWED_ORIGINS empty to disable cross-origin browser access.
# EDGE_API_ALLOWED_ORIGINS=https://mobile.example.com
EDGE_API_MAX_BODY_BYTES=16384

# Edge API JWT and refresh-token settings for `/api/v1/token`.
# EDGE_API_JWT_SECRET falls back to APP_SECRET when omitted, but production should
# set a dedicated value and store it as a server-only secret.
EDGE_API_JWT_SECRET=replace-with-a-dedicated-edge-api-jwt-secret
# EDGE_API_JWT_ISSUER=https://cms.example.com/api/v1
# EDGE_API_JWT_AUDIENCE=awcms-mini-edge-api
EDGE_API_ACCESS_TOKEN_TTL_SECONDS=900
EDGE_API_REFRESH_TOKEN_TTL_SECONDS=2592000

# Public browser-facing origin used by the deployment.
# Astro uses this as the canonical deployed site URL.
# For Cloudflare-hosted deployments, this should match the external hostname.
SITE_URL=https://awcms-mini.ahlikoding.com

# The current implementation still supports an optional dedicated admin hostname,
# but the reviewed target rollout is a single host with admin entry at `/_emdash/`.
# ADMIN_SITE_URL=https://awcms-mini-admin.ahlikoding.com
# ADMIN_ENTRY_PATH=/_emdash/

# Trusted proxy mode for client IP extraction.
# Use `cloudflare` when Cloudflare is the browser-facing edge for the hosted runtime.
TRUSTED_PROXY_MODE=cloudflare

# ---------------------------------------------------------------------------
# Cloudflare account and operator automation variables.
# Keep these in `.env.local` for local operator use or in CI/CD-managed secret
# storage. Do not commit live values to source control.
# ---------------------------------------------------------------------------

# Cloudflare account ID used by Wrangler non-interactive commands.
# Keep in `.env.local` or CI/CD secret storage.
# CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id

# ---------------------------------------------------------------------------
# Cloudflare Tunnel operator variables.
# Required by tunnel-connector runbook steps and the private-database Hyperdrive
# path. Keep the token in server-managed secret storage on the VPS connector host.
# Do not commit live tunnel tokens to source control or issue bodies.
# ---------------------------------------------------------------------------

# Cloudflare Tunnel resource ID for the reviewed `awcms-mini-postgres` tunnel.
# Keep in `.env.local` or CI/CD secret storage.
# CLOUDFLARE_TUNNEL_ID=replace-with-cloudflare-tunnel-id

# Cloudflare Tunnel name for operator reference (e.g. `awcms-mini-postgres`).
# Keep in `.env.local` or operator notes.
# CLOUDFLARE_TUNNEL_NAME=replace-with-cloudflare-tunnel-name

# Cloudflare Tunnel token used by the `cloudflared` connector process.
# This is equivalent to the right to run the tunnel. Rotate if leaked.
# Keep in root-only server-managed secret storage on the VPS host, not in `.env.local`.
# The current reviewed VPS posture rotates this token weekly from the host.
# See `docs/process/cloudflare-tunnel-private-db-connector-runbook.md`.
# CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# ---------------------------------------------------------------------------
# Cloudflare Access / Zero Trust operator variables.
# Used for service-token auth and Access app verification in operator workflows.
# CLOUDFLARE_ACCESS_CLIENT_ID and CLOUDFLARE_ACCESS_CLIENT_SECRET should be
# stored as Cloudflare-managed Worker secrets or CI/CD-managed secrets when
# they are needed at runtime.
# ---------------------------------------------------------------------------

# Cloudflare Access application ID for the reviewed Access app.
# Keep in `.env.local` or operator notes.
# CLOUDFLARE_ACCESS_APP_ID=replace-with-cloudflare-access-app-id

# Cloudflare Access JWT audience tag for the reviewed Access app.
# Used to validate Cloudflare Access JWT tokens server-side.
# Keep in `.env.local` or deployment-managed configuration.
# CLOUDFLARE_ACCESS_APP_AUD=replace-with-cloudflare-access-app-aud

# Cloudflare Access service token client ID.
# Keep in Cloudflare-managed Worker secrets or CI/CD-managed secrets.
# CLOUDFLARE_ACCESS_CLIENT_ID=replace-with-cloudflare-access-client-id

# Cloudflare Access service token client secret.
# Keep in Cloudflare-managed Worker secrets or CI/CD-managed secrets.
# Rotate immediately if exposed. Do not log or echo this value.
# CLOUDFLARE_ACCESS_CLIENT_SECRET=replace-with-cloudflare-access-client-secret

# Cloudflare Access service token resource ID for operator reference.
# Keep in `.env.local` or operator notes.
# CLOUDFLARE_ACCESS_SERVICE_TOKEN_ID=replace-with-cloudflare-access-service-token-id

# ---------------------------------------------------------------------------
# VPS recovery posture.
# The reviewed Coolify-managed VPS now uses key-only root SSH recovery.
# Do not introduce `VPS_ROOT_PASSWORD` into `.env`, `.env.local`, or scripts.
# Keep recovery aligned with the reviewed SSH key path and the runbook.
# ---------------------------------------------------------------------------
