# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Markdown: pertahankan trailing spaces (hard line break) tetapi tetap newline akhir
trim_trailing_whitespace = false

[*.{sql,mjs,ts,tsx,js,jsx,astro,json,jsonc,yml,yaml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_style = space
indent_size = 2
