---
/**
 * LanguageSwitcher — Astro island (Issue #433, i18n).
 *
 * Unlike ThemeToggle (pure CSS, swaps instantly client-side), changing the
 * locale changes SSR-rendered *text* — there is no client-side fix-up for
 * that, so this control writes the `awcms_mini_locale` cookie (read by
 * `src/lib/i18n/request-locale.ts` on the next request) and does a full page
 * reload. Options show each language's own native name + flag (not
 * translated into the current UI locale) — the standard convention so a
 * user can find their language even if the current UI is one they can't
 * read (doc 14 §Internationalization).
 */
import {
  LOCALE_COOKIE_NAME,
  LOCALE_FLAGS,
  LOCALE_LABELS,
  SUPPORTED_LOCALES,
  type SupportedLocale
} from "../lib/i18n/locale";

interface Props {
  currentLocale: SupportedLocale;
  ariaLabel: string;
}

const { currentLocale, ariaLabel } = Astro.props;
---

<div class="language-switcher">
  <label class="sr-only" for="language-switcher-select">{ariaLabel}</label>
  <select
    id="language-switcher-select"
    class="language-switcher-select"
    data-cookie-name={LOCALE_COOKIE_NAME}
  >
    {
      SUPPORTED_LOCALES.map((locale) => (
        <option value={locale} selected={locale === currentLocale}>
          {LOCALE_FLAGS[locale]} {LOCALE_LABELS[locale]}
        </option>
      ))
    }
  </select>
</div>

<style>
  .language-switcher-select {
    appearance: none;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--color-text);
    cursor: pointer;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  const select = document.getElementById(
    "language-switcher-select"
  ) as HTMLSelectElement | null;

  select?.addEventListener("change", () => {
    const cookieName = select.dataset.cookieName;
    const oneYearSeconds = 60 * 60 * 24 * 365;
    document.cookie = `${cookieName}=${select.value}; path=/; max-age=${oneYearSeconds}; SameSite=Lax`;
    window.location.reload();
  });
</script>
