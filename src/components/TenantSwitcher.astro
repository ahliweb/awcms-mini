---
/**
 * TenantSwitcher — presentational stub (Issue 8.1).
 *
 * `awcms_mini_identities.tenant_id` is a 1:1 tenant-scoped column — there is
 * no cross-tenant identity linking anywhere in the schema today, so an
 * identity can never actually belong to more than one tenant. A real
 * "switch tenant" action therefore has nothing to switch *to*. This
 * component only displays the current tenant's name in a
 * dropdown-shaped, disabled control so the topbar matches the doc 14
 * admin shell layout; it is intentionally not wired to any switching
 * logic. See `src/modules/identity-access/README.md` §Tenant switcher
 * stub for the backlog note (cross-tenant identity linking, if ever
 * added, is what would make this control real).
 */
interface Props {
  tenantName: string;
  ariaLabel: string;
}

const { tenantName, ariaLabel } = Astro.props;
---

<div class="tenant-switcher">
  <label class="sr-only" for="tenant-switcher-select">{ariaLabel}</label>
  <select
    id="tenant-switcher-select"
    class="tenant-switcher-select"
    disabled
    aria-label={ariaLabel}
  >
    <option selected>{tenantName}</option>
  </select>
</div>

<style>
  .tenant-switcher-select {
    appearance: none;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--color-text);
    cursor: not-allowed;
  }
</style>
