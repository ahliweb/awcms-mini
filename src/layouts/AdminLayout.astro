---
/**
 * AdminLayout — SSR admin shell (Issue 8.1 — Build Admin Layout Shell;
 * responsive drawer sidebar + `TenantBadge` added by Issue #693, epic
 * #679 platform-hardening).
 *
 * Topbar (site name, tenant badge, sync indicator, theme toggle, user menu
 * + logout) + sidebar (permission-filtered nav, off-canvas drawer below
 * `--bp-md`) + breadcrumb + `<slot />` for page content, per
 * `docs/awcms-mini/14_ui_ux_design_system.md` §Layout shell / Admin shell.
 *
 * Auth: the actual "redirect to /login when there is no valid session"
 * check (doc 15 §Autentikasi dan sesi) lives in `src/middleware.ts`, not
 * here — see that file's comment for why. `Astro.locals.ssrContext` is
 * guaranteed set by the time this layout renders for a `/admin/*` route;
 * the throw below is a defensive invariant check, not a normal code path.
 *
 * SyncIndicator was a hardcoded `active={false}` stub until Issue 9.1
 * (Management Reporting), which is responsible for wiring it to real data
 * (see `src/components/SyncIndicator.astro`'s own comment). It now calls
 * `fetchSyncIndicatorActive`, a single lightweight `EXISTS` query — not the
 * full `GET /reports/sync-health` aggregation, since this layout renders on
 * every `/admin/*` request.
 *
 * Responsive sidebar/drawer (Issue #693): below `--bp-md` (768px) the
 * sidebar becomes an off-canvas drawer toggled by a hamburger button in the
 * topbar (`#admin-nav-toggle`) instead of always-visible static nav. The
 * inline `<script>` at the bottom wires open/close, a scrim
 * (`#admin-sidebar-scrim`) that closes on click, Escape-to-close, a manual
 * focus trap while open (Tab/Shift+Tab cycle within the drawer), focus
 * moved into the drawer on open and back to the toggle button on close, and
 * `inert` on the rest of the page (topbar/main) while the drawer covers the
 * screen — all mobile-only (checked via `window.matchMedia("(max-width:
 * 768px)")`); desktop keeps the pre-existing always-visible static sidebar
 * unchanged.
 */
import "../styles/tokens.css";
import TenantBadge from "../components/TenantBadge.astro";
import SyncIndicator from "../components/SyncIndicator.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import { getDatabaseClient } from "../lib/database/client";
import { withTenant } from "../lib/database/tenant-context";
import { fetchSyncIndicatorActive } from "../modules/reporting/application/sync-indicator";
import { fetchVisibleModuleNavigationEntries } from "../modules/module-management/application/navigation-registry";
import { createTranslator } from "../lib/i18n/translate";
import { THEME_INIT_SCRIPT_BODY } from "../lib/security/theme-init-script";

interface Props {
  title: string;
}

const { title } = Astro.props;

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "AdminLayout rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this layout ever runs."
  );
}

const sql = getDatabaseClient();

// Issue #434 (UX/UI audit): these two lightweight lookups back the topbar
// chrome that every single `/admin/*` request renders — a transient DB
// hiccup here previously took the whole page down with an unhandled 500
// instead of degrading gracefully. Neither value is essential to the page
// being usable (tenant name is cosmetic, sync indicator is informational),
// so a failure falls back to a safe default rather than failing the request.
let tenantName = "Tenant";
let tenantDefaultTheme = "system";
try {
  const rows = await withTenant(
    sql,
    context.tenantId,
    (tx) => tx`
      SELECT tenant_name, default_theme FROM awcms_mini_tenants WHERE id = ${context.tenantId}
    `
  );
  tenantName = (rows[0]?.tenant_name as string | undefined) ?? tenantName;
  tenantDefaultTheme =
    (rows[0]?.default_theme as string | undefined) ?? tenantDefaultTheme;
} catch (error) {
  console.error("AdminLayout: failed to load tenant profile", error);
}

let syncActive = false;
try {
  syncActive = await withTenant(sql, context.tenantId, (tx) =>
    fetchSyncIndicatorActive(tx, context.tenantId)
  );
} catch (error) {
  console.error("AdminLayout: failed to load sync indicator state", error);
}

// Issue #518 — module-declared nav entries (currently just
// `module_management`'s own `/admin/modules`), appended after the 4
// existing hardcoded items below. Same defensive pattern as
// tenantName/syncActive above: a failure here must never hide the
// hardcoded items or otherwise lock an admin out, so it falls back to an
// empty list rather than failing the whole page.
let moduleNavEntries: Awaited<
  ReturnType<typeof fetchVisibleModuleNavigationEntries>
> = [];
try {
  moduleNavEntries = await withTenant(sql, context.tenantId, (tx) =>
    fetchVisibleModuleNavigationEntries(
      tx,
      context.tenantId,
      context.permissions
    )
  );
} catch (error) {
  console.error("AdminLayout: failed to load module navigation entries", error);
}

// i18n (Issue #433): already fully resolved (cookie -> tenant default -> en)
// by src/middleware.ts before this layout — and before the page nested
// inside it — ever rendered. Do NOT re-resolve here: the page's own
// frontmatter runs first and would use a stale/less-complete value if this
// layout were the only place doing the tenant-fallback lookup (found during
// live verification).
const locale = Astro.locals.locale;
const t = await createTranslator(locale);

const permissionList = Array.from(context.permissions);
const hasAccessMenu = permissionList.some((key) =>
  key.startsWith("identity_access.")
);
const hasSyncMenu = permissionList.some((key) =>
  key.startsWith("sync_storage.")
);

const pathname = Astro.url.pathname;
const isDashboardActive = pathname === "/admin";
const isAccessUsersActive = pathname === "/admin/access-users";
const isSyncActive = pathname === "/admin/sync";
const isSettingsActive = pathname === "/admin/settings";
---

<!doctype html>
<html lang={locale} data-tenant-default-theme={tenantDefaultTheme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · AWCMS-Mini</title>
    {
      /*
        Theme resolution — runs before paint to prevent a flash of the
        wrong theme (doc 14 §Theming). Reads localStorage first (the user's
        personal per-browser override, set by ThemeToggle.astro — always
        wins once present); falls back to the tenant's
        `awcms_mini_tenants.default_theme` (editable at /admin/settings,
        Settings PR, exposed above as the `data-tenant-default-theme`
        attribute on <html>, read by the script below) for a browser that
        has never picked a theme. Resolves against prefers-color-scheme
        when the effective value is "system", and sets data-theme on
        <html>. `is:inline` keeps this script exactly as authored (no
        bundling/defer) so it executes synchronously here in <head>, ahead
        of body paint.

        CSP note (Issue #437): every inline `<script>`/`<style>` Astro
        emits per-component (`ThemeToggle.astro`, `LanguageSwitcher.astro`,
        the logout button's script below) is covered by Astro's own
        built-in `security.csp` feature (`astro.config.mjs`), which hashes
        whatever it actually inlines at build time and sets a real
        `Content-Security-Policy` response header for this SSR build. THIS
        script is the one exception — real headless-Chrome verification
        found Astro's own hashing does not cover `is:inline` scripts at all
        (by design: `is:inline` opts a script out of Astro's processing
        pipeline, and Astro can only hash what it processes). Its body
        (`THEME_INIT_SCRIPT_BODY`, `src/lib/security/theme-init-script.ts`)
        is therefore inlined verbatim via `set:html` — never hand-authored
        a second time here — and its hash is registered manually via
        `security.csp.scriptDirective.hashes` in `astro.config.mjs`. That
        module also explains why the body reads its server-computed
        default from the `data-tenant-default-theme` HTML attribute above
        instead of `define:vars` textual interpolation: it keeps this
        script's bytes identical on every request (no per-tenant
        variation), so the one manually-registered hash is correct for
        every tenant, not just whichever value happened to be used when it
        was computed.
      */
    }
    <script is:inline set:html={THEME_INIT_SCRIPT_BODY} />
  </head>
  <body>
    <a href="#admin-main-content" class="skip-link">
      {t("admin.layout.skip_to_content")}
    </a>
    <div class="admin-shell">
      <header class="admin-topbar">
        <button
          type="button"
          id="admin-nav-toggle"
          class="admin-nav-toggle"
          aria-expanded="false"
          aria-controls="admin-sidebar-nav"
          aria-label={t("admin.layout.nav_toggle_aria_label")}
        >
          <span class="admin-nav-toggle-icon" aria-hidden="true">☰</span>
        </button>
        <span class="admin-topbar-brand">AWCMS-Mini</span>
        <TenantBadge
          tenantName={tenantName}
          ariaLabel={t("admin.layout.active_tenant_aria_label")}
        />
        <div class="admin-topbar-spacer"></div>
        <SyncIndicator
          active={syncActive}
          activeLabel={t("admin.layout.sync_active")}
          inactiveLabel={t("admin.layout.sync_inactive")}
        />
        <ThemeToggle
          ariaLabel={t("admin.layout.theme_toggle_aria_label")}
          systemLabel={t("admin.layout.theme_system")}
          lightLabel={t("admin.layout.theme_light")}
          darkLabel={t("admin.layout.theme_dark")}
        />
        <LanguageSwitcher
          currentLocale={locale}
          ariaLabel={t("admin.layout.language_switcher_aria_label")}
        />
        <div class="admin-user-menu">
          <span class="admin-user-menu-roles">
            {
              context.roles.length > 0
                ? context.roles.join(", ")
                : t("admin.layout.no_role")
            }
          </span>
          <button
            type="button"
            id="admin-logout-button"
            class="admin-logout-button"
          >
            {t("admin.layout.logout")}
          </button>
        </div>
      </header>
      <div class="admin-body">
        <div
          id="admin-sidebar-scrim"
          class="admin-sidebar-scrim"
          data-open="false"
          aria-hidden="true"
          hidden
        >
        </div>
        <nav
          id="admin-sidebar-nav"
          class="admin-sidebar"
          data-open="false"
          aria-label={t("admin.layout.nav_aria_label")}
        >
          <ul>
            <li>
              <a
                href="/admin"
                aria-current={isDashboardActive ? "page" : undefined}
              >
                {t("admin.layout.nav_dashboard")}
              </a>
            </li>
            {
              hasAccessMenu && (
                <li>
                  <a
                    href="/admin/access-users"
                    aria-current={isAccessUsersActive ? "page" : undefined}
                  >
                    {t("admin.layout.nav_access_users")}
                  </a>
                </li>
              )
            }
            {
              hasSyncMenu && (
                <li>
                  <a
                    href="/admin/sync"
                    aria-current={isSyncActive ? "page" : undefined}
                  >
                    {t("admin.layout.nav_sync")}
                  </a>
                </li>
              )
            }
            <li>
              <a
                href="/admin/settings"
                aria-current={isSettingsActive ? "page" : undefined}
              >
                {t("admin.layout.nav_settings")}
              </a>
            </li>
            {
              moduleNavEntries.map((entry) => (
                <li>
                  <a
                    href={entry.path}
                    aria-current={pathname === entry.path ? "page" : undefined}
                  >
                    {t(entry.labelKey)}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <main class="admin-main">
          <nav
            class="admin-breadcrumb"
            aria-label={t("admin.layout.breadcrumb_aria_label")}
          >
            <ol>
              <li><a href="/admin">AWCMS-Mini</a></li>
              <li aria-current="page">{title}</li>
            </ol>
          </nav>
          <div id="admin-main-content" class="admin-content" tabindex="-1">
            <slot />
          </div>
        </main>
      </div>
    </div>
    <script>
      document
        .getElementById("admin-logout-button")
        ?.addEventListener("click", async () => {
          try {
            // Content-Type is required even for an empty body: Astro's
            // built-in checkOrigin CSRF guard rejects POST requests without
            // it (see src/modules/identity-access/README.md §Catatan
            // operasional). Cookies are same-origin and sent automatically.
            await fetch("/api/v1/auth/logout", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "same-origin"
            });
          } finally {
            window.location.href = "/login";
          }
        });

      // Responsive sidebar/drawer (Issue #693) — mobile-only (below
      // `--bp-md`/768px, mirrored here since CSS custom properties can't be
      // read as an @media condition). Desktop keeps the sidebar statically
      // visible and none of this runs.
      const navToggle = document.getElementById("admin-nav-toggle");
      const sidebar = document.getElementById("admin-sidebar-nav");
      const scrim = document.getElementById("admin-sidebar-scrim");
      const topbar = document.querySelector(".admin-topbar");
      const main = document.querySelector(".admin-main");
      const mobileQuery = window.matchMedia("(max-width: 768px)");

      function isMobileDrawer(): boolean {
        return mobileQuery.matches;
      }

      function setInertSafely(el: Element | null, value: boolean): void {
        if (!el) return;
        if ("inert" in el) {
          (el as HTMLElement).inert = value;
        } else if (value) {
          el.setAttribute("aria-hidden", "true");
        } else {
          el.removeAttribute("aria-hidden");
        }
      }

      function openDrawer(): void {
        if (!sidebar) return;
        sidebar.dataset.open = "true";
        navToggle?.setAttribute("aria-expanded", "true");
        if (scrim) {
          scrim.dataset.open = "true";
          scrim.hidden = false;
        }
        if (isMobileDrawer()) {
          setInertSafely(topbar, true);
          setInertSafely(main, true);
          const firstFocusable = sidebar.querySelector<HTMLElement>(
            "a[href], button:not([disabled])"
          );
          firstFocusable?.focus();
        }
      }

      function closeDrawer(options: { restoreFocus?: boolean } = {}): void {
        const { restoreFocus = true } = options;
        if (!sidebar) return;
        sidebar.dataset.open = "false";
        navToggle?.setAttribute("aria-expanded", "false");
        if (scrim) {
          scrim.dataset.open = "false";
          scrim.hidden = true;
        }
        setInertSafely(topbar, false);
        setInertSafely(main, false);
        if (restoreFocus) navToggle?.focus();
      }

      navToggle?.addEventListener("click", () => {
        const isOpen = sidebar?.dataset.open === "true";
        if (isOpen) {
          closeDrawer();
        } else {
          openDrawer();
        }
      });

      scrim?.addEventListener("click", () => closeDrawer());

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Escape") return;
        if (sidebar?.dataset.open === "true" && isMobileDrawer()) {
          closeDrawer();
        }
      });

      // Manual focus trap while the drawer is open on mobile — native
      // `<dialog>` gives this for free (see `ConfirmDialog.astro`), but the
      // sidebar must stay a plain `<nav>` (always statically visible on
      // desktop, never modal there), so the trap is hand-wired here instead.
      sidebar?.addEventListener("keydown", (event: KeyboardEvent) => {
        if (
          event.key !== "Tab" ||
          !isMobileDrawer() ||
          sidebar.dataset.open !== "true"
        ) {
          return;
        }

        const focusables = Array.from(
          sidebar.querySelectorAll<HTMLElement>(
            "a[href], button:not([disabled])"
          )
        );
        if (focusables.length === 0) return;

        const first = focusables[0]!;
        const last = focusables[focusables.length - 1]!;

        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      });

      // If the viewport grows past the mobile breakpoint while the drawer
      // is open, drop the mobile-only open/inert/scrim state so desktop's
      // always-visible sidebar isn't left `inert` or hidden behind a scrim.
      mobileQuery.addEventListener("change", (event) => {
        if (!event.matches) {
          closeDrawer({ restoreFocus: false });
        }
      });
    </script>
  </body>
</html>

<style>
  /* Skip link (doc 14 §Keyboard-only) — visually hidden until it receives
     keyboard focus, then jumps above the topbar/sidebar so a keyboard user
     doesn't have to tab through the whole nav on every page. */
  .skip-link {
    position: absolute;
    top: -100px;
    left: var(--sp-2);
    z-index: var(--z-toast);
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    padding: var(--sp-2) var(--sp-4);
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-weight: 600;
  }

  .skip-link:focus {
    top: var(--sp-2);
  }

  .admin-shell {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .admin-topbar {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-2) var(--sp-4);
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  /* Hamburger drawer toggle (Issue #693) — hidden by default (desktop:
     sidebar is always visible, nothing to toggle); shown only below
     `--bp-md` via the media query further down. `display: none` also
     removes it from the desktop tab order automatically, so no extra
     `tabindex`/`aria-hidden` bookkeeping is needed for that breakpoint. */
  .admin-nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--fs-lg);
    line-height: 1;
    color: var(--color-text);
    cursor: pointer;
  }

  .admin-nav-toggle:hover {
    background: var(--color-surface-2);
  }

  .admin-nav-toggle:focus-visible {
    outline: 3px solid var(--color-focus);
    outline-offset: 2px;
  }

  .admin-topbar-brand {
    font-weight: 700;
    font-size: var(--fs-md);
  }

  .admin-topbar-spacer {
    flex: 1;
  }

  .admin-user-menu {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .admin-user-menu-roles {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
  }

  .admin-logout-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    cursor: pointer;
  }

  .admin-logout-button:hover {
    background: var(--color-danger-strong);
    color: var(--color-primary-contrast);
    border-color: var(--color-danger-strong);
  }

  /* Touch target >= 44px on tablet/mobile (doc 14 §Aksesibilitas), plus the
     off-canvas drawer pattern itself (Issue #693): below this breakpoint
     the sidebar becomes a fixed, full-height panel that slides in from the
     left (`transform`, toggled by the `data-open` attribute the inline
     `<script>` above sets), covering the topbar too (`--z-drawer` >
     `--z-nav`) so there is nothing interactive left showing behind it
     besides the scrim. Above this breakpoint none of this applies — the
     sidebar stays the static, always-visible column it always was. */
  @media (max-width: 768px) {
    .admin-nav-toggle {
      display: inline-flex;
    }

    .admin-logout-button {
      min-height: 44px;
    }

    .admin-sidebar a {
      min-height: 44px;
      box-sizing: border-box;
      display: flex;
      align-items: center;
    }

    .admin-sidebar {
      position: fixed;
      top: 0;
      bottom: 0;
      left: 0;
      width: min(280px, 85vw);
      z-index: var(--z-drawer);
      box-shadow: var(--shadow-lg);
      overflow-y: auto;
      transform: translateX(-100%);
      transition: transform 0.2s ease;
    }

    .admin-sidebar[data-open="true"] {
      transform: translateX(0);
    }

    .admin-sidebar-scrim {
      position: fixed;
      inset: 0;
      z-index: calc(var(--z-drawer) - 1);
      background: rgba(15, 23, 42, 0.5);
    }
  }

  /* Desktop/tablet: the scrim never renders regardless of its `data-open`
     state (there is no drawer to dim behind on a statically-visible
     sidebar) — belt-and-suspenders alongside the `hidden` attribute the
     script also sets/clears. */
  @media (min-width: 769px) {
    .admin-sidebar-scrim {
      display: none;
    }
  }

  .admin-body {
    display: flex;
    flex: 1;
  }

  .admin-sidebar {
    width: 220px;
    flex-shrink: 0;
    background: var(--color-surface);
    border-right: 1px solid var(--color-border);
    padding: var(--sp-4) var(--sp-2);
  }

  .admin-sidebar ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .admin-sidebar a {
    display: block;
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    text-decoration: none;
  }

  .admin-sidebar a:hover {
    background: var(--color-surface-2);
  }

  .admin-sidebar a[aria-current="page"] {
    /* `-strong` (not the plain `--color-primary`) — Issue #434's own audit
       measured the plain token at only ~3.68:1 with white text in dark
       theme, below WCAG AA's 4.5:1; see tokens.css's own comment. Found
       while touching this selector for Issue #693's drawer rewrite. */
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
  }

  .admin-main {
    flex: 1;
    padding: var(--sp-4);
    min-width: 0;
  }

  .admin-breadcrumb ol {
    list-style: none;
    display: flex;
    gap: var(--sp-1);
    margin: 0 0 var(--sp-4);
    padding: 0;
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  .admin-breadcrumb li + li::before {
    content: "/";
    margin-right: var(--sp-1);
  }

  .admin-breadcrumb a {
    color: var(--color-text-muted);
  }

  .admin-content {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-4);
  }
</style>
