---
/**
 * Sync admin screen — ops dashboard over the sync-storage module: node
 * registry (activate/deactivate), open conflicts (resolve), and the object
 * upload queue (manual retry for failed entries).
 *
 * Sync itself is node-to-node (HMAC-authenticated, machine callers, see
 * sync-storage/README.md §Autentikasi berbeda dari endpoint lain) — nothing
 * here talks to a node directly. This page is entirely about the human
 * oversight layer: reviewing state a node reported and making judgment calls
 * (deactivate a lost device, resolve a conflict, retry a stuck upload).
 *
 * Summary tiles reuse `fetchSyncHealthReport` (Issue 9.1) — the exact same
 * aggregation `admin/index.astro`'s dashboard card and `GET /reports/sync-health`
 * already use, so this page adds no duplicate counting query. The three
 * detail tables (nodes/conflicts/object-queue) reuse the same application-layer
 * functions the JSON endpoints call (`sync-directory.ts`), matching the
 * `user-directory.ts` pattern from `/admin/access-users`.
 *
 * Permission-gated per-section (defense-in-depth — the endpoints are the
 * real enforcement):
 *   - sync_storage.node_management.{read,update}
 *   - sync_storage.conflict_resolution.{read,approve}
 *   - sync_storage.object_queue.{read,retry}
 */
import AdminLayout from "../../layouts/AdminLayout.astro";
import StateNotice from "../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../lib/database/client";
import { withTenant } from "../../lib/database/tenant-context";
import { permissionKey } from "../../modules/identity-access/domain/access-control";
import { fetchSyncHealthReport } from "../../modules/reporting/application/sync-health-report";
import {
  fetchObjectQueueEntries,
  fetchSyncNodes
} from "../../modules/sync-storage/application/sync-directory";
import { createTranslator } from "../../lib/i18n/translate";
import { buildClientErrorMessages } from "../../lib/i18n/error-messages";
import { formatDateTime } from "../../lib/i18n/format";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/sync.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const locale = Astro.locals.locale;
const t = await createTranslator(locale);

const clientStrings = {
  updateNodeSuccess: t("admin.sync.update_node_success"),
  resolveConflictSuccess: t("admin.sync.resolve_conflict_success"),
  retryObjectSuccess: t("admin.sync.retry_object_success"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

const CAN_READ_NODES = context.permissions.has(
  permissionKey("sync_storage", "node_management", "read")
);
const CAN_UPDATE_NODES = context.permissions.has(
  permissionKey("sync_storage", "node_management", "update")
);
const CAN_READ_CONFLICTS = context.permissions.has(
  permissionKey("sync_storage", "conflict_resolution", "read")
);
const CAN_APPROVE_CONFLICTS = context.permissions.has(
  permissionKey("sync_storage", "conflict_resolution", "approve")
);
const CAN_READ_QUEUE = context.permissions.has(
  permissionKey("sync_storage", "object_queue", "read")
);
const CAN_RETRY_QUEUE = context.permissions.has(
  permissionKey("sync_storage", "object_queue", "retry")
);

const hasAnyAccess = CAN_READ_NODES || CAN_READ_CONFLICTS || CAN_READ_QUEUE;

// Issue #434 (UX/UI audit) — see `admin/access-users.astro` for the same
// pattern: distinguish "denied" (no permission) from "error" (transient DB
// failure) so the page can show the doc 14 §State pattern wajib Error
// branch instead of an unhandled 500.
type OpenConflictRow = {
  id: string;
  node_id: string;
  batch_id: string;
  aggregate_type: string;
  aggregate_id: string;
  conflict_type: string;
  payload_json: unknown;
  created_at: Date;
};

let data: {
  health: Awaited<ReturnType<typeof fetchSyncHealthReport>>;
  nodes: Awaited<ReturnType<typeof fetchSyncNodes>>;
  openConflicts: OpenConflictRow[];
  failedObjects: Awaited<ReturnType<typeof fetchObjectQueueEntries>>;
} | null = null;
let loadError = false;

if (hasAnyAccess) {
  try {
    data = await withTenant(
      getDatabaseClient(),
      context.tenantId,
      async (tx) => ({
        health: await fetchSyncHealthReport(tx, context.tenantId),
        nodes: CAN_READ_NODES ? await fetchSyncNodes(tx, context.tenantId) : [],
        openConflicts: CAN_READ_CONFLICTS
          ? ((await tx`
            SELECT id, node_id, batch_id, aggregate_type, aggregate_id, conflict_type,
                   payload_json, created_at
            FROM awcms_mini_sync_conflicts
            WHERE tenant_id = ${context.tenantId} AND status = 'open'
            ORDER BY created_at DESC
            LIMIT 50
          `) as OpenConflictRow[])
          : [],
        failedObjects: CAN_READ_QUEUE
          ? await fetchObjectQueueEntries(tx, context.tenantId, "failed")
          : []
      })
    );
  } catch (error) {
    console.error("admin/sync.astro: failed to load data", error);
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.layout.nav_sync")}>
  {
    !hasAnyAccess && (
      <StateNotice
        kind="denied"
        title={t("admin.sync.access_denied_title")}
        body={t("admin.sync.access_denied_body")}
      />
    )
  }
  {
    hasAnyAccess && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    data && (
      <div class="sync-admin">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        <section class="sync-section">
          <h2>{t("admin.sync.summary_title")}</h2>
          <div class="health-grid">
            <div class="health-tile">
              <dt>{t("admin.dashboard.active_nodes_label")}</dt>
              <dd>
                {data.health.activeNodeCount} / {data.health.totalNodeCount}
              </dd>
            </div>
            <div class="health-tile">
              <dt>{t("admin.dashboard.open_conflicts_label")}</dt>
              <dd>{data.health.openConflictCount}</dd>
            </div>
            <div class="health-tile">
              <dt>{t("admin.dashboard.pending_objects_label")}</dt>
              <dd>{data.health.pendingObjectCount}</dd>
            </div>
            <div class="health-tile">
              <dt>{t("admin.dashboard.failed_objects_label")}</dt>
              <dd>{data.health.failedObjectCount}</dd>
            </div>
            <div class="health-tile">
              <dt>{t("admin.dashboard.status_label")}</dt>
              <dd>
                {data.health.isHealthy
                  ? t("admin.dashboard.status_healthy")
                  : t("admin.dashboard.status_needs_attention")}
              </dd>
            </div>
          </div>
        </section>

        {CAN_READ_NODES && (
          <section class="sync-section">
            <h2>{t("admin.sync.nodes_title")}</h2>
            <div class="table-scroll">
              <table class="sync-table">
                <thead>
                  <tr>
                    <th>{t("admin.sync.node_column")}</th>
                    <th>{t("admin.access_users.code_column")}</th>
                    <th>{t("admin.access_users.status_column")}</th>
                    <th>{t("admin.sync.last_pushed_column")}</th>
                    <th>{t("admin.sync.last_pulled_column")}</th>
                    {CAN_UPDATE_NODES && (
                      <th>{t("admin.access_users.actions_column")}</th>
                    )}
                  </tr>
                </thead>
                <tbody>
                  {data.nodes.length === 0 && (
                    <tr>
                      <td colspan={CAN_UPDATE_NODES ? 6 : 5}>
                        {t("admin.sync.no_nodes")}
                      </td>
                    </tr>
                  )}
                  {data.nodes.map((node) => (
                    <tr>
                      <td>{node.nodeName}</td>
                      <td>
                        <code>{node.nodeCode}</code>
                      </td>
                      <td>
                        <span class="status-pill" data-status={node.status}>
                          {node.status === "active"
                            ? t("common.status_active")
                            : t("common.status_inactive")}
                        </span>
                      </td>
                      <td>
                        {node.lastPushedAt
                          ? formatDateTime(new Date(node.lastPushedAt), locale)
                          : "-"}
                      </td>
                      <td>
                        {node.lastPulledAt
                          ? formatDateTime(new Date(node.lastPulledAt), locale)
                          : "-"}
                      </td>
                      {CAN_UPDATE_NODES && (
                        <td>
                          <button
                            type="button"
                            class="toggle-node-button"
                            data-toggle-node={node.nodeId}
                            data-next-status={
                              node.status === "active" ? "inactive" : "active"
                            }
                          >
                            {node.status === "active"
                              ? t("admin.access_users.deactivate_button")
                              : t("admin.access_users.activate_button")}
                          </button>
                        </td>
                      )}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {CAN_READ_CONFLICTS && (
          <section class="sync-section">
            <h2>{t("admin.sync.open_conflicts_title")}</h2>
            <div class="table-scroll">
              <table class="sync-table">
                <thead>
                  <tr>
                    <th>{t("admin.sync.aggregate_column")}</th>
                    <th>{t("admin.sync.conflict_type_column")}</th>
                    <th>{t("admin.sync.batch_column")}</th>
                    <th>{t("admin.sync.created_column")}</th>
                    {CAN_APPROVE_CONFLICTS && (
                      <th>{t("admin.sync.resolution_column")}</th>
                    )}
                  </tr>
                </thead>
                <tbody>
                  {data.openConflicts.length === 0 && (
                    <tr>
                      <td colspan={CAN_APPROVE_CONFLICTS ? 5 : 4}>
                        {t("admin.sync.no_open_conflicts")}
                      </td>
                    </tr>
                  )}
                  {data.openConflicts.map((conflict) => (
                    <tr>
                      <td>
                        {conflict.aggregate_type} <br />
                        <code>{conflict.aggregate_id}</code>
                      </td>
                      <td>{conflict.conflict_type}</td>
                      <td>{conflict.batch_id}</td>
                      <td>{formatDateTime(conflict.created_at, locale)}</td>
                      {CAN_APPROVE_CONFLICTS && (
                        <td>
                          <form
                            class="resolve-conflict-form"
                            data-conflict-id={conflict.id}
                          >
                            <select name="resolution" required>
                              <option value="accept_incoming">
                                {t("admin.sync.resolution_accept_incoming")}
                              </option>
                              <option value="keep_existing">
                                {t("admin.sync.resolution_keep_existing")}
                              </option>
                              <option value="manual">
                                {t("admin.sync.resolution_manual")}
                              </option>
                            </select>
                            <input
                              type="text"
                              name="note"
                              placeholder={t(
                                "admin.sync.resolution_note_placeholder"
                              )}
                            />
                            <button type="submit">
                              {t("admin.sync.resolve_button")}
                            </button>
                          </form>
                        </td>
                      )}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {CAN_READ_QUEUE && (
          <section class="sync-section">
            <h2>{t("admin.sync.failed_queue_title")}</h2>
            <div class="table-scroll">
              <table class="sync-table">
                <thead>
                  <tr>
                    <th>{t("admin.sync.node_column")}</th>
                    <th>{t("admin.sync.object_key_column")}</th>
                    <th>{t("admin.sync.retry_column")}</th>
                    <th>{t("admin.sync.last_error_column")}</th>
                    {CAN_RETRY_QUEUE && (
                      <th>{t("admin.access_users.actions_column")}</th>
                    )}
                  </tr>
                </thead>
                <tbody>
                  {data.failedObjects.length === 0 && (
                    <tr>
                      <td colspan={CAN_RETRY_QUEUE ? 5 : 4}>
                        {t("admin.sync.no_failed_objects")}
                      </td>
                    </tr>
                  )}
                  {data.failedObjects.map((entry) => (
                    <tr>
                      <td>
                        <code>{entry.nodeCode}</code>
                      </td>
                      <td>{entry.objectKey}</td>
                      <td>{entry.retryCount}</td>
                      <td>{entry.lastError ?? "-"}</td>
                      {CAN_RETRY_QUEUE && (
                        <td>
                          <button
                            type="button"
                            class="retry-object-button"
                            data-retry-object={entry.objectQueueId}
                          >
                            {t("admin.sync.retry_button")}
                          </button>
                        </td>
                      )}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .sync-admin {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
  }

  .action-banner[data-variant="success"] {
    background: color-mix(
      in srgb,
      var(--color-success) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-success);
  }

  .action-banner[data-variant="error"] {
    background: color-mix(
      in srgb,
      var(--color-danger) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-danger);
  }

  .sync-section h2 {
    margin: 0 0 var(--sp-3);
    font-size: var(--fs-md);
  }

  .health-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--sp-3);
  }

  .health-tile {
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }

  .health-tile dt {
    color: var(--color-text-muted);
    font-size: var(--fs-sm);
    margin: 0 0 var(--sp-1);
  }

  .health-tile dd {
    margin: 0;
    font-weight: 600;
    font-size: var(--fs-lg);
  }

  /* Responsive (doc 14 §Responsif) — wide tables scroll in their own
     container instead of forcing the whole page to scroll horizontally. */
  .table-scroll {
    overflow-x: auto;
  }

  .sync-table {
    width: 100%;
    border-collapse: collapse;
  }

  .sync-table th,
  .sync-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--fs-sm);
    vertical-align: top;
  }

  /* Solid-fill badge — see `admin/access-users.astro`'s `.status-pill`
     comment (Issue #434 UX/UI audit): text-on-tint failed WCAG AA contrast
     in both themes; the "-strong" tokens are tuned for white text on a
     solid fill. */
  .status-pill {
    display: inline-block;
    padding: 0 var(--sp-2);
    border-radius: var(--radius-full);
    font-size: var(--fs-xs);
    color: var(--color-primary-contrast);
  }

  .status-pill[data-status="active"] {
    background: var(--color-success-strong);
  }

  .status-pill[data-status="inactive"] {
    background: var(--color-danger-strong);
  }

  .toggle-node-button,
  .retry-object-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-2);
    cursor: pointer;
    font-size: var(--fs-xs);
  }

  .resolve-conflict-form {
    display: flex;
    gap: var(--sp-1);
    flex-wrap: wrap;
  }

  .resolve-conflict-form select,
  .resolve-conflict-form input,
  .resolve-conflict-form button {
    font-size: var(--fs-xs);
  }

  .toggle-node-button:disabled,
  .retry-object-button:disabled,
  .resolve-conflict-form button:disabled {
    cursor: not-allowed;
    opacity: 0.7;
  }

  /* Touch target >= 44px on tablet/mobile (doc 14 §Aksesibilitas). */
  @media (max-width: 768px) {
    .toggle-node-button,
    .retry-object-button,
    .resolve-conflict-form button {
      min-height: 44px;
      min-width: 44px;
    }
  }
</style>

<script>
  // Issue #434 (UX/UI audit) — see `admin/access-users.astro` for why this
  // is now a shared import instead of a duplicated inline implementation,
  // and why every mutation locks its trigger button for the duration of the
  // request (doc 14 §Form UX "cegah double-submit").
  import {
    lockElement,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../lib/ui/admin-form-client";

  interface SyncStrings {
    updateNodeSuccess: string;
    resolveConflictSuccess: string;
    retryObjectSuccess: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<SyncStrings>();

  document.querySelectorAll(".toggle-node-button").forEach((button) => {
    button.addEventListener("click", async () => {
      const el = button as HTMLButtonElement;
      if (el.disabled) return;
      const unlock = lockElement(el, strings.pleaseWait);

      try {
        const nodeId = el.dataset.toggleNode!;
        const nextStatus = el.dataset.nextStatus!;

        const result = await submitJson(
          `/api/v1/sync/nodes/${nodeId}`,
          "PATCH",
          { status: nextStatus },
          strings
        );
        showBanner(
          "action-banner",
          result.ok ? strings.updateNodeSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock();
      }
    });
  });

  document.querySelectorAll(".resolve-conflict-form").forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const el = event.target as HTMLFormElement;
      const button = el.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (button?.disabled) return;
      const unlock = button ? lockElement(button, strings.pleaseWait) : null;

      try {
        const conflictId = el.dataset.conflictId!;
        const formData = new FormData(el);
        const note = formData.get("note");

        const result = await submitJson(
          `/api/v1/sync/conflicts/${conflictId}/resolve`,
          "POST",
          {
            resolution: formData.get("resolution"),
            note: typeof note === "string" && note.length > 0 ? note : undefined
          },
          strings
        );
        showBanner(
          "action-banner",
          result.ok ? strings.resolveConflictSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock?.();
      }
    });
  });

  document.querySelectorAll(".retry-object-button").forEach((button) => {
    button.addEventListener("click", async () => {
      const el = button as HTMLButtonElement;
      if (el.disabled) return;
      const unlock = lockElement(el, strings.pleaseWait);

      try {
        const objectQueueId = el.dataset.retryObject!;

        const result = await submitJson(
          `/api/v1/sync/object-queue/${objectQueueId}/retry`,
          "POST",
          {},
          strings
        );
        showBanner(
          "action-banner",
          result.ok ? strings.retryObjectSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock();
      }
    });
  });
</script>
