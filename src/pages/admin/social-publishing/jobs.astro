---
/**
 * Social publish job monitor (Issue #643 acceptance criterion: "Admin UI
 * shows accounts, rules, jobs, attempts, external IDs, and safe error
 * messages"). Approve/cancel/retry are high-risk mutations requiring a
 * fresh `Idempotency-Key` per submit, same pattern
 * `admin/tenant/domains.astro`'s verify/set-primary buttons use.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import {
  listSocialPublishAttemptsForJob,
  listSocialPublishJobs,
  type SocialPublishAttemptView
} from "../../../modules/social-publishing/application/social-publish-job-directory";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/social-publishing/jobs.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("social_publishing", "jobs", "read")
);
const CAN_APPROVE = context.permissions.has(
  permissionKey("social_publishing", "jobs", "approve")
);
const CAN_CANCEL = context.permissions.has(
  permissionKey("social_publishing", "jobs", "cancel")
);
const CAN_RETRY = context.permissions.has(
  permissionKey("social_publishing", "jobs", "retry")
);

const clientStrings = {
  approveSuccess: t("admin.social_publishing.jobs.approve_success"),
  cancelSuccess: t("admin.social_publishing.jobs.cancel_success"),
  retrySuccess: t("admin.social_publishing.jobs.retry_success"),
  cancelReasonPrompt: t("admin.social_publishing.jobs.cancel_reason_prompt"),
  cancelConfirm: t("admin.social_publishing.jobs.cancel_confirm"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

const JOBS_LIST_LIMIT = 100;

let jobs: Awaited<ReturnType<typeof listSocialPublishJobs>> = [];
let attemptsByJobId = new Map<string, SocialPublishAttemptView[]>();
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      jobs = await listSocialPublishJobs(tx, context.tenantId, {
        limit: JOBS_LIST_LIMIT
      });

      for (const job of jobs) {
        attemptsByJobId.set(
          job.id,
          await listSocialPublishAttemptsForJob(tx, context.tenantId, job.id)
        );
      }
    });
  } catch (error) {
    logAdminPageError(
      "admin/social-publishing/jobs.astro: failed to load jobs",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.social_publishing.jobs.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.social_publishing.access_denied_title")}
        body={t("admin.social_publishing.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="config-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        {jobs.length === 0 ? (
          <p class="empty-state">{t("admin.social_publishing.jobs.no_jobs")}</p>
        ) : (
          jobs.map((job) => (
            <section class="section-card">
              <h2>
                {job.title}{" "}
                <span class="status-badge" data-status={job.status}>
                  {job.status}
                </span>
              </h2>
              <p class="job-meta">
                {job.providerKey} · {job.triggerEvent} ·{" "}
                {t("admin.social_publishing.jobs.field_attempts")}:{" "}
                {job.attemptCount}/{job.maxAttempts}
              </p>
              {job.externalPostUrl && (
                <p class="job-meta">
                  {t("admin.social_publishing.jobs.field_external_url")}:{" "}
                  <a
                    href={job.externalPostUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {job.externalPostUrl}
                  </a>
                </p>
              )}
              {job.lastErrorMessage && (
                <p class="job-error">
                  {job.lastErrorCode}: {job.lastErrorMessage}
                </p>
              )}
              <div class="job-actions">
                {CAN_APPROVE && job.status === "requires_approval" && (
                  <button type="button" class="approve-button" data-id={job.id}>
                    {t("admin.social_publishing.jobs.approve_button")}
                  </button>
                )}
                {CAN_RETRY &&
                  ["failed", "rate_limited", "needs_reauth"].includes(
                    job.status
                  ) && (
                    <button type="button" class="retry-button" data-id={job.id}>
                      {t("admin.social_publishing.jobs.retry_button")}
                    </button>
                  )}
                {CAN_CANCEL &&
                  !["published", "cancelled", "skipped"].includes(
                    job.status
                  ) && (
                    <button
                      type="button"
                      class="cancel-button"
                      data-id={job.id}
                    >
                      {t("admin.social_publishing.jobs.cancel_button")}
                    </button>
                  )}
              </div>
              {(attemptsByJobId.get(job.id) ?? []).length > 0 && (
                <details class="attempts-details">
                  <summary>
                    {t("admin.social_publishing.jobs.attempts_summary")}
                  </summary>
                  <table class="attempts-table">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>
                          {t("admin.social_publishing.jobs.field_outcome")}
                        </th>
                        <th>{t("admin.social_publishing.jobs.field_error")}</th>
                        <th>
                          {t("admin.social_publishing.jobs.field_started_at")}
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      {(attemptsByJobId.get(job.id) ?? []).map((attempt) => (
                        <tr>
                          <td>{attempt.attemptNumber}</td>
                          <td>{attempt.outcome}</td>
                          <td>{attempt.errorMessage ?? ""}</td>
                          <td>{attempt.startedAt.toISOString()}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </details>
              )}
            </section>
          ))
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
  }

  .action-banner[data-variant="success"] {
    background: color-mix(
      in srgb,
      var(--color-success) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-success);
  }

  .action-banner[data-variant="error"] {
    background: color-mix(
      in srgb,
      var(--color-danger) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-danger);
  }

  .empty-state {
    color: var(--color-text-muted);
  }

  .section-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }

  .section-card h2 {
    font-size: var(--fs-md);
    margin: 0 0 var(--sp-2);
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .status-badge {
    font-size: var(--fs-xs);
    font-weight: 400;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0 var(--sp-1);
  }

  .job-meta {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    margin: var(--sp-1) 0;
  }

  .job-error {
    font-size: var(--fs-sm);
    color: var(--color-danger-strong);
    margin: var(--sp-1) 0;
  }

  .job-actions {
    display: flex;
    gap: var(--sp-2);
    margin-top: var(--sp-2);
  }

  .approve-button,
  .retry-button {
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }

  .cancel-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }

  .attempts-details {
    margin-top: var(--sp-2);
  }

  .attempts-details summary {
    cursor: pointer;
    font-size: var(--fs-sm);
  }

  .attempts-table {
    margin-top: var(--sp-2);
    border-collapse: collapse;
    width: 100%;
    font-size: var(--fs-xs);
  }

  .attempts-table th,
  .attempts-table td {
    text-align: left;
    padding: var(--sp-1) var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }

  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface JobMonitorStrings {
    approveSuccess: string;
    cancelSuccess: string;
    retrySuccess: string;
    cancelReasonPrompt: string;
    cancelConfirm: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<JobMonitorStrings>();

  document.querySelectorAll(".approve-button").forEach((button) => {
    button.addEventListener("click", async () => {
      const el = button as HTMLButtonElement;
      if (el.disabled) return;

      const unlock = lockElement(el, strings.pleaseWait);
      try {
        const id = el.dataset.id!;
        const result = await submitJson(
          `/api/v1/social-publishing/jobs/${id}/approve`,
          "POST",
          {},
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );
        showBanner(
          "action-banner",
          result.ok ? strings.approveSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock();
      }
    });
  });

  document.querySelectorAll(".retry-button").forEach((button) => {
    button.addEventListener("click", async () => {
      const el = button as HTMLButtonElement;
      if (el.disabled) return;

      const unlock = lockElement(el, strings.pleaseWait);
      try {
        const id = el.dataset.id!;
        const result = await submitJson(
          `/api/v1/social-publishing/jobs/${id}/retry`,
          "POST",
          {},
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );
        showBanner(
          "action-banner",
          result.ok ? strings.retrySuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock();
      }
    });
  });

  document.querySelectorAll(".cancel-button").forEach((button) => {
    button.addEventListener("click", async () => {
      const el = button as HTMLButtonElement;
      if (el.disabled) return;

      const reason = window.prompt(strings.cancelReasonPrompt);
      if (!reason || reason.trim().length === 0) return;
      if (!window.confirm(strings.cancelConfirm)) return;

      const unlock = lockElement(el, strings.pleaseWait);
      try {
        const id = el.dataset.id!;
        const result = await submitJson(
          `/api/v1/social-publishing/jobs/${id}/cancel`,
          "POST",
          { reason },
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );
        showBanner(
          "action-banner",
          result.ok ? strings.cancelSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock();
      }
    });
  });
</script>
