---
/**
 * Document registry admin screen (Issue #751, epic #738
 * platform-evolution Wave 3). List + create + void + restore (undo
 * soft-delete or un-void). Reclassify, versions, relations, and evidence
 * history live on the per-document detail screen
 * (`documents/[id].astro`), linked from each row.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { listDocuments } from "../../../modules/document-infrastructure/application/document-directory";
import { listClassifications } from "../../../modules/document-infrastructure/application/document-classification-directory";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/document-infrastructure/documents.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("document_infrastructure", "documents", "read")
);
const CAN_CREATE = context.permissions.has(
  permissionKey("document_infrastructure", "documents", "create")
);
const CAN_VOID = context.permissions.has(
  permissionKey("document_infrastructure", "documents", "void")
);
const CAN_RESTORE = context.permissions.has(
  permissionKey("document_infrastructure", "documents", "restore")
);

const clientStrings = {
  createSuccess: t("admin.document_infrastructure.documents.create_success"),
  voidSuccess: t("admin.document_infrastructure.documents.void_success"),
  restoreSuccess: t("admin.document_infrastructure.documents.restore_success"),
  voidReasonPrompt: t(
    "admin.document_infrastructure.documents.void_reason_prompt"
  ),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let documents: Awaited<ReturnType<typeof listDocuments>> = [];
let classifications: Awaited<ReturnType<typeof listClassifications>> = [];
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      documents = await listDocuments(tx, context.tenantId, {});
      classifications = await listClassifications(tx, context.tenantId, {
        status: "active"
      });
    });
  } catch (error) {
    logAdminPageError(
      "admin/document-infrastructure/documents.astro: failed to load documents",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.document_infrastructure.documents.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.document_infrastructure.access_denied_title")}
        body={t("admin.document_infrastructure.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="config-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        {documents.length === 0 ? (
          <p class="empty-state">
            {t("admin.document_infrastructure.documents.no_rows")}
          </p>
        ) : (
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">
                  {t("admin.document_infrastructure.documents.col_title")}
                </th>
                <th scope="col">
                  {t(
                    "admin.document_infrastructure.documents.col_owner_module"
                  )}
                </th>
                <th scope="col">
                  {t("admin.document_infrastructure.documents.col_status")}
                </th>
                <th scope="col">
                  {t("admin.document_infrastructure.documents.col_version")}
                </th>
                <th scope="col">
                  {t("admin.document_infrastructure.documents.col_actions")}
                </th>
              </tr>
            </thead>
            <tbody>
              {documents.map((document) => (
                <tr data-id={document.id}>
                  <td>
                    <a
                      href={`/admin/document-infrastructure/documents/${document.id}`}
                    >
                      {document.title}
                    </a>
                  </td>
                  <td>{document.ownerModuleKey}</td>
                  <td>{document.deletedAt ? "deleted" : document.status}</td>
                  <td>{document.currentVersionNumber}</td>
                  <td>
                    {CAN_VOID &&
                      !document.deletedAt &&
                      document.status !== "void" && (
                        <button
                          type="button"
                          class="void-button"
                          data-id={document.id}
                        >
                          {t(
                            "admin.document_infrastructure.documents.void_button"
                          )}
                        </button>
                      )}
                    {CAN_RESTORE &&
                      (document.deletedAt || document.status === "void") && (
                        <button
                          type="button"
                          class="restore-button"
                          data-id={document.id}
                        >
                          {t(
                            "admin.document_infrastructure.documents.restore_button"
                          )}
                        </button>
                      )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}

        {CAN_CREATE && (
          <details class="create-config">
            <summary>
              {t("admin.document_infrastructure.documents.create_summary")}
            </summary>
            <form id="create-form" class="create-config-form">
              <label>
                {t(
                  "admin.document_infrastructure.documents.field_owner_module"
                )}
                <input
                  type="text"
                  name="ownerModuleKey"
                  required
                  pattern="^[a-z][a-z0-9_]*$"
                  maxlength="64"
                />
              </label>
              <label>
                {t(
                  "admin.document_infrastructure.documents.field_document_type"
                )}
                <input
                  type="text"
                  name="documentType"
                  required
                  pattern="^[a-z][a-z0-9_]*$"
                  maxlength="64"
                />
              </label>
              <label>
                {t("admin.document_infrastructure.documents.field_title")}
                <input type="text" name="title" required maxlength="300" />
              </label>
              <label>
                {t("admin.document_infrastructure.documents.field_summary")}
                <textarea name="summary" maxlength="4000" />
              </label>
              <label>
                {t(
                  "admin.document_infrastructure.documents.field_classification"
                )}
                <select name="classificationId">
                  <option value="">
                    {t(
                      "admin.document_infrastructure.documents.field_classification_none"
                    )}
                  </option>
                  {classifications.map((classification) => (
                    <option value={classification.id}>
                      {classification.name}
                    </option>
                  ))}
                </select>
              </label>
              <label>
                {t(
                  "admin.document_infrastructure.documents.field_confidentiality"
                )}
                <select name="confidentialityLevel" required>
                  <option value="public">public</option>
                  <option value="internal" selected>
                    internal
                  </option>
                  <option value="confidential">confidential</option>
                  <option value="restricted">restricted</option>
                </select>
              </label>
              <label>
                {t(
                  "admin.document_infrastructure.documents.field_resource_type"
                )}
                <input
                  type="text"
                  name="resourceType"
                  required
                  maxlength="120"
                />
              </label>
              <label>
                {t("admin.document_infrastructure.documents.field_resource_id")}
                <input type="text" name="resourceId" required maxlength="200" />
              </label>
              <button type="submit">
                {t("admin.document_infrastructure.documents.create_submit")}
              </button>
            </form>
          </details>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
  }

  .action-banner[data-variant="success"] {
    background: var(--color-success-surface, #e6f4ea);
    color: var(--color-success-strong, #1e7e34);
  }

  .action-banner[data-variant="error"] {
    background: var(--color-danger-surface, #fdecea);
    color: var(--color-danger-strong);
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }

  .void-button,
  .restore-button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .void-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
  }

  .restore-button {
    background: var(--color-primary-strong);
    border: none;
    color: var(--color-primary-contrast);
  }

  .create-config {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }

  .create-config summary {
    cursor: pointer;
    font-weight: 600;
  }

  .create-config-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 480px;
    margin-top: var(--sp-2);
  }

  .create-config-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }

  .create-config-form input,
  .create-config-form select,
  .create-config-form textarea {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .create-config-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }

  input:focus-visible,
  select:focus-visible,
  textarea:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    createSuccess: string;
    voidSuccess: string;
    restoreSuccess: string;
    voidReasonPrompt: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE_URL = "/api/v1/document-infrastructure/documents";

  document
    .getElementById("create-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);

      try {
        const formData = new FormData(form);
        const result = await submitJson(
          BASE_URL,
          "POST",
          {
            ownerModuleKey: formData.get("ownerModuleKey"),
            documentType: formData.get("documentType"),
            title: formData.get("title"),
            summary: formData.get("summary") || null,
            classificationId: formData.get("classificationId") || null,
            confidentialityLevel: formData.get("confidentialityLevel"),
            resourceType: formData.get("resourceType"),
            resourceId: formData.get("resourceId")
          },
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );

        if (result.ok) {
          showBanner("action-banner", strings.createSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  document
    .querySelectorAll<HTMLButtonElement>(".void-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const reason = window.prompt(strings.voidReasonPrompt);
        if (!reason) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}/void`,
            "POST",
            { voidReason: reason },
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.voidSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>(".restore-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}/restore`,
            "POST",
            {},
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.restoreSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
</script>
