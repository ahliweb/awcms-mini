---
/**
 * Document classifications admin screen (Issue #751, epic #738
 * platform-evolution Wave 3). Same "SSR list load, client-side create/
 * deactivate/restore via fetch" pattern
 * `admin/organization-structure/legal-entities.astro` establishes.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { listClassifications } from "../../../modules/document-infrastructure/application/document-classification-directory";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/document-infrastructure/classifications.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("document_infrastructure", "classifications", "read")
);
const CAN_CREATE = context.permissions.has(
  permissionKey("document_infrastructure", "classifications", "create")
);
const CAN_DELETE = context.permissions.has(
  permissionKey("document_infrastructure", "classifications", "delete")
);
const CAN_RESTORE = context.permissions.has(
  permissionKey("document_infrastructure", "classifications", "restore")
);

const clientStrings = {
  createSuccess: t(
    "admin.document_infrastructure.classifications.create_success"
  ),
  deactivateSuccess: t(
    "admin.document_infrastructure.classifications.deactivate_success"
  ),
  restoreSuccess: t(
    "admin.document_infrastructure.classifications.restore_success"
  ),
  deactivateReasonPrompt: t(
    "admin.document_infrastructure.classifications.deactivate_reason_prompt"
  ),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let classifications: Awaited<ReturnType<typeof listClassifications>> = [];
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      classifications = await listClassifications(tx, context.tenantId, {
        includeDeleted: CAN_RESTORE
      });
    });
  } catch (error) {
    logAdminPageError(
      "admin/document-infrastructure/classifications.astro: failed to load classifications",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.document_infrastructure.classifications.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.document_infrastructure.access_denied_title")}
        body={t("admin.document_infrastructure.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="config-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        {classifications.length === 0 ? (
          <p class="empty-state">
            {t("admin.document_infrastructure.classifications.no_rows")}
          </p>
        ) : (
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">
                  {t("admin.document_infrastructure.classifications.col_code")}
                </th>
                <th scope="col">
                  {t("admin.document_infrastructure.classifications.col_name")}
                </th>
                <th scope="col">
                  {t(
                    "admin.document_infrastructure.classifications.col_confidentiality"
                  )}
                </th>
                <th scope="col">
                  {t(
                    "admin.document_infrastructure.classifications.col_status"
                  )}
                </th>
                <th scope="col">
                  {t(
                    "admin.document_infrastructure.classifications.col_actions"
                  )}
                </th>
              </tr>
            </thead>
            <tbody>
              {classifications.map((classification) => (
                <tr data-id={classification.id}>
                  <td>{classification.code}</td>
                  <td>{classification.name}</td>
                  <td>{classification.confidentialityLevel}</td>
                  <td>
                    {classification.deletedAt
                      ? "inactive"
                      : classification.status}
                  </td>
                  <td>
                    {CAN_DELETE && !classification.deletedAt && (
                      <button
                        type="button"
                        class="deactivate-button"
                        data-id={classification.id}
                      >
                        {t(
                          "admin.document_infrastructure.classifications.deactivate_button"
                        )}
                      </button>
                    )}
                    {CAN_RESTORE && classification.deletedAt && (
                      <button
                        type="button"
                        class="restore-button"
                        data-id={classification.id}
                      >
                        {t(
                          "admin.document_infrastructure.classifications.restore_button"
                        )}
                      </button>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}

        {CAN_CREATE && (
          <details class="create-config">
            <summary>
              {t(
                "admin.document_infrastructure.classifications.create_summary"
              )}
            </summary>
            <form id="create-form" class="create-config-form">
              <label>
                {t("admin.document_infrastructure.classifications.field_code")}
                <input
                  type="text"
                  name="code"
                  required
                  pattern="^[a-z][a-z0-9_]*$"
                  maxlength="64"
                />
              </label>
              <label>
                {t("admin.document_infrastructure.classifications.field_name")}
                <input type="text" name="name" required maxlength="200" />
              </label>
              <label>
                {t(
                  "admin.document_infrastructure.classifications.field_confidentiality"
                )}
                <select name="confidentialityLevel" required>
                  <option value="public">public</option>
                  <option value="internal" selected>
                    internal
                  </option>
                  <option value="confidential">confidential</option>
                  <option value="restricted">restricted</option>
                </select>
              </label>
              <label>
                {t(
                  "admin.document_infrastructure.classifications.field_retention_reference"
                )}
                <input type="text" name="retentionReference" maxlength="200" />
              </label>
              <button type="submit">
                {t(
                  "admin.document_infrastructure.classifications.create_submit"
                )}
              </button>
            </form>
          </details>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
  }

  .action-banner[data-variant="success"] {
    background: color-mix(
      in srgb,
      var(--color-success) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-success);
  }

  .action-banner[data-variant="error"] {
    background: color-mix(
      in srgb,
      var(--color-danger) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-danger);
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }

  .deactivate-button,
  .restore-button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .deactivate-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
  }

  .restore-button {
    background: var(--color-primary-strong);
    border: none;
    color: var(--color-primary-contrast);
  }

  .create-config {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }

  .create-config summary {
    cursor: pointer;
    font-weight: 600;
  }

  .create-config-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 480px;
    margin-top: var(--sp-2);
  }

  .create-config-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }

  .create-config-form input,
  .create-config-form select {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .create-config-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }

  input:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    createSuccess: string;
    deactivateSuccess: string;
    restoreSuccess: string;
    deactivateReasonPrompt: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE_URL = "/api/v1/document-infrastructure/classifications";

  document
    .getElementById("create-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);

      try {
        const formData = new FormData(form);
        const result = await submitJson(
          BASE_URL,
          "POST",
          {
            code: formData.get("code"),
            name: formData.get("name"),
            confidentialityLevel: formData.get("confidentialityLevel"),
            retentionReference: formData.get("retentionReference") || null
          },
          strings
        );

        if (result.ok) {
          showBanner("action-banner", strings.createSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  document
    .querySelectorAll<HTMLButtonElement>(".deactivate-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const reason = window.prompt(strings.deactivateReasonPrompt);
        if (!reason) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}`,
            "DELETE",
            { deleteReason: reason },
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.deactivateSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>(".restore-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}/restore`,
            "POST",
            {},
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.restoreSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
</script>
