---
/**
 * Number sequences admin screen (Issue #751, epic #738
 * platform-evolution Wave 3) — define/revise/deactivate/restore
 * concurrency-safe numbering sequences, and reserve/commit/cancel for
 * recent reservations. Commit prompts for a target document id (free
 * text — there is no cross-module document picker here, same
 * constraint `documents/[id].astro`'s relation-link form documents for
 * `resourceType`/`resourceId`) since this is the only admin surface
 * that exposes reservation commit at all (reviewer finding, PR #780:
 * the document detail screen has no reservation UI).
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { listCurrentSequences } from "../../../modules/document-infrastructure/application/document-number-sequence-definition-service";
import { listReservations } from "../../../modules/document-infrastructure/application/document-number-reservation-service";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/document-infrastructure/sequences.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("document_infrastructure", "sequences", "read")
);
const CAN_CREATE = context.permissions.has(
  permissionKey("document_infrastructure", "sequences", "create")
);
const CAN_DELETE = context.permissions.has(
  permissionKey("document_infrastructure", "sequences", "delete")
);
const CAN_RESTORE = context.permissions.has(
  permissionKey("document_infrastructure", "sequences", "restore")
);
const CAN_RESERVE = context.permissions.has(
  permissionKey("document_infrastructure", "reservations", "reserve")
);
const CAN_CANCEL_RESERVATION = context.permissions.has(
  permissionKey("document_infrastructure", "reservations", "cancel")
);
const CAN_COMMIT_RESERVATION = context.permissions.has(
  permissionKey("document_infrastructure", "reservations", "commit")
);
// Confidentiality-tier clearance (Issue #787 fast-follow to #751's
// security-review Critical finding) — reservations already committed to
// a confidential/restricted document must not leak that document's
// existence to a caller who lacks read clearance for it. See
// `documents/[id].astro`'s identical DOCUMENT_ACCESS comment.
const RESERVATION_ACCESS = {
  canReadConfidential: context.permissions.has(
    permissionKey("document_infrastructure", "documents_confidential", "read")
  ),
  canReadRestricted: context.permissions.has(
    permissionKey("document_infrastructure", "documents_restricted", "read")
  )
};

const clientStrings = {
  defineSuccess: t("admin.document_infrastructure.sequences.define_success"),
  deactivateSuccess: t(
    "admin.document_infrastructure.sequences.deactivate_success"
  ),
  deactivateReasonPrompt: t(
    "admin.document_infrastructure.sequences.deactivate_reason_prompt"
  ),
  reserveSuccess: t("admin.document_infrastructure.sequences.reserve_success"),
  cancelSuccess: t("admin.document_infrastructure.sequences.cancel_success"),
  cancelReasonPrompt: t(
    "admin.document_infrastructure.sequences.cancel_reason_prompt"
  ),
  commitSuccess: t("admin.document_infrastructure.sequences.commit_success"),
  commitDocumentIdPrompt: t(
    "admin.document_infrastructure.sequences.commit_document_id_prompt"
  ),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let sequences: Awaited<ReturnType<typeof listCurrentSequences>> = [];
let reservations: Awaited<ReturnType<typeof listReservations>> = [];
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      sequences = await listCurrentSequences(tx, context.tenantId);
      reservations = await listReservations(
        tx,
        context.tenantId,
        RESERVATION_ACCESS,
        {}
      );
    });
  } catch (error) {
    logAdminPageError(
      "admin/document-infrastructure/sequences.astro: failed to load sequences",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.document_infrastructure.sequences.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.document_infrastructure.access_denied_title")}
        body={t("admin.document_infrastructure.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="config-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        <section>
          <h3>
            {t("admin.document_infrastructure.sequences.definitions_heading")}
          </h3>
          {sequences.length === 0 ? (
            <p class="empty-state">
              {t("admin.document_infrastructure.sequences.no_rows")}
            </p>
          ) : (
            <table class="data-table">
              <thead>
                <tr>
                  <th scope="col">
                    {t("admin.document_infrastructure.sequences.col_scope")}
                  </th>
                  <th scope="col">
                    {t("admin.document_infrastructure.sequences.col_key")}
                  </th>
                  <th scope="col">
                    {t("admin.document_infrastructure.sequences.col_format")}
                  </th>
                  <th scope="col">
                    {t(
                      "admin.document_infrastructure.sequences.col_current_value"
                    )}
                  </th>
                  <th scope="col">
                    {t("admin.document_infrastructure.sequences.col_actions")}
                  </th>
                </tr>
              </thead>
              <tbody>
                {sequences.map((sequence) => (
                  <tr
                    data-scope-type={sequence.scopeType}
                    data-scope-id={sequence.scopeId ?? ""}
                    data-sequence-key={sequence.sequenceKey}
                  >
                    <td>
                      {sequence.scopeType}
                      {sequence.scopeId ? `:${sequence.scopeId}` : ""}
                    </td>
                    <td>{sequence.sequenceKey}</td>
                    <td>{sequence.formatTemplate}</td>
                    <td>{sequence.currentValue}</td>
                    <td>
                      {CAN_DELETE && (
                        <button type="button" class="deactivate-button">
                          {t(
                            "admin.document_infrastructure.sequences.deactivate_button"
                          )}
                        </button>
                      )}
                      {CAN_RESERVE && (
                        <button type="button" class="reserve-button">
                          {t(
                            "admin.document_infrastructure.sequences.reserve_button"
                          )}
                        </button>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}

          {CAN_CREATE && (
            <details class="create-config">
              <summary>
                {t("admin.document_infrastructure.sequences.create_summary")}
              </summary>
              <form id="create-form" class="create-config-form">
                <label>
                  {t(
                    "admin.document_infrastructure.sequences.field_scope_type"
                  )}
                  <input
                    type="text"
                    name="scopeType"
                    required
                    pattern="^[a-z][a-z0-9_]*$"
                    maxlength="64"
                    placeholder="tenant"
                  />
                </label>
                <label>
                  {t("admin.document_infrastructure.sequences.field_scope_id")}
                  <input type="text" name="scopeId" maxlength="200" />
                </label>
                <label>
                  {t(
                    "admin.document_infrastructure.sequences.field_sequence_key"
                  )}
                  <input
                    type="text"
                    name="sequenceKey"
                    required
                    pattern="^[a-z][a-z0-9_]*$"
                    maxlength="64"
                    placeholder="invoice"
                  />
                </label>
                <label>
                  {t(
                    "admin.document_infrastructure.sequences.field_format_template"
                  )}
                  <input
                    type="text"
                    name="formatTemplate"
                    required
                    maxlength="128"
                    placeholder="{PREFIX}/{YYYY}/{SEQ:6}"
                  />
                </label>
                <label>
                  {t(
                    "admin.document_infrastructure.sequences.field_reset_policy"
                  )}
                  <select name="resetPolicy" required>
                    <option value="never">never</option>
                    <option value="yearly">yearly</option>
                    <option value="monthly">monthly</option>
                    <option value="daily">daily</option>
                  </select>
                </label>
                <button type="submit">
                  {t("admin.document_infrastructure.sequences.create_submit")}
                </button>
              </form>
            </details>
          )}
        </section>

        <section>
          <h3>
            {t("admin.document_infrastructure.sequences.reservations_heading")}
          </h3>
          {reservations.length === 0 ? (
            <p class="empty-state">
              {t(
                "admin.document_infrastructure.sequences.reservations_no_rows"
              )}
            </p>
          ) : (
            <table class="data-table">
              <thead>
                <tr>
                  <th scope="col">
                    {t(
                      "admin.document_infrastructure.sequences.col_formatted_number"
                    )}
                  </th>
                  <th scope="col">
                    {t(
                      "admin.document_infrastructure.sequences.col_reservation_status"
                    )}
                  </th>
                  <th scope="col">
                    {t("admin.document_infrastructure.sequences.col_actions")}
                  </th>
                </tr>
              </thead>
              <tbody>
                {reservations.map((reservation) => (
                  <tr data-id={reservation.id}>
                    <td>{reservation.formattedNumber}</td>
                    <td>{reservation.status}</td>
                    <td>
                      {CAN_COMMIT_RESERVATION &&
                        reservation.status === "reserved" && (
                          <button
                            type="button"
                            class="commit-reservation-button"
                            data-id={reservation.id}
                          >
                            {t(
                              "admin.document_infrastructure.sequences.commit_button"
                            )}
                          </button>
                        )}
                      {CAN_CANCEL_RESERVATION &&
                        reservation.status === "reserved" && (
                          <button
                            type="button"
                            class="cancel-reservation-button"
                            data-id={reservation.id}
                          >
                            {t(
                              "admin.document_infrastructure.sequences.cancel_button"
                            )}
                          </button>
                        )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </section>
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
  }

  .action-banner[data-variant="success"] {
    background: var(--color-success-surface, #e6f4ea);
    color: var(--color-success-strong, #1e7e34);
  }

  .action-banner[data-variant="error"] {
    background: var(--color-danger-surface, #fdecea);
    color: var(--color-danger-strong);
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }

  .deactivate-button,
  .cancel-reservation-button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
    cursor: pointer;
    margin-right: var(--sp-1);
  }

  .reserve-button,
  .commit-reservation-button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    background: var(--color-primary-strong);
    border: none;
    color: var(--color-primary-contrast);
    cursor: pointer;
  }

  .commit-reservation-button {
    margin-right: var(--sp-1);
  }

  .create-config {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }

  .create-config summary {
    cursor: pointer;
    font-weight: 600;
  }

  .create-config-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 480px;
    margin-top: var(--sp-2);
  }

  .create-config-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }

  .create-config-form input,
  .create-config-form select {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .create-config-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }

  input:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    defineSuccess: string;
    deactivateSuccess: string;
    deactivateReasonPrompt: string;
    reserveSuccess: string;
    cancelSuccess: string;
    cancelReasonPrompt: string;
    commitSuccess: string;
    commitDocumentIdPrompt: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE_URL = "/api/v1/document-infrastructure";

  document
    .getElementById("create-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);

      try {
        const formData = new FormData(form);
        const result = await submitJson(
          `${BASE_URL}/sequences`,
          "POST",
          {
            scopeType: formData.get("scopeType"),
            scopeId: formData.get("scopeId") || null,
            sequenceKey: formData.get("sequenceKey"),
            formatTemplate: formData.get("formatTemplate"),
            resetPolicy: formData.get("resetPolicy")
          },
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );

        if (result.ok) {
          showBanner("action-banner", strings.defineSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  document
    .querySelectorAll<HTMLButtonElement>(".deactivate-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const row = button.closest("tr");
        const reason = window.prompt(strings.deactivateReasonPrompt);
        if (!reason || !row) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/sequences/deactivate`,
            "POST",
            {
              scopeType: row.dataset.scopeType,
              scopeId: row.dataset.scopeId || null,
              sequenceKey: row.dataset.sequenceKey,
              deleteReason: reason
            },
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.deactivateSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>(".reserve-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const row = button.closest("tr");
        if (!row) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/reservations/reserve`,
            "POST",
            {
              scopeType: row.dataset.scopeType,
              scopeId: row.dataset.scopeId || null,
              sequenceKey: row.dataset.sequenceKey
            },
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.reserveSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>(".commit-reservation-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const documentId = window.prompt(strings.commitDocumentIdPrompt);
        if (!documentId) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/reservations/${button.dataset.id}/commit`,
            "POST",
            { documentId },
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.commitSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>(".cancel-reservation-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const reason = window.prompt(strings.cancelReasonPrompt);
        if (!reason) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/reservations/${button.dataset.id}/cancel`,
            "POST",
            { cancelReason: reason },
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.cancelSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
</script>
