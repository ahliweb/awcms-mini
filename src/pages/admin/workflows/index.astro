---
/**
 * Consolidated admin approval inbox (Issue #747, epic `platform-evolution`
 * #738 Wave 2). Client-side rendered against the already-shipped API —
 * same convention `admin/analytics.astro` established (Issue #622: "this
 * page adds no new endpoint... every number/table comes from a real
 * client-side fetch"), so server-side ABAC (`authorizeInTransaction`)
 * remains the only real enforcement point; every permission check in this
 * file's frontmatter is a second, UI-only convenience layer that can only
 * ever be MORE restrictive than the API, never less.
 *
 * Covers the issue's own approval-inbox acceptance bullet: pagination
 * (keyset "load more", `GET /api/v1/workflows/tasks`'s `nextCursor`),
 * filters (workflow key / resource type / status / overdue), safe search,
 * and per-instance immutable action history (`GET
 * /api/v1/workflows/instances/{id}`). Decision (approve/reject),
 * administrative recovery (reassign/cancel/force-decide) all reuse the
 * existing high-risk endpoints unchanged — this page issues a fresh
 * `Idempotency-Key` per submit exactly like
 * `admin/social-publishing/jobs.astro`.
 *
 * Deliberately NOT in scope of this page: authoring/publishing workflow
 * DEFINITIONS (draft graph editor) — `POST/GET /api/v1/workflows/
 * definitions/**` exist and are exercised by tests, but a visual
 * node/transition graph editor is a substantial standalone UI effort the
 * issue's own escape hatch ("ship a smaller-but-real vertical slice...
 * document what was deferred") applies to; definitions are authored via
 * the API/fixtures for now, same precedent Issue 11.1 set for the
 * original linear engine. Tracked as a follow-up, not silently dropped.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { createTranslator } from "../../../lib/i18n/translate";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/workflows/index.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("workflow", "approval", "read")
);
const CAN_DECIDE = context.permissions.has(
  permissionKey("workflow", "approval", "approve")
);
const CAN_REASSIGN = context.permissions.has(
  permissionKey("workflow", "recovery", "reassign")
);
const CAN_CANCEL = context.permissions.has(
  permissionKey("workflow", "recovery", "cancel")
);
const CAN_FORCE_DECIDE = context.permissions.has(
  permissionKey("workflow", "recovery", "force_decide")
);

const clientStrings = {
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t),
  stateLoading: t("admin.workflows.state_loading"),
  stateEmpty: t("admin.workflows.state_empty"),
  stateError: t("admin.workflows.state_error"),
  decideApproveSuccess: t("admin.workflows.decide_approve_success"),
  decideRejectSuccess: t("admin.workflows.decide_reject_success"),
  decideReasonPrompt: t("admin.workflows.decide_reason_prompt"),
  rejectReasonPrompt: t("admin.workflows.reject_reason_prompt"),
  reassignPrompt: t("admin.workflows.reassign_prompt"),
  reassignReasonPrompt: t("admin.workflows.reassign_reason_prompt"),
  reassignSuccess: t("admin.workflows.reassign_success"),
  cancelReasonPrompt: t("admin.workflows.cancel_reason_prompt"),
  cancelConfirm: t("admin.workflows.cancel_confirm"),
  cancelSuccess: t("admin.workflows.cancel_success"),
  forceDecidePrompt: t("admin.workflows.force_decide_prompt"),
  forceDecideReasonPrompt: t("admin.workflows.force_decide_reason_prompt"),
  forceDecideSuccess: t("admin.workflows.force_decide_success"),
  historyEmpty: t("admin.workflows.history_empty"),
  historyLoadError: t("admin.workflows.history_load_error")
};

const pageConfig = {
  canDecide: CAN_DECIDE,
  canReassign: CAN_REASSIGN,
  canCancel: CAN_CANCEL,
  canForceDecide: CAN_FORCE_DECIDE
};
---

<AdminLayout title={t("admin.layout.nav_workflow_inbox")}>
  <h1>{t("admin.workflows.heading")}</h1>

  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.workflows.access_denied_title")}
        body={t("admin.workflows.access_denied_body")}
      />
    )
  }

  {
    CAN_READ && (
      <div class="workflow-inbox">
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />
        <script
          type="application/json"
          id="workflow-inbox-config"
          set:html={JSON.stringify(pageConfig)}
        />
        <div id="action-banner" class="action-banner" role="alert" hidden />

        <form class="filters-toolbar" id="filters-form">
          <label for="status-filter">
            {t("admin.workflows.filter_status_label")}
          </label>
          <select id="status-filter">
            <option value="pending" selected>
              {t("admin.workflows.filter_status_pending")}
            </option>
            <option value="completed">
              {t("admin.workflows.filter_status_completed")}
            </option>
            <option value="skipped">
              {t("admin.workflows.filter_status_skipped")}
            </option>
            <option value="cancelled">
              {t("admin.workflows.filter_status_cancelled")}
            </option>
          </select>

          <label for="workflow-key-filter">
            {t("admin.workflows.filter_workflow_key_label")}
          </label>
          <input type="text" id="workflow-key-filter" autocomplete="off" />

          <label for="resource-type-filter">
            {t("admin.workflows.filter_resource_type_label")}
          </label>
          <input type="text" id="resource-type-filter" autocomplete="off" />

          <label class="checkbox-label" for="overdue-filter">
            <input type="checkbox" id="overdue-filter" />
            {t("admin.workflows.filter_overdue_label")}
          </label>

          <label for="search-filter">
            {t("admin.workflows.filter_search_label")}
          </label>
          <input type="search" id="search-filter" autocomplete="off" />

          <button type="submit" class="ghost-button">
            {t("admin.workflows.filter_apply_button")}
          </button>
        </form>

        <div class="table-scroll">
          <table class="inbox-table" data-role="inbox-table">
            <thead>
              <tr>
                <th>{t("admin.workflows.column_workflow")}</th>
                <th>{t("admin.workflows.column_resource")}</th>
                <th>{t("admin.workflows.column_node")}</th>
                <th>{t("admin.workflows.column_due")}</th>
                <th>{t("admin.workflows.column_actions")}</th>
              </tr>
            </thead>
            <tbody />
          </table>
        </div>
        <p class="section-state" data-role="inbox-state" aria-live="polite">
          {t("admin.workflows.state_loading")}
        </p>
        <button type="button" id="load-more-button" class="ghost-button" hidden>
          {t("admin.workflows.load_more_button")}
        </button>
      </div>
    )
  }
</AdminLayout>

<style>
  .workflow-inbox {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
  }

  .action-banner[data-variant="success"] {
    background: color-mix(
      in srgb,
      var(--color-success) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-success);
  }

  .action-banner[data-variant="error"] {
    background: color-mix(
      in srgb,
      var(--color-danger) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-danger);
  }

  .filters-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-sm);
  }

  .filters-toolbar input,
  .filters-toolbar select {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
    min-height: 44px;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: var(--sp-1);
  }

  .table-scroll {
    overflow-x: auto;
  }

  .inbox-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-sm);
  }

  .inbox-table th,
  .inbox-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .overdue-badge {
    color: var(--color-danger-strong);
    font-weight: 600;
  }

  .row-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1);
  }

  .row-actions button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: var(--fs-xs);
  }

  .approve-button {
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
  }

  .reject-button,
  .cancel-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
  }

  .reassign-button,
  .force-decide-button,
  .history-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .history-panel {
    font-size: var(--fs-xs);
    margin-top: var(--sp-1);
  }

  .history-panel ul {
    margin: var(--sp-1) 0 0;
    padding-left: var(--sp-4);
  }

  .section-state {
    margin: 0;
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  .section-state:empty {
    display: none;
  }

  .ghost-button {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
    color: var(--color-text);
  }

  .ghost-button:hover {
    background: var(--color-surface-2);
  }

  button:focus-visible,
  input:focus-visible,
  select:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    fetchJson,
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface WorkflowInboxStrings {
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
    stateLoading: string;
    stateEmpty: string;
    stateError: string;
    decideApproveSuccess: string;
    decideRejectSuccess: string;
    decideReasonPrompt: string;
    rejectReasonPrompt: string;
    reassignPrompt: string;
    reassignReasonPrompt: string;
    reassignSuccess: string;
    cancelReasonPrompt: string;
    cancelConfirm: string;
    cancelSuccess: string;
    forceDecidePrompt: string;
    forceDecideReasonPrompt: string;
    forceDecideSuccess: string;
    historyEmpty: string;
    historyLoadError: string;
  }

  interface WorkflowInboxConfig {
    canDecide: boolean;
    canReassign: boolean;
    canCancel: boolean;
    canForceDecide: boolean;
  }

  interface TaskRow {
    id: string;
    nodeId: string;
    status: string;
    quorumRule: string;
    dueAt?: string;
    overdue: boolean;
    createdAt: string;
    instanceId: string;
    resourceType: string;
    resourceId: string;
    requestedByTenantUserId: string;
    workflowKey: string;
    workflowName: string;
  }

  function readPageConfig(): WorkflowInboxConfig {
    const fallback: WorkflowInboxConfig = {
      canDecide: false,
      canReassign: false,
      canCancel: false,
      canForceDecide: false
    };
    try {
      const raw = document.getElementById("workflow-inbox-config")?.textContent;
      return raw ? { ...fallback, ...JSON.parse(raw) } : fallback;
    } catch {
      return fallback;
    }
  }

  const config = readPageConfig();
  const strings = readClientStrings<WorkflowInboxStrings>();

  let nextCursor: string | null = null;
  let tasksRaw: TaskRow[] = [];

  function stateEl(): HTMLElement | null {
    return document.querySelector('[data-role="inbox-state"]');
  }

  function setState(
    state: "ready" | "empty" | "error",
    message?: string
  ): void {
    const el = stateEl();
    if (!el) return;
    if (state === "ready") {
      el.textContent = "";
      return;
    }
    el.textContent =
      message ?? (state === "empty" ? strings.stateEmpty : strings.stateError);
  }

  function buildQuery(cursor: string | null): string {
    const params = new URLSearchParams();
    params.set(
      "status",
      (document.getElementById("status-filter") as HTMLSelectElement)?.value ??
        "pending"
    );
    const workflowKey = (
      document.getElementById("workflow-key-filter") as HTMLInputElement
    )?.value.trim();
    if (workflowKey) params.set("workflowKey", workflowKey);
    const resourceType = (
      document.getElementById("resource-type-filter") as HTMLInputElement
    )?.value.trim();
    if (resourceType) params.set("resourceType", resourceType);
    const overdue = (
      document.getElementById("overdue-filter") as HTMLInputElement
    )?.checked;
    if (overdue) params.set("overdue", "true");
    const search = (
      document.getElementById("search-filter") as HTMLInputElement
    )?.value.trim();
    if (search) params.set("search", search);
    if (cursor) params.set("cursor", cursor);
    return params.toString();
  }

  function renderHistoryRow(entry: {
    kind: string;
    action: string;
    createdAt: string;
    actorTenantUserId?: string;
  }): string {
    return `<li>${entry.createdAt} — ${entry.kind}:${entry.action}${
      entry.actorTenantUserId ? " (" + entry.actorTenantUserId + ")" : ""
    }</li>`;
  }

  async function toggleHistory(
    instanceId: string,
    panel: HTMLElement
  ): Promise<void> {
    if (panel.dataset.loaded === "true") {
      panel.hidden = !panel.hidden;
      return;
    }
    panel.hidden = false;
    panel.textContent = strings.stateLoading;
    const result = await fetchJson<{
      history: {
        kind: string;
        action: string;
        createdAt: string;
        actorTenantUserId?: string;
      }[];
    }>(`/api/v1/workflows/instances/${instanceId}`, strings);
    if (!result.ok || !result.data) {
      panel.textContent = strings.historyLoadError;
      return;
    }
    if (result.data.history.length === 0) {
      panel.textContent = strings.historyEmpty;
    } else {
      panel.innerHTML = `<ul>${result.data.history.map(renderHistoryRow).join("")}</ul>`;
    }
    panel.dataset.loaded = "true";
  }

  function renderRows(): void {
    const tbody = document.querySelector('[data-role="inbox-table"] tbody');
    if (!tbody) return;
    tbody.innerHTML = "";

    if (tasksRaw.length === 0) {
      setState("empty");
      return;
    }
    setState("ready");

    for (const task of tasksRaw) {
      const tr = document.createElement("tr");

      const workflowTd = document.createElement("td");
      workflowTd.textContent = `${task.workflowName} (${task.workflowKey})`;
      tr.append(workflowTd);

      const resourceTd = document.createElement("td");
      resourceTd.textContent = `${task.resourceType}:${task.resourceId}`;
      tr.append(resourceTd);

      const nodeTd = document.createElement("td");
      nodeTd.textContent = `${task.nodeId} (${task.quorumRule})`;
      tr.append(nodeTd);

      const dueTd = document.createElement("td");
      dueTd.textContent = task.dueAt ?? "–";
      if (task.overdue) {
        dueTd.classList.add("overdue-badge");
      }
      tr.append(dueTd);

      const actionsTd = document.createElement("td");
      const actionsWrap = document.createElement("div");
      actionsWrap.className = "row-actions";

      if (config.canDecide && task.status === "pending") {
        const approveButton = document.createElement("button");
        approveButton.type = "button";
        approveButton.className = "approve-button";
        approveButton.textContent = "✓";
        approveButton.dataset.id = task.id;
        approveButton.addEventListener(
          "click",
          () => void decide(task.id, "approve", approveButton)
        );
        actionsWrap.append(approveButton);

        const rejectButton = document.createElement("button");
        rejectButton.type = "button";
        rejectButton.className = "reject-button";
        rejectButton.textContent = "✗";
        rejectButton.dataset.id = task.id;
        rejectButton.addEventListener(
          "click",
          () => void decide(task.id, "reject", rejectButton)
        );
        actionsWrap.append(rejectButton);
      }

      if (config.canReassign && task.status === "pending") {
        const reassignButton = document.createElement("button");
        reassignButton.type = "button";
        reassignButton.className = "reassign-button";
        reassignButton.textContent = strings.reassignPrompt;
        reassignButton.addEventListener(
          "click",
          () => void reassign(task.id, reassignButton)
        );
        actionsWrap.append(reassignButton);
      }

      if (config.canForceDecide && task.status === "pending") {
        const forceButton = document.createElement("button");
        forceButton.type = "button";
        forceButton.className = "force-decide-button";
        forceButton.textContent = strings.forceDecidePrompt;
        forceButton.addEventListener(
          "click",
          () => void forceDecide(task.id, forceButton)
        );
        actionsWrap.append(forceButton);
      }

      if (config.canCancel && task.status === "pending") {
        const cancelButton = document.createElement("button");
        cancelButton.type = "button";
        cancelButton.className = "cancel-button";
        cancelButton.textContent = strings.cancelReasonPrompt;
        cancelButton.addEventListener(
          "click",
          () => void cancelInstance(task.instanceId, cancelButton)
        );
        actionsWrap.append(cancelButton);
      }

      const historyButton = document.createElement("button");
      historyButton.type = "button";
      historyButton.className = "history-button";
      historyButton.textContent = "…";
      actionsWrap.append(historyButton);

      actionsTd.append(actionsWrap);

      const historyPanel = document.createElement("div");
      historyPanel.className = "history-panel";
      historyPanel.hidden = true;
      actionsTd.append(historyPanel);
      historyButton.addEventListener(
        "click",
        () => void toggleHistory(task.instanceId, historyPanel)
      );

      tr.append(actionsTd);
      tbody.append(tr);
    }
  }

  async function loadPage(cursor: string | null): Promise<void> {
    setState("ready");
    const query = buildQuery(cursor);
    const result = await fetchJson<{
      tasks: TaskRow[];
      nextCursor: string | null;
    }>(`/api/v1/workflows/tasks?${query}`, strings);
    if (!result.ok || !result.data) {
      setState("error", result.message);
      return;
    }
    tasksRaw = cursor ? tasksRaw.concat(result.data.tasks) : result.data.tasks;
    nextCursor = result.data.nextCursor;
    const loadMoreButton = document.getElementById(
      "load-more-button"
    ) as HTMLButtonElement | null;
    if (loadMoreButton) loadMoreButton.hidden = !nextCursor;
    renderRows();
  }

  async function decide(
    taskId: string,
    decision: "approve" | "reject",
    button: HTMLButtonElement
  ): Promise<void> {
    let reason: string | undefined;
    if (decision === "reject") {
      const promptResult = window.prompt(strings.rejectReasonPrompt);
      if (promptResult === null) return;
      reason = promptResult.trim() || undefined;
    }
    const unlock = lockElement(button, strings.pleaseWait);
    try {
      const result = await submitJson(
        `/api/v1/workflows/tasks/${taskId}/decisions`,
        "POST",
        { decision, reason },
        strings,
        { "Idempotency-Key": newIdempotencyKey() }
      );
      showBanner(
        "action-banner",
        result.ok
          ? decision === "approve"
            ? strings.decideApproveSuccess
            : strings.decideRejectSuccess
          : result.message,
        result.ok ? "success" : "error"
      );
      if (result.ok) void loadPage(null);
    } finally {
      unlock();
    }
  }

  async function reassign(
    taskId: string,
    button: HTMLButtonElement
  ): Promise<void> {
    const toTenantUserId = window.prompt(strings.reassignPrompt);
    if (!toTenantUserId) return;
    const reason = window.prompt(strings.reassignReasonPrompt);
    if (!reason || reason.trim().length === 0) return;

    const unlock = lockElement(button, strings.pleaseWait);
    try {
      const result = await submitJson(
        `/api/v1/workflows/tasks/${taskId}/reassign`,
        "POST",
        { toTenantUserId: toTenantUserId.trim(), reason },
        strings,
        { "Idempotency-Key": newIdempotencyKey() }
      );
      showBanner(
        "action-banner",
        result.ok ? strings.reassignSuccess : result.message,
        result.ok ? "success" : "error"
      );
      if (result.ok) void loadPage(null);
    } finally {
      unlock();
    }
  }

  async function forceDecide(
    taskId: string,
    button: HTMLButtonElement
  ): Promise<void> {
    const decision = window.prompt(strings.forceDecidePrompt, "approve");
    if (decision !== "approve" && decision !== "reject") return;
    const reason = window.prompt(strings.forceDecideReasonPrompt);
    if (!reason || reason.trim().length === 0) return;

    const unlock = lockElement(button, strings.pleaseWait);
    try {
      const result = await submitJson(
        `/api/v1/workflows/tasks/${taskId}/force-decision`,
        "POST",
        { decision, reason },
        strings,
        { "Idempotency-Key": newIdempotencyKey() }
      );
      showBanner(
        "action-banner",
        result.ok ? strings.forceDecideSuccess : result.message,
        result.ok ? "success" : "error"
      );
      if (result.ok) void loadPage(null);
    } finally {
      unlock();
    }
  }

  async function cancelInstance(
    instanceId: string,
    button: HTMLButtonElement
  ): Promise<void> {
    const reason = window.prompt(strings.cancelReasonPrompt);
    if (!reason || reason.trim().length === 0) return;
    if (!window.confirm(strings.cancelConfirm)) return;

    const unlock = lockElement(button, strings.pleaseWait);
    try {
      const result = await submitJson(
        `/api/v1/workflows/instances/${instanceId}/cancel`,
        "POST",
        { reason },
        strings,
        { "Idempotency-Key": newIdempotencyKey() }
      );
      showBanner(
        "action-banner",
        result.ok ? strings.cancelSuccess : result.message,
        result.ok ? "success" : "error"
      );
      if (result.ok) void loadPage(null);
    } finally {
      unlock();
    }
  }

  document
    .getElementById("filters-form")
    ?.addEventListener("submit", (event) => {
      event.preventDefault();
      void loadPage(null);
    });

  document.getElementById("load-more-button")?.addEventListener("click", () => {
    if (nextCursor) void loadPage(nextCursor);
  });

  void loadPage(null);
</script>
