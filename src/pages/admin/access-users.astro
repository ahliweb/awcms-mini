---
/**
 * Access & Users admin screen — full management UI over the identity-access
 * module: tenant users (create, rename, activate/deactivate), roles (create,
 * rename, edit permission set, soft delete), and role assignment.
 *
 * SSR fetches via the same application-layer functions the JSON endpoints
 * use (`modules/identity-access/application/user-directory.ts`) — matching
 * `admin/index.astro`'s pattern of not round-tripping through its own HTTP
 * API for the initial render. All mutations (create/update/assign/delete) go
 * through the real `/api/v1/users`, `/api/v1/roles`, `/api/v1/permissions`,
 * `/api/v1/access/assignments` endpoints via client-side `fetch` — the same
 * ABAC-guarded, audited endpoints any other API client would use, so the UI
 * has no privileged shortcut. No client-side framework is available in this
 * project (Astro + vanilla JS only, see AdminLayout's logout button for the
 * same pattern) — the single <script> below does all the wiring.
 *
 * Permission-gated per-section, matching each endpoint's own guard exactly
 * (defense-in-depth: hiding a control here is a UX nicety, the real
 * enforcement is server-side):
 *   - identity_access.user_management.read    -> see the Users table
 *   - identity_access.user_management.create  -> "Tambah pengguna" form
 *   - identity_access.user_management.update  -> rename / activate-deactivate
 *   - identity_access.access_control.read     -> see the Roles table
 *   - identity_access.access_control.configure -> create/edit/delete role
 *   - identity_access.access_control.assign    -> assign/unassign role chips
 */
import AdminLayout from "../../layouts/AdminLayout.astro";
import StateNotice from "../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../lib/database/client";
import { withTenant } from "../../lib/database/tenant-context";
import { permissionKey } from "../../modules/identity-access/domain/access-control";
import {
  fetchPermissionCatalog,
  fetchRolesWithPermissions,
  fetchTenantUsersWithRoles,
  type PermissionCatalogEntry
} from "../../modules/identity-access/application/user-directory";
import { createTranslator } from "../../lib/i18n/translate";
import { buildClientErrorMessages } from "../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/access-users.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

// i18n (Issue #433): the client <script> below can't read the .po catalog
// itself (server-side only, via Bun.file) — translated strings/error-code
// map it needs are injected as a <script type="application/json"> blob, the
// same pattern login.astro uses.
const clientStrings = {
  createUserSuccess: t("admin.access_users.create_user_success"),
  createRoleSuccess: t("admin.access_users.create_role_success"),
  updateRoleSuccess: t("admin.access_users.update_role_success"),
  deleteRoleSuccess: t("admin.access_users.delete_role_success"),
  updateStatusSuccess: t("admin.access_users.update_status_success"),
  assignRoleSuccess: t("admin.access_users.assign_role_success"),
  unassignRoleSuccess: t("admin.access_users.unassign_role_success"),
  deleteRolePrompt: t("admin.access_users.delete_role_prompt"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

const CAN_READ_USERS = context.permissions.has(
  permissionKey("identity_access", "user_management", "read")
);
const CAN_CREATE_USERS = context.permissions.has(
  permissionKey("identity_access", "user_management", "create")
);
const CAN_UPDATE_USERS = context.permissions.has(
  permissionKey("identity_access", "user_management", "update")
);
const CAN_READ_ROLES = context.permissions.has(
  permissionKey("identity_access", "access_control", "read")
);
const CAN_CONFIGURE_ROLES = context.permissions.has(
  permissionKey("identity_access", "access_control", "configure")
);
const CAN_ASSIGN = context.permissions.has(
  permissionKey("identity_access", "access_control", "assign")
);

const hasAnyAccess = CAN_READ_USERS || CAN_READ_ROLES;

// Issue #434 (UX/UI audit): the doc 14 §State pattern wajib requires an
// explicit Error branch ("Loading -> Error: gagal") — previously a DB
// failure here had no graceful path at all (unhandled 500). `loadError`
// distinguishes "you can't see this" (permission) from "we couldn't load
// it right now" (transient failure); see `StateNotice.astro`.
let data: {
  users: Awaited<ReturnType<typeof fetchTenantUsersWithRoles>>;
  roles: Awaited<ReturnType<typeof fetchRolesWithPermissions>>;
  permissions: PermissionCatalogEntry[];
} | null = null;
let loadError = false;

if (hasAnyAccess) {
  try {
    data = await withTenant(
      getDatabaseClient(),
      context.tenantId,
      async (tx) => ({
        users: CAN_READ_USERS
          ? await fetchTenantUsersWithRoles(tx, context.tenantId)
          : [],
        roles: CAN_READ_ROLES
          ? await fetchRolesWithPermissions(tx, context.tenantId)
          : [],
        permissions: CAN_READ_ROLES ? await fetchPermissionCatalog(tx) : []
      })
    );
  } catch (error) {
    console.error("admin/access-users.astro: failed to load data", error);
    loadError = true;
  }
}

// Group the permission catalog by moduleKey for a readable checkbox layout.
const permissionGroups = new Map<string, PermissionCatalogEntry[]>();
if (data) {
  for (const permission of data.permissions) {
    const list = permissionGroups.get(permission.moduleKey) ?? [];
    list.push(permission);
    permissionGroups.set(permission.moduleKey, list);
  }
}
---

<AdminLayout title={t("admin.layout.nav_access_users")}>
  {
    !hasAnyAccess && (
      <StateNotice
        kind="denied"
        title={t("admin.access_users.access_denied_title")}
        body={t("admin.access_users.access_denied_body")}
      />
    )
  }
  {
    hasAnyAccess && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    data && (
      <div class="access-users">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        {CAN_READ_USERS && (
          <section class="au-section">
            <div class="au-section-header">
              <h2>{t("admin.access_users.users_title")}</h2>
            </div>

            <div class="table-scroll">
              <table class="au-table">
                <thead>
                  <tr>
                    <th>{t("admin.access_users.name_column")}</th>
                    <th>{t("admin.access_users.login_column")}</th>
                    <th>{t("admin.access_users.status_column")}</th>
                    <th>{t("admin.access_users.role_column")}</th>
                    {(CAN_UPDATE_USERS || CAN_ASSIGN) && (
                      <th>{t("admin.access_users.actions_column")}</th>
                    )}
                  </tr>
                </thead>
                <tbody>
                  {data.users.length === 0 && (
                    <tr>
                      <td colspan={CAN_UPDATE_USERS || CAN_ASSIGN ? 5 : 4}>
                        {t("admin.access_users.no_users")}
                      </td>
                    </tr>
                  )}
                  {data.users.map((user) => (
                    <tr data-user-row={user.tenantUserId}>
                      <td>{user.displayName}</td>
                      <td>{user.loginIdentifier}</td>
                      <td>
                        <span class="status-pill" data-status={user.status}>
                          {user.status === "active"
                            ? t("common.status_active")
                            : t("common.status_inactive")}
                        </span>
                      </td>
                      <td>
                        <div class="role-chip-list">
                          {user.roles.length === 0 && (
                            <span class="role-chip-empty">
                              {t("admin.layout.no_role")}
                            </span>
                          )}
                          {user.roles.map((role) => (
                            <span class="role-chip">
                              {role.roleName}
                              {CAN_ASSIGN && (
                                <button
                                  type="button"
                                  class="role-chip-remove"
                                  data-unassign-user={user.tenantUserId}
                                  data-unassign-role={role.roleId}
                                  aria-label={t(
                                    "admin.access_users.unassign_role_aria_label",
                                    { role: role.roleName }
                                  )}
                                >
                                  &times;
                                </button>
                              )}
                            </span>
                          ))}
                        </div>
                        {CAN_ASSIGN && (
                          <form
                            class="assign-role-form"
                            data-assign-user={user.tenantUserId}
                          >
                            <select name="roleId" required>
                              <option value="">
                                {t(
                                  "admin.access_users.assign_role_placeholder"
                                )}
                              </option>
                              {data.roles
                                .filter(
                                  (role) =>
                                    !user.roles.some(
                                      (r) => r.roleId === role.roleId
                                    )
                                )
                                .map((role) => (
                                  <option value={role.roleId}>
                                    {role.roleName}
                                  </option>
                                ))}
                            </select>
                            <button type="submit">
                              {t("admin.access_users.assign_button")}
                            </button>
                          </form>
                        )}
                      </td>
                      {(CAN_UPDATE_USERS || CAN_ASSIGN) && (
                        <td>
                          {CAN_UPDATE_USERS && (
                            <button
                              type="button"
                              class="toggle-status-button"
                              data-toggle-user={user.tenantUserId}
                              data-next-status={
                                user.status === "active" ? "inactive" : "active"
                              }
                            >
                              {user.status === "active"
                                ? t("admin.access_users.deactivate_button")
                                : t("admin.access_users.activate_button")}
                            </button>
                          )}
                        </td>
                      )}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            {CAN_CREATE_USERS && (
              <details class="au-create">
                <summary>{t("admin.access_users.create_user_summary")}</summary>
                <form id="create-user-form" class="au-form">
                  <label>
                    {t("admin.access_users.name_label")}
                    <input type="text" name="displayName" required />
                  </label>
                  <label>
                    {t("admin.access_users.login_identifier_label")}
                    <input type="text" name="loginIdentifier" required />
                  </label>
                  <label>
                    {t("admin.access_users.password_label")}
                    <input
                      type="password"
                      name="password"
                      minlength="8"
                      required
                    />
                  </label>
                  <fieldset class="role-checkbox-group">
                    <legend>
                      {t("admin.access_users.initial_roles_legend")}
                    </legend>
                    {data.roles.map((role) => (
                      <label class="checkbox-label">
                        <input
                          type="checkbox"
                          name="roleIds"
                          value={role.roleId}
                        />
                        {role.roleName}
                      </label>
                    ))}
                  </fieldset>
                  <button type="submit">
                    {t("admin.access_users.create_user_submit")}
                  </button>
                </form>
              </details>
            )}
          </section>
        )}

        {CAN_READ_ROLES && (
          <section class="au-section">
            <div class="au-section-header">
              <h2>{t("admin.access_users.roles_title")}</h2>
            </div>

            <div class="table-scroll">
              <table class="au-table">
                <thead>
                  <tr>
                    <th>{t("admin.access_users.role_column")}</th>
                    <th>{t("admin.access_users.code_column")}</th>
                    <th>{t("admin.access_users.permission_column")}</th>
                    <th>{t("admin.access_users.users_column")}</th>
                    {CAN_CONFIGURE_ROLES && (
                      <th>{t("admin.access_users.actions_column")}</th>
                    )}
                  </tr>
                </thead>
                <tbody>
                  {data.roles.length === 0 && (
                    <tr>
                      <td colspan={CAN_CONFIGURE_ROLES ? 5 : 4}>
                        {t("admin.access_users.no_roles")}
                      </td>
                    </tr>
                  )}
                  {data.roles.map((role) => (
                    <tr>
                      <td>
                        {role.roleName}
                        {role.isSystem && (
                          <em class="system-role-badge">
                            {t("admin.access_users.system_role_badge")}
                          </em>
                        )}
                      </td>
                      <td>
                        <code>{role.roleCode}</code>
                      </td>
                      <td>{role.permissionIds.length}</td>
                      <td>{role.assignedUserCount}</td>
                      {CAN_CONFIGURE_ROLES && (
                        <td>
                          <details>
                            <summary>
                              {t("admin.access_users.edit_summary")}
                            </summary>
                            <form
                              class="edit-role-form"
                              data-role-id={role.roleId}
                              data-role-system={
                                role.isSystem ? "true" : "false"
                              }
                            >
                              <label>
                                {t("admin.access_users.role_name_label")}
                                <input
                                  type="text"
                                  name="roleName"
                                  value={role.roleName}
                                  required
                                />
                              </label>
                              <fieldset
                                class="role-checkbox-group"
                                disabled={role.isSystem}
                              >
                                <legend>
                                  {t("admin.access_users.permission_legend")}
                                  {role.isSystem &&
                                    ` ${t("admin.access_users.system_role_note")}`}
                                </legend>
                                {[...permissionGroups.entries()].map(
                                  ([moduleKey, perms]) => (
                                    <div class="permission-module-group">
                                      <strong>{moduleKey}</strong>
                                      {perms.map((permission) => (
                                        <label class="checkbox-label">
                                          <input
                                            type="checkbox"
                                            name="permissionIds"
                                            value={permission.permissionId}
                                            checked={role.permissionIds.includes(
                                              permission.permissionId
                                            )}
                                          />
                                          {permission.activityCode}.
                                          {permission.action}
                                        </label>
                                      ))}
                                    </div>
                                  )
                                )}
                              </fieldset>
                              <button type="submit">
                                {t("admin.access_users.save_button")}
                              </button>
                            </form>
                          </details>
                          {!role.isSystem && (
                            <button
                              type="button"
                              class="delete-role-button"
                              data-delete-role={role.roleId}
                            >
                              {t("admin.access_users.delete_button")}
                            </button>
                          )}
                        </td>
                      )}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            {CAN_CONFIGURE_ROLES && (
              <details class="au-create">
                <summary>{t("admin.access_users.create_role_summary")}</summary>
                <form id="create-role-form" class="au-form">
                  <label>
                    {t("admin.access_users.role_code_label")}
                    <input
                      type="text"
                      name="roleCode"
                      pattern="^[a-z][a-z0-9_]*$"
                      placeholder={t(
                        "admin.access_users.role_code_placeholder"
                      )}
                      required
                    />
                  </label>
                  <label>
                    {t("admin.access_users.role_name_label")}
                    <input type="text" name="roleName" required />
                  </label>
                  <fieldset class="role-checkbox-group">
                    <legend>{t("admin.access_users.permission_legend")}</legend>
                    {[...permissionGroups.entries()].map(
                      ([moduleKey, perms]) => (
                        <div class="permission-module-group">
                          <strong>{moduleKey}</strong>
                          {perms.map((permission) => (
                            <label class="checkbox-label">
                              <input
                                type="checkbox"
                                name="permissionIds"
                                value={permission.permissionId}
                              />
                              {permission.activityCode}.{permission.action}
                            </label>
                          ))}
                        </div>
                      )
                    )}
                  </fieldset>
                  <button type="submit">
                    {t("admin.access_users.create_role_submit")}
                  </button>
                </form>
              </details>
            )}
          </section>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .access-users {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
  }

  .action-banner[data-variant="success"] {
    background: color-mix(
      in srgb,
      var(--color-success) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-success);
  }

  .action-banner[data-variant="error"] {
    background: color-mix(
      in srgb,
      var(--color-danger) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-danger);
  }

  .au-section-header h2 {
    margin: 0 0 var(--sp-3);
    font-size: var(--fs-md);
  }

  /* Responsive (doc 14 §Responsif) — a wide table scrolls inside its own
     container on tablet instead of forcing the whole page to scroll
     horizontally. */
  .table-scroll {
    overflow-x: auto;
    margin-bottom: var(--sp-3);
  }

  .au-table {
    width: 100%;
    border-collapse: collapse;
  }

  .au-table th,
  .au-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--fs-sm);
    vertical-align: top;
  }

  /*
   * Solid-fill badge (Issue #434 UX/UI audit): the previous style used
   * `--color-success`/`--color-danger` as *text* color on `--color-surface-2`
   * — measured at 2.91:1 (active, light) and 4.06:1 (inactive, dark),
   * both below the WCAG AA 4.5:1 minimum for text. A solid fill paired with
   * `--color-primary-contrast` (white) using the "-strong" tokens (tuned for
   * exactly this pairing, see tokens.css) fixes contrast in both themes.
   * Status is still conveyed by the text label too ("Aktif"/"Tidak aktif"),
   * not color alone.
   */
  .status-pill {
    display: inline-block;
    padding: 0 var(--sp-2);
    border-radius: var(--radius-full);
    font-size: var(--fs-xs);
    color: var(--color-primary-contrast);
  }

  .status-pill[data-status="active"] {
    background: var(--color-success-strong);
  }

  .status-pill[data-status="inactive"] {
    background: var(--color-danger-strong);
  }

  .role-chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1);
    margin-bottom: var(--sp-1);
  }

  .role-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    background: var(--color-surface-2);
    border-radius: var(--radius-full);
    padding: 0 var(--sp-2);
    font-size: var(--fs-xs);
  }

  .role-chip-empty {
    color: var(--color-text-muted);
    font-size: var(--fs-xs);
  }

  .role-chip-remove {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    font-size: var(--fs-sm);
    line-height: 1;
    padding: 0;
  }

  .role-chip-remove:hover {
    color: var(--color-danger-strong);
  }

  /* Touch target >= 44px on tablet/mobile (doc 14 §Aksesibilitas). */
  @media (max-width: 768px) {
    .role-chip-remove,
    .toggle-status-button,
    .delete-role-button,
    .assign-role-form button {
      min-height: 44px;
      min-width: 44px;
    }
  }

  .assign-role-form {
    display: flex;
    gap: var(--sp-1);
  }

  .assign-role-form select,
  .assign-role-form button {
    font-size: var(--fs-xs);
  }

  .system-role-badge {
    font-style: normal;
    font-size: var(--fs-xs);
    background: var(--color-surface-2);
    border-radius: var(--radius-sm);
    padding: 0 var(--sp-1);
    margin-left: var(--sp-1);
  }

  .toggle-status-button,
  .delete-role-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-2);
    cursor: pointer;
    font-size: var(--fs-xs);
  }

  .delete-role-button {
    margin-top: var(--sp-1);
    color: var(--color-danger-strong);
    border-color: var(--color-danger-strong);
  }

  .au-create {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }

  .au-create summary {
    cursor: pointer;
    font-weight: 600;
  }

  .au-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-top: var(--sp-3);
    max-width: 480px;
  }

  .au-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }

  .au-form input[type="text"],
  .au-form input[type="password"] {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .role-checkbox-group {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--sp-2);
  }

  .permission-module-group {
    margin-bottom: var(--sp-2);
  }

  .permission-module-group strong {
    display: block;
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin-bottom: var(--sp-1);
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
    font-weight: 400;
  }

  .au-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-2) var(--sp-4);
    min-height: 44px;
    cursor: pointer;
  }

  .au-form button:disabled,
  .assign-role-form button:disabled,
  .toggle-status-button:disabled,
  .delete-role-button:disabled {
    cursor: not-allowed;
    opacity: 0.7;
  }
</style>

<script>
  // Issue #434 (UX/UI audit): `submitJson`/`showBanner`/`reloadAfterDelay`
  // used to be duplicated verbatim in this file, `admin/sync.astro`, and
  // `admin/settings.astro` — now shared (doc 14 §Konsistensi). `lockElement`
  // is new: it disables the button that triggered a mutation for the
  // duration of the request so a fast double-click/double-Enter can't fire
  // it twice (doc 14 §Form UX "cegah double-submit"); errors leave the
  // button re-enabled and every field exactly as the user left it.
  import {
    lockElement,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../lib/ui/admin-form-client";

  interface AccessUsersStrings {
    createUserSuccess: string;
    createRoleSuccess: string;
    updateRoleSuccess: string;
    deleteRoleSuccess: string;
    updateStatusSuccess: string;
    assignRoleSuccess: string;
    unassignRoleSuccess: string;
    deleteRolePrompt: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<AccessUsersStrings>();

  function submitButtonOf(form: HTMLFormElement): HTMLButtonElement | null {
    return form.querySelector('button[type="submit"]');
  }

  document
    .getElementById("create-user-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = submitButtonOf(form);
      if (button?.disabled) return;
      const unlock = button ? lockElement(button, strings.pleaseWait) : null;

      try {
        const formData = new FormData(form);
        const roleIds = formData.getAll("roleIds") as string[];

        const result = await submitJson(
          "/api/v1/users",
          "POST",
          {
            displayName: formData.get("displayName"),
            loginIdentifier: formData.get("loginIdentifier"),
            password: formData.get("password"),
            roleIds
          },
          strings
        );

        showBanner(
          "action-banner",
          result.ok ? strings.createUserSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock?.();
      }
    });

  document
    .getElementById("create-role-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = submitButtonOf(form);
      if (button?.disabled) return;
      const unlock = button ? lockElement(button, strings.pleaseWait) : null;

      try {
        const formData = new FormData(form);
        const permissionIds = formData.getAll("permissionIds") as string[];

        const result = await submitJson(
          "/api/v1/roles",
          "POST",
          {
            roleCode: formData.get("roleCode"),
            roleName: formData.get("roleName"),
            permissionIds
          },
          strings
        );

        showBanner(
          "action-banner",
          result.ok ? strings.createRoleSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock?.();
      }
    });

  document.querySelectorAll(".edit-role-form").forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const el = event.target as HTMLFormElement;
      const button = submitButtonOf(el);
      if (button?.disabled) return;
      const unlock = button ? lockElement(button, strings.pleaseWait) : null;

      try {
        const roleId = el.dataset.roleId!;
        const isSystem = el.dataset.roleSystem === "true";
        const formData = new FormData(el);

        const body: Record<string, unknown> = {
          roleName: formData.get("roleName")
        };
        if (!isSystem) {
          body.permissionIds = formData.getAll("permissionIds");
        }

        const result = await submitJson(
          `/api/v1/roles/${roleId}`,
          "PATCH",
          body,
          strings
        );
        showBanner(
          "action-banner",
          result.ok ? strings.updateRoleSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock?.();
      }
    });
  });

  document.querySelectorAll(".delete-role-button").forEach((button) => {
    button.addEventListener("click", async () => {
      const el = button as HTMLButtonElement;
      if (el.disabled) return;

      const roleId = el.dataset.deleteRole!;
      const reason = window.prompt(strings.deleteRolePrompt);
      if (!reason || reason.trim().length === 0) return;

      const unlock = lockElement(el, strings.pleaseWait);
      try {
        const result = await submitJson(
          `/api/v1/roles/${roleId}`,
          "DELETE",
          { reason },
          strings
        );
        showBanner(
          "action-banner",
          result.ok ? strings.deleteRoleSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock();
      }
    });
  });

  document.querySelectorAll(".toggle-status-button").forEach((button) => {
    button.addEventListener("click", async () => {
      const el = button as HTMLButtonElement;
      if (el.disabled) return;
      const unlock = lockElement(el, strings.pleaseWait);

      try {
        const tenantUserId = el.dataset.toggleUser!;
        const nextStatus = el.dataset.nextStatus!;

        const result = await submitJson(
          `/api/v1/users/${tenantUserId}`,
          "PATCH",
          { status: nextStatus },
          strings
        );
        showBanner(
          "action-banner",
          result.ok ? strings.updateStatusSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock();
      }
    });
  });

  document.querySelectorAll(".assign-role-form").forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const el = event.target as HTMLFormElement;
      const button = submitButtonOf(el);
      if (button?.disabled) return;

      const formData = new FormData(el);
      const roleId = formData.get("roleId");
      if (!roleId) return;

      const unlock = button ? lockElement(button, strings.pleaseWait) : null;
      try {
        const tenantUserId = el.dataset.assignUser!;
        const result = await submitJson(
          "/api/v1/access/assignments",
          "POST",
          { tenantUserId, roleId },
          strings
        );
        showBanner(
          "action-banner",
          result.ok ? strings.assignRoleSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock?.();
      }
    });
  });

  document.querySelectorAll(".role-chip-remove").forEach((button) => {
    button.addEventListener("click", async () => {
      const el = button as HTMLButtonElement;
      if (el.disabled) return;
      const unlock = lockElement(el);

      try {
        const tenantUserId = el.dataset.unassignUser!;
        const roleId = el.dataset.unassignRole!;

        const result = await submitJson(
          "/api/v1/access/assignments",
          "DELETE",
          { tenantUserId, roleId },
          strings
        );
        showBanner(
          "action-banner",
          result.ok ? strings.unassignRoleSuccess : result.message,
          result.ok ? "success" : "error"
        );
        if (result.ok) reloadAfterDelay();
      } finally {
        unlock();
      }
    });
  });
</script>
