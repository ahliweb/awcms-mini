---
/**
 * Organization-unit types admin screen (Issue #749, epic #738
 * platform-evolution Wave 2). Same compact pattern as
 * `legal-entities.astro`.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { listOrganizationUnitTypes } from "../../../modules/organization-structure/application/organization-unit-type-directory";
import { DEFAULT_UNIT_TYPE_SEEDS } from "../../../modules/organization-structure/domain/organization-unit-type";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/organization-structure/unit-types.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("organization_structure", "unit_types", "read")
);
const CAN_CREATE = context.permissions.has(
  permissionKey("organization_structure", "unit_types", "create")
);
const CAN_DELETE = context.permissions.has(
  permissionKey("organization_structure", "unit_types", "delete")
);
const CAN_RESTORE = context.permissions.has(
  permissionKey("organization_structure", "unit_types", "restore")
);

const clientStrings = {
  createSuccess: t("admin.organization_structure.unit_types.create_success"),
  deleteSuccess: t("admin.organization_structure.unit_types.delete_success"),
  restoreSuccess: t("admin.organization_structure.unit_types.restore_success"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let unitTypes: Awaited<ReturnType<typeof listOrganizationUnitTypes>> = [];
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      unitTypes = await listOrganizationUnitTypes(
        tx,
        context.tenantId,
        CAN_RESTORE
      );
    });
  } catch (error) {
    logAdminPageError(
      "admin/organization-structure/unit-types.astro: failed to load unit types",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.organization_structure.unit_types.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.organization_structure.access_denied_title")}
        body={t("admin.organization_structure.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="config-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        {unitTypes.length === 0 ? (
          <p class="empty-state">
            {t("admin.organization_structure.unit_types.no_rows")}
          </p>
        ) : (
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">
                  {t("admin.organization_structure.unit_types.col_code")}
                </th>
                <th scope="col">
                  {t("admin.organization_structure.unit_types.col_name")}
                </th>
                <th scope="col">
                  {t("admin.organization_structure.unit_types.col_status")}
                </th>
                <th scope="col">
                  {t("admin.organization_structure.unit_types.col_actions")}
                </th>
              </tr>
            </thead>
            <tbody>
              {unitTypes.map((unitType) => (
                <tr data-id={unitType.id}>
                  <td>{unitType.code}</td>
                  <td>{unitType.name}</td>
                  <td>{unitType.deletedAt ? "deleted" : unitType.status}</td>
                  <td>
                    {CAN_DELETE && !unitType.deletedAt && (
                      <button
                        type="button"
                        class="delete-button"
                        data-id={unitType.id}
                      >
                        {t(
                          "admin.organization_structure.unit_types.delete_button"
                        )}
                      </button>
                    )}
                    {CAN_RESTORE && unitType.deletedAt && (
                      <button
                        type="button"
                        class="restore-button"
                        data-id={unitType.id}
                      >
                        {t(
                          "admin.organization_structure.unit_types.restore_button"
                        )}
                      </button>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}

        {CAN_CREATE && (
          <details class="create-config">
            <summary>
              {t("admin.organization_structure.unit_types.create_summary")}
            </summary>
            <p class="field-hint">
              {t("admin.organization_structure.unit_types.suggested_codes")}:{" "}
              {DEFAULT_UNIT_TYPE_SEEDS.map((seed) => seed.code).join(", ")}
            </p>
            <form id="create-form" class="create-config-form">
              <label>
                {t("admin.organization_structure.unit_types.field_code")}
                <input
                  type="text"
                  name="code"
                  required
                  pattern="^[a-z][a-z0-9_]*$"
                  maxlength="60"
                />
              </label>
              <label>
                {t("admin.organization_structure.unit_types.field_name")}
                <input type="text" name="name" required maxlength="200" />
              </label>
              <label>
                {t("admin.organization_structure.unit_types.field_description")}
                <textarea name="description" rows={2} />
              </label>
              <button type="submit">
                {t("admin.organization_structure.unit_types.create_submit")}
              </button>
            </form>
          </details>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
  }
  .action-banner[data-variant="success"] {
    background: color-mix(
      in srgb,
      var(--color-success) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-success);
  }
  .action-banner[data-variant="error"] {
    background: color-mix(
      in srgb,
      var(--color-danger) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-danger);
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
  }
  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }
  .delete-button,
  .restore-button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .delete-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
  }
  .restore-button {
    background: var(--color-primary-strong);
    border: none;
    color: var(--color-primary-contrast);
  }
  .create-config {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }
  .create-config summary {
    cursor: pointer;
    font-weight: 600;
  }
  .field-hint {
    color: var(--color-text-muted);
    font-size: var(--fs-xs);
  }
  .create-config-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 480px;
    margin-top: var(--sp-2);
  }
  .create-config-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }
  .create-config-form input,
  .create-config-form textarea {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }
  .create-config-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }
  input:focus-visible,
  textarea:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    createSuccess: string;
    deleteSuccess: string;
    restoreSuccess: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE_URL = "/api/v1/organization-structure/unit-types";

  document
    .getElementById("create-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);

      try {
        const formData = new FormData(form);
        const result = await submitJson(
          BASE_URL,
          "POST",
          {
            code: formData.get("code"),
            name: formData.get("name"),
            description: formData.get("description") || null
          },
          strings
        );

        if (result.ok) {
          showBanner("action-banner", strings.createSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  document
    .querySelectorAll<HTMLButtonElement>(".delete-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const unlock = lockElement(button, strings.pleaseWait);
        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}`,
            "DELETE",
            {},
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );
          if (result.ok) {
            showBanner("action-banner", strings.deleteSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>(".restore-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const unlock = lockElement(button, strings.pleaseWait);
        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}/restore`,
            "POST",
            {},
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );
          if (result.ok) {
            showBanner("action-banner", strings.restoreSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
</script>
