---
/**
 * Organization-unit assignments admin screen (Issue #749, epic #738
 * platform-evolution Wave 2).
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { listOrganizationUnitAssignments } from "../../../modules/organization-structure/application/organization-unit-assignment-service";
import { listOrganizationUnits } from "../../../modules/organization-structure/application/organization-unit-directory";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/organization-structure/assignments.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("organization_structure", "assignments", "read")
);
const CAN_CREATE = context.permissions.has(
  permissionKey("organization_structure", "assignments", "create")
);
const CAN_REVOKE = context.permissions.has(
  permissionKey("organization_structure", "assignments", "revoke")
);

const clientStrings = {
  createSuccess: t("admin.organization_structure.assignments.create_success"),
  endSuccess: t("admin.organization_structure.assignments.end_success"),
  endReasonPrompt: t(
    "admin.organization_structure.assignments.end_reason_prompt"
  ),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let assignments: Awaited<ReturnType<typeof listOrganizationUnitAssignments>> =
  [];
let units: Awaited<ReturnType<typeof listOrganizationUnits>>["units"] = [];
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      assignments = await listOrganizationUnitAssignments(
        tx,
        context.tenantId,
        {}
      );
      units = (await listOrganizationUnits(tx, context.tenantId, {})).units;
    });
  } catch (error) {
    logAdminPageError(
      "admin/organization-structure/assignments.astro: failed to load assignments",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}

function unitLabel(unitId: string): string {
  const unit = units.find((candidate) => candidate.id === unitId);
  return unit ? `${unit.name} (${unit.code})` : unitId;
}
---

<AdminLayout title={t("admin.organization_structure.assignments.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.organization_structure.access_denied_title")}
        body={t("admin.organization_structure.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="config-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        {assignments.length === 0 ? (
          <p class="empty-state">
            {t("admin.organization_structure.assignments.no_rows")}
          </p>
        ) : (
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">
                  {t("admin.organization_structure.assignments.col_unit")}
                </th>
                <th scope="col">
                  {t("admin.organization_structure.assignments.col_position")}
                </th>
                <th scope="col">
                  {t("admin.organization_structure.assignments.col_status")}
                </th>
                <th scope="col">
                  {t("admin.organization_structure.assignments.col_actions")}
                </th>
              </tr>
            </thead>
            <tbody>
              {assignments.map((assignment) => (
                <tr data-id={assignment.id}>
                  <td>{unitLabel(assignment.organizationUnitId)}</td>
                  <td>{assignment.positionLabel ?? "—"}</td>
                  <td>{assignment.status}</td>
                  <td>
                    {CAN_REVOKE && assignment.status === "active" && (
                      <button
                        type="button"
                        class="end-button"
                        data-id={assignment.id}
                      >
                        {t(
                          "admin.organization_structure.assignments.end_button"
                        )}
                      </button>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}

        {CAN_CREATE && (
          <details class="create-config">
            <summary>
              {t("admin.organization_structure.assignments.create_summary")}
            </summary>
            <form id="create-form" class="create-config-form">
              <label>
                {t("admin.organization_structure.assignments.field_unit")}
                <select name="organizationUnitId" required>
                  {units.map((unit) => (
                    <option value={unit.id}>
                      {unit.name} ({unit.code})
                    </option>
                  ))}
                </select>
              </label>
              <label>
                {t(
                  "admin.organization_structure.assignments.field_tenant_user"
                )}
                <input
                  type="text"
                  name="tenantUserId"
                  required
                  placeholder="uuid"
                />
              </label>
              <label>
                {t("admin.organization_structure.assignments.field_position")}
                <input type="text" name="positionLabel" maxlength="200" />
              </label>
              <button type="submit">
                {t("admin.organization_structure.assignments.create_submit")}
              </button>
            </form>
          </details>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
  }
  .action-banner[data-variant="success"] {
    background: var(--color-success-surface, #e6f4ea);
    color: var(--color-success-strong, #1e7e34);
  }
  .action-banner[data-variant="error"] {
    background: var(--color-danger-surface, #fdecea);
    color: var(--color-danger-strong);
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
  }
  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }
  .end-button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
  }
  .create-config {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }
  .create-config summary {
    cursor: pointer;
    font-weight: 600;
  }
  .create-config-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 480px;
    margin-top: var(--sp-2);
  }
  .create-config-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }
  .create-config-form input,
  .create-config-form select {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }
  .create-config-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }
  input:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    createSuccess: string;
    endSuccess: string;
    endReasonPrompt: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE_URL = "/api/v1/organization-structure/assignments";

  document
    .getElementById("create-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);

      try {
        const formData = new FormData(form);
        const result = await submitJson(
          BASE_URL,
          "POST",
          {
            organizationUnitId: formData.get("organizationUnitId"),
            tenantUserId: formData.get("tenantUserId"),
            positionLabel: formData.get("positionLabel") || null
          },
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );

        if (result.ok) {
          showBanner("action-banner", strings.createSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  document
    .querySelectorAll<HTMLButtonElement>(".end-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const reason = window.prompt(strings.endReasonPrompt);
        if (!reason) return;
        const unlock = lockElement(button, strings.pleaseWait);
        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}/end`,
            "POST",
            { endReason: reason },
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );
          if (result.ok) {
            showBanner("action-banner", strings.endSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
</script>
