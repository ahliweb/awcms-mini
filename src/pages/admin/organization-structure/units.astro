---
/**
 * Organization units admin screen (Issue #749, epic #738
 * platform-evolution Wave 2). Lists the first page (no client-side
 * pagination UI yet — `nextCursor` is a documented follow-up, same
 * "bounded first page, pagination UI later" precedent other admin list
 * screens in this repo accept for a first cut).
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { listOrganizationUnits } from "../../../modules/organization-structure/application/organization-unit-directory";
import { listLegalEntities } from "../../../modules/organization-structure/application/legal-entity-directory";
import { listOrganizationUnitTypes } from "../../../modules/organization-structure/application/organization-unit-type-directory";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/organization-structure/units.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("organization_structure", "units", "read")
);
const CAN_CREATE = context.permissions.has(
  permissionKey("organization_structure", "units", "create")
);
const CAN_DELETE = context.permissions.has(
  permissionKey("organization_structure", "units", "delete")
);
const CAN_RESTORE = context.permissions.has(
  permissionKey("organization_structure", "units", "restore")
);

const clientStrings = {
  createSuccess: t("admin.organization_structure.units.create_success"),
  deactivateSuccess: t("admin.organization_structure.units.deactivate_success"),
  restoreSuccess: t("admin.organization_structure.units.restore_success"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let units: Awaited<ReturnType<typeof listOrganizationUnits>>["units"] = [];
let legalEntities: Awaited<ReturnType<typeof listLegalEntities>> = [];
let unitTypes: Awaited<ReturnType<typeof listOrganizationUnitTypes>> = [];
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      const result = await listOrganizationUnits(tx, context.tenantId, {});
      units = result.units;
      legalEntities = await listLegalEntities(tx, context.tenantId);
      unitTypes = await listOrganizationUnitTypes(tx, context.tenantId);
    });
  } catch (error) {
    logAdminPageError(
      "admin/organization-structure/units.astro: failed to load units",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.organization_structure.units.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.organization_structure.access_denied_title")}
        body={t("admin.organization_structure.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="config-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        {units.length === 0 ? (
          <p class="empty-state">
            {t("admin.organization_structure.units.no_rows")}
          </p>
        ) : (
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">
                  {t("admin.organization_structure.units.col_code")}
                </th>
                <th scope="col">
                  {t("admin.organization_structure.units.col_name")}
                </th>
                <th scope="col">
                  {t("admin.organization_structure.units.col_status")}
                </th>
                <th scope="col">
                  {t("admin.organization_structure.units.col_actions")}
                </th>
              </tr>
            </thead>
            <tbody>
              {units.map((unit) => (
                <tr data-id={unit.id}>
                  <td>{unit.code}</td>
                  <td>{unit.name}</td>
                  <td>{unit.deletedAt ? "deleted" : unit.status}</td>
                  <td>
                    {CAN_DELETE && !unit.deletedAt && (
                      <button
                        type="button"
                        class="deactivate-button"
                        data-id={unit.id}
                      >
                        {t(
                          "admin.organization_structure.units.deactivate_button"
                        )}
                      </button>
                    )}
                    {CAN_RESTORE && unit.deletedAt && (
                      <button
                        type="button"
                        class="restore-button"
                        data-id={unit.id}
                      >
                        {t("admin.organization_structure.units.restore_button")}
                      </button>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}

        {CAN_CREATE && (
          <details class="create-config">
            <summary>
              {t("admin.organization_structure.units.create_summary")}
            </summary>
            <form id="create-form" class="create-config-form">
              <label>
                {t("admin.organization_structure.units.field_code")}
                <input
                  type="text"
                  name="code"
                  required
                  pattern="^[a-z0-9][a-z0-9_-]*$"
                  maxlength="60"
                />
              </label>
              <label>
                {t("admin.organization_structure.units.field_name")}
                <input type="text" name="name" required maxlength="200" />
              </label>
              <label>
                {t("admin.organization_structure.units.field_legal_entity")}
                <select name="legalEntityId">
                  <option value="">
                    {t("admin.organization_structure.units.none_option")}
                  </option>
                  {legalEntities.map((entity) => (
                    <option value={entity.id}>{entity.name}</option>
                  ))}
                </select>
              </label>
              <label>
                {t("admin.organization_structure.units.field_unit_type")}
                <select name="unitTypeId">
                  <option value="">
                    {t("admin.organization_structure.units.none_option")}
                  </option>
                  {unitTypes.map((unitType) => (
                    <option value={unitType.id}>{unitType.name}</option>
                  ))}
                </select>
              </label>
              <button type="submit">
                {t("admin.organization_structure.units.create_submit")}
              </button>
            </form>
          </details>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
  }
  .action-banner[data-variant="success"] {
    background: var(--color-success-surface, #e6f4ea);
    color: var(--color-success-strong, #1e7e34);
  }
  .action-banner[data-variant="error"] {
    background: var(--color-danger-surface, #fdecea);
    color: var(--color-danger-strong);
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
  }
  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }
  .deactivate-button,
  .restore-button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .deactivate-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
  }
  .restore-button {
    background: var(--color-primary-strong);
    border: none;
    color: var(--color-primary-contrast);
  }
  .create-config {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }
  .create-config summary {
    cursor: pointer;
    font-weight: 600;
  }
  .create-config-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 480px;
    margin-top: var(--sp-2);
  }
  .create-config-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }
  .create-config-form input,
  .create-config-form select {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }
  .create-config-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }
  input:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    createSuccess: string;
    deactivateSuccess: string;
    restoreSuccess: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE_URL = "/api/v1/organization-structure/units";

  document
    .getElementById("create-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);

      try {
        const formData = new FormData(form);
        const result = await submitJson(
          BASE_URL,
          "POST",
          {
            code: formData.get("code"),
            name: formData.get("name"),
            legalEntityId: formData.get("legalEntityId") || null,
            unitTypeId: formData.get("unitTypeId") || null
          },
          strings
        );

        if (result.ok) {
          showBanner("action-banner", strings.createSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  document
    .querySelectorAll<HTMLButtonElement>(".deactivate-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const unlock = lockElement(button, strings.pleaseWait);
        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}`,
            "DELETE",
            {},
            strings
          );
          if (result.ok) {
            showBanner("action-banner", strings.deactivateSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>(".restore-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const unlock = lockElement(button, strings.pleaseWait);
        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}/restore`,
            "POST",
            {},
            strings
          );
          if (result.ok) {
            showBanner("action-banner", strings.restoreSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
</script>
