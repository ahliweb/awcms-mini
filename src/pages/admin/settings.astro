---
/**
 * Settings admin screen — tenant profile (name, legal name) and preferences
 * (default locale, default theme, timezone, feature flags), backed by
 * `GET/PATCH /api/v1/settings`.
 *
 * `defaultTheme` here is the tenant-wide *fallback* used when a browser has
 * no personal override yet — distinct from `ThemeToggle.astro`'s per-browser
 * `localStorage["awcms_mini_theme"]`, which always wins once set (doc 14
 * §Theming: "localStorage + awcms_mini_tenants.default_theme"). See
 * AdminLayout.astro's inline no-flash theme script for how the two combine.
 *
 * SSR fetches via the same application-layer function the JSON endpoint uses
 * (`tenant-admin/application/tenant-settings-directory.ts`), matching the
 * `user-directory.ts`/`sync-directory.ts` pattern from the other two admin
 * screens. Permission-gated on `tenant_admin.tenant_settings.{read,update}`
 * (migration 015) — defense-in-depth, the endpoint is the real enforcement.
 */
import AdminLayout from "../../layouts/AdminLayout.astro";
import StateNotice from "../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../lib/database/client";
import { withTenant } from "../../lib/database/tenant-context";
import { permissionKey } from "../../modules/identity-access/domain/access-control";
import { fetchTenantSettings } from "../../modules/tenant-admin/application/tenant-settings-directory";
import { createTranslator } from "../../lib/i18n/translate";
import { buildClientErrorMessages } from "../../lib/i18n/error-messages";
import {
  LOCALE_FLAGS,
  LOCALE_LABELS,
  SUPPORTED_LOCALES
} from "../../lib/i18n/locale";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/settings.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const clientStrings = {
  invalidFeatureFlags: t("admin.settings.invalid_feature_flags"),
  saveSuccess: t("admin.settings.save_success"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

const CAN_READ = context.permissions.has(
  permissionKey("tenant_admin", "tenant_settings", "read")
);
const CAN_UPDATE = context.permissions.has(
  permissionKey("tenant_admin", "tenant_settings", "update")
);

// Issue #434 (UX/UI audit) — see `admin/access-users.astro` for the same
// denied-vs-error split (doc 14 §State pattern wajib Error branch).
let settings: Awaited<ReturnType<typeof fetchTenantSettings>> | null = null;
let loadError = false;

if (CAN_READ) {
  try {
    settings = await withTenant(getDatabaseClient(), context.tenantId, (tx) =>
      fetchTenantSettings(tx, context.tenantId)
    );
  } catch (error) {
    console.error("admin/settings.astro: failed to load settings", error);
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.layout.nav_settings")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.settings.access_denied_title")}
        body={t("admin.settings.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    settings && (
      <div class="settings-admin">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        <form id="settings-form" class="settings-form">
          <fieldset disabled={!CAN_UPDATE}>
            <legend>{t("admin.settings.tenant_profile_legend")}</legend>
            <label>
              {t("admin.settings.tenant_name_label")}
              <input
                type="text"
                name="tenantName"
                value={settings.tenantName}
                required
              />
            </label>
            <label>
              {t("admin.settings.legal_name_label")}
              <input
                type="text"
                name="legalName"
                value={settings.legalName ?? ""}
              />
            </label>
          </fieldset>

          <fieldset disabled={!CAN_UPDATE}>
            <legend>{t("admin.settings.display_preferences_legend")}</legend>
            <label>
              {t("admin.settings.default_locale_label")}
              <select name="defaultLocale">
                {SUPPORTED_LOCALES.map((locale) => (
                  <option
                    value={locale}
                    selected={locale === settings.defaultLocale}
                  >
                    {LOCALE_FLAGS[locale]} {LOCALE_LABELS[locale]}
                  </option>
                ))}
              </select>
            </label>
            <label>
              {t("admin.settings.default_theme_label")}
              <select name="defaultTheme">
                {["system", "light", "dark"].map((theme) => (
                  <option
                    value={theme}
                    selected={theme === settings.defaultTheme}
                  >
                    {theme}
                  </option>
                ))}
              </select>
            </label>
            <p class="field-hint">{t("admin.settings.default_theme_hint")}</p>
          </fieldset>

          <fieldset disabled={!CAN_UPDATE}>
            <legend>{t("admin.settings.timezone_legend")}</legend>
            <label>
              {t("admin.settings.timezone_label")}
              <input
                type="text"
                name="timezone"
                value={settings.timezone}
                placeholder="Asia/Jakarta"
                required
              />
            </label>
          </fieldset>

          <fieldset disabled={!CAN_UPDATE}>
            <legend>{t("admin.settings.feature_flags_legend")}</legend>
            <label>
              {t("admin.settings.feature_flags_json_label")}
              <textarea name="featureFlags" rows="6" spellcheck="false">
                {JSON.stringify(settings.featureFlags, null, 2)}
              </textarea>
            </label>
            <p class="field-hint">{t("admin.settings.feature_flags_hint")}</p>
          </fieldset>

          {CAN_UPDATE && (
            <button type="submit" id="settings-save-button">
              {t("admin.access_users.save_button")}
            </button>
          )}
        </form>
      </div>
    )
  }
</AdminLayout>

<style>
  .settings-admin {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    max-width: 640px;
  }

  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
  }

  .action-banner[data-variant="success"] {
    background: color-mix(
      in srgb,
      var(--color-success) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-success);
  }

  .action-banner[data-variant="error"] {
    background: color-mix(
      in srgb,
      var(--color-danger) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-danger);
  }

  .settings-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .settings-form fieldset {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .settings-form legend {
    font-weight: 600;
    padding: 0 var(--sp-1);
  }

  .settings-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }

  .settings-form input,
  .settings-form select,
  .settings-form textarea {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
    font-family: inherit;
  }

  .settings-form textarea {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
  }

  /* Touch target >= 44px on tablet/mobile (doc 14 §Aksesibilitas). */
  @media (max-width: 768px) {
    .settings-form input,
    .settings-form select {
      min-height: 44px;
    }
  }

  .field-hint {
    margin: 0;
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
  }

  .settings-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-2) var(--sp-4);
    min-height: 44px;
    cursor: pointer;
  }

  .settings-form button:disabled {
    cursor: not-allowed;
    opacity: 0.7;
  }
</style>

<script>
  // Issue #434 (UX/UI audit) — see `admin/access-users.astro` for why this
  // is now a shared import instead of a duplicated inline implementation,
  // and why the save button locks for the duration of the request (doc 14
  // §Form UX "cegah double-submit").
  import {
    lockElement,
    readClientStrings,
    showBanner,
    submitJson
  } from "../../lib/ui/admin-form-client";

  interface SettingsStrings {
    invalidFeatureFlags: string;
    saveSuccess: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<SettingsStrings>();

  document
    .getElementById("settings-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = document.getElementById(
        "settings-save-button"
      ) as HTMLButtonElement | null;
      if (button?.disabled) return;

      const formData = new FormData(form);

      const featureFlagsRaw = String(formData.get("featureFlags") ?? "{}");
      let featureFlags: unknown;
      try {
        featureFlags = JSON.parse(featureFlagsRaw);
      } catch {
        showBanner("action-banner", strings.invalidFeatureFlags, "error");
        return;
      }

      const unlock = button ? lockElement(button, strings.pleaseWait) : null;
      try {
        const legalNameRaw = formData.get("legalName");
        const body = {
          tenantName: formData.get("tenantName"),
          legalName:
            typeof legalNameRaw === "string" && legalNameRaw.trim().length > 0
              ? legalNameRaw
              : null,
          defaultLocale: formData.get("defaultLocale"),
          defaultTheme: formData.get("defaultTheme"),
          timezone: formData.get("timezone"),
          featureFlags
        };

        const result = await submitJson(
          "/api/v1/settings",
          "PATCH",
          body,
          strings
        );
        showBanner(
          "action-banner",
          result.ok ? strings.saveSuccess : result.message,
          result.ok ? "success" : "error"
        );
      } finally {
        unlock?.();
      }
    });
</script>
