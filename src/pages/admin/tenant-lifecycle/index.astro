---
/**
 * Tenant lifecycle admin control panel (Issue #873, epic #868 SaaS control
 * plane, ADR-0022). Platform-operator only — the SSR permission gate
 * (`ssr-session.ts`) strips `tenant_lifecycle.*` for any tenant that has not
 * enabled the module (`defaultTenantState: "disabled"`), and the API further
 * restricts every command to the platform (setup singleton) tenant (no soft
 * super-tenant, ADR-0022 §6).
 *
 * A lifecycle record belongs to a TARGET tenant (not the operator's own tenant
 * context), so state + restrictions + timeline are loaded CLIENT-SIDE by target
 * tenant id — the SSR page renders the lookup form + action panel the island
 * fills. Every mutation carries a mandatory reason and an Idempotency-Key.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { createTranslator } from "../../../lib/i18n/translate";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/tenant-lifecycle/index.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("tenant_lifecycle", "states", "read")
);
const CAN_UPDATE = context.permissions.has(
  permissionKey("tenant_lifecycle", "states", "update")
);
const CAN_RESTORE = context.permissions.has(
  permissionKey("tenant_lifecycle", "states", "restore")
);

const clientStrings = {
  notFound: t("admin.tenant_lifecycle.not_found"),
  reasonPrompt: t("admin.tenant_lifecycle.reason_prompt"),
  transitionSuccess: t("admin.tenant_lifecycle.transition_success"),
  restoreSuccess: t("admin.tenant_lifecycle.restore_success"),
  colWhen: t("admin.tenant_lifecycle.col_when"),
  colEvent: t("admin.tenant_lifecycle.col_event"),
  colChange: t("admin.tenant_lifecycle.col_change"),
  colReason: t("admin.tenant_lifecycle.col_reason"),
  transitionLabel: t("admin.tenant_lifecycle.transition_button"),
  restoreLabel: t("admin.tenant_lifecycle.restore_button"),
  restrictionsHeading: t("admin.tenant_lifecycle.restrictions_heading"),
  canUpdate: CAN_UPDATE,
  canRestore: CAN_RESTORE,
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};
---

<AdminLayout title={t("admin.tenant_lifecycle.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.tenant_lifecycle.access_denied_title")}
        body={t("admin.tenant_lifecycle.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && (
      <div class="lifecycle-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />
        <p class="intro">{t("admin.tenant_lifecycle.intro")}</p>

        <section class="panel">
          <h2>{t("admin.tenant_lifecycle.lookup_heading")}</h2>
          <form id="lookup-form" class="inline-form">
            <label>
              {t("admin.tenant_lifecycle.field_target_tenant")}
              <input name="tenantId" required size="40" />
            </label>
            <button type="submit">
              {t("admin.tenant_lifecycle.lookup_button")}
            </button>
          </form>
          <div id="state-panel" class="state-panel" hidden />
          <div id="timeline" class="timeline" hidden />
        </section>
      </div>
    )
  }
</AdminLayout>

<style>
  .lifecycle-manager {
    display: flex;
    flex-direction: column;
    gap: var(--space-6, 1.5rem);
  }
  .panel {
    border: 1px solid var(--color-border, #d4d4d8);
    border-radius: var(--radius-md, 0.5rem);
    padding: var(--space-4, 1rem);
  }
  .action-banner {
    padding: var(--space-3, 0.75rem);
    border-radius: var(--radius-md, 0.5rem);
  }
  .action-banner[data-variant="success"] {
    background: var(--color-success-subtle, #dcfce7);
  }
  .action-banner[data-variant="error"] {
    background: var(--color-danger-subtle, #fee2e2);
  }
  .intro {
    color: var(--color-text-muted, #71717a);
  }
  .inline-form {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3, 0.75rem);
    align-items: end;
  }
  label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.85rem;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: var(--space-2, 0.5rem);
  }
  th,
  td {
    text-align: left;
    padding: var(--space-2, 0.5rem);
    border-bottom: 1px solid var(--color-border, #e4e4e7);
    vertical-align: top;
  }
  .timeline {
    margin-top: var(--space-3, 0.75rem);
    overflow-x: auto;
  }
  .commands {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2, 0.5rem);
    margin-top: var(--space-3, 0.75rem);
  }
  button.danger {
    color: var(--color-danger, #b91c1c);
  }
  input:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    notFound: string;
    reasonPrompt: string;
    transitionSuccess: string;
    restoreSuccess: string;
    colWhen: string;
    colEvent: string;
    colChange: string;
    colReason: string;
    transitionLabel: string;
    restoreLabel: string;
    restrictionsHeading: string;
    canUpdate: boolean;
    canRestore: boolean;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE = "/api/v1/tenant-lifecycle";
  const STATES = [
    "provisioning",
    "trial",
    "active",
    "renewal_due",
    "past_due",
    "grace",
    "suspended",
    "canceled",
    "restoring",
    "blocked"
  ];

  function esc(value: unknown): string {
    return String(value ?? "").replace(
      /[&<>"']/g,
      (c) =>
        ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;"
        })[c] ?? c
    );
  }

  let currentTenantId = "";
  let currentVersion = 0;

  async function loadState(tenantId: string): Promise<void> {
    const statePanel = document.getElementById("state-panel");
    const timeline = document.getElementById("timeline");
    if (!statePanel || !timeline) return;
    currentTenantId = tenantId;
    const response = await fetch(
      `${BASE}/tenants/${encodeURIComponent(tenantId)}`,
      { headers: { Accept: "application/json" } }
    );
    if (response.status === 404) {
      statePanel.hidden = false;
      statePanel.textContent = strings.notFound;
      timeline.hidden = true;
      return;
    }
    if (!response.ok) {
      statePanel.hidden = false;
      statePanel.textContent = strings.networkError;
      return;
    }
    const body = await response.json();
    const data = body.data;
    const lc = data.lifecycle;
    currentVersion = Number(lc.version);
    const profile = data.restrictions.profile as Record<string, boolean>;
    const flags = Object.entries(profile)
      .map(
        ([k, v]) => `<li>${esc(k)}: <strong>${v ? "yes" : "no"}</strong></li>`
      )
      .join("");

    const commands: string[] = [];
    if (strings.canUpdate) {
      const options = STATES.map(
        (s) => `<option value="${s}">${s}</option>`
      ).join("");
      commands.push(
        `<label>${esc(strings.transitionLabel)}<select id="target-state">${options}</select></label>` +
          `<button type="button" data-cmd="transition">${esc(strings.transitionLabel)}</button>`
      );
    }
    if (strings.canRestore) {
      commands.push(
        `<button type="button" class="danger" data-cmd="restore">${esc(strings.restoreLabel)}</button>`
      );
    }

    statePanel.hidden = false;
    statePanel.innerHTML = `
      <p>state <strong>${esc(lc.state)}</strong> · version <strong>${esc(
        lc.version
      )}</strong>${
        lc.scheduledToState
          ? ` · scheduled -> ${esc(lc.scheduledToState)} @ ${esc(lc.scheduledAt)}`
          : ""
      }</p>
      <h3>${esc(strings.restrictionsHeading)}</h3>
      <ul>${flags}</ul>
      <div class="commands">${commands.join("")}</div>`;

    statePanel
      .querySelectorAll<HTMLButtonElement>("[data-cmd]")
      .forEach((button) =>
        button.addEventListener("click", () => runCommand(button))
      );

    const timelineRows: Array<Record<string, unknown>> = data.timeline ?? [];
    timeline.hidden = false;
    timeline.innerHTML = `<table><thead><tr><th>${esc(
      strings.colWhen
    )}</th><th>${esc(strings.colEvent)}</th><th>${esc(
      strings.colChange
    )}</th><th>${esc(strings.colReason)}</th></tr></thead><tbody>${timelineRows
      .map(
        (h) =>
          `<tr><td>${esc(h.createdAt)}</td><td>${esc(h.eventKind)}</td><td>${esc(
            h.fromState
          )} → ${esc(h.toState)}</td><td>${esc(h.reason)}</td></tr>`
      )
      .join("")}</tbody></table>`;
  }

  async function runCommand(button: HTMLButtonElement): Promise<void> {
    const cmd = button.dataset.cmd ?? "";
    const reason = window.prompt(strings.reasonPrompt) ?? null;
    if (reason === null) return;
    let path = "";
    let payload: Record<string, unknown> = {
      reason,
      expectedVersion: currentVersion
    };
    let successMsg = strings.transitionSuccess;
    if (cmd === "transition") {
      const select = document.getElementById(
        "target-state"
      ) as HTMLSelectElement | null;
      payload.toState = select?.value ?? "";
      path = "transition";
    } else if (cmd === "restore") {
      payload = {
        reason,
        confirmUnresolved: true,
        expectedVersion: currentVersion
      };
      path = "restore";
      successMsg = strings.restoreSuccess;
    }
    const unlock = lockElement(button, strings.pleaseWait);
    try {
      const result = await submitJson(
        `${BASE}/tenants/${encodeURIComponent(currentTenantId)}/${path}`,
        "POST",
        payload,
        strings,
        { "Idempotency-Key": newIdempotencyKey() }
      );
      if (result.ok) {
        showBanner("action-banner", successMsg, "success");
        await loadState(currentTenantId);
      } else {
        showBanner("action-banner", result.message, "error");
      }
    } finally {
      unlock();
    }
  }

  document
    .getElementById("lookup-form")
    ?.addEventListener("submit", (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const tenantId = String(new FormData(form).get("tenantId") ?? "").trim();
      if (tenantId) void loadState(tenantId);
    });
</script>
