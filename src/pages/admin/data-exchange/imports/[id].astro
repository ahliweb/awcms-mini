---
/**
 * Import batch detail/preview screen (Issue #752, epic #738
 * platform-evolution Wave 3) — preview (first page, SSR), errors, and the
 * commit/cancel/retry/pause/resume action set. Same SSR-load +
 * client-action-via-fetch pattern as `imports.astro`.
 */
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import StateNotice from "../../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../../lib/database/client";
import { withTenant } from "../../../../lib/database/tenant-context";
import { permissionKey } from "../../../../modules/identity-access/domain/access-control";
import {
  getImportBatchById,
  resolveImportDescriptor
} from "../../../../modules/data-exchange/application/import-batch-directory";
import {
  countStagedRows,
  listStagedRows,
  maskAllFields,
  maskSensitiveFields,
  type StagedRowRow
} from "../../../../modules/data-exchange/application/staged-row-directory";
import { isDescriptorPermissionGranted } from "../../../../modules/data-exchange/application/descriptor-authorization";
import { resolveModuleEnabled } from "../../../../modules/identity-access/application/auth-context";
import { listReconciliationReports } from "../../../../modules/data-exchange/application/reconciliation-service";
import { createTranslator } from "../../../../lib/i18n/translate";
import { logAdminPageError } from "../../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/data-exchange/imports/[id].astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);
const batchId = Astro.params.id;

const CAN_READ = context.permissions.has(
  permissionKey("data_exchange", "imports", "read")
);
const CAN_POST = context.permissions.has(
  permissionKey("data_exchange", "imports", "post")
);
const CAN_CANCEL = context.permissions.has(
  permissionKey("data_exchange", "imports", "cancel")
);
const CAN_RETRY = context.permissions.has(
  permissionKey("data_exchange", "imports", "retry")
);
const CAN_MANAGE = context.permissions.has(
  permissionKey("data_exchange", "imports", "manage")
);
// Issue #820: this screen does NOT go through
// `GET /api/v1/data-exchange/imports/{id}/preview` — it queries and projects
// staged rows itself, and so had its own independent copy of every defect
// that issue fixes in the route (default-allow on an undeclared policy, a
// hardcoded `data_exchange.preview_errors.read` in place of the
// descriptor's own `rawValuePermission`, and no handling of a descriptor
// that stopped resolving). BOTH descriptor-level decisions are made below,
// from the descriptor, exactly as the route makes them — there is
// deliberately no page-level `CAN_SEE_RAW` constant to drift from them
// again.
//
// PR #839's security review found the first pass here made only the
// raw-value decision and skipped the descriptor's `requiredPermission`
// gate entirely — the OWNING module's own permission, which all six API
// routes enforce via `authorizeExchangeDescriptorPermission`. A descriptor
// declaring `requiredPermission: "hr.payroll.read"` was therefore enforced
// everywhere except here, letting a holder of the generic
// `data_exchange.imports.read` read that module's staged content off this
// page. Both gates now run below, sharing the route's semantics via
// `isDescriptorPermissionGranted`.

const clientStrings = {
  actionSuccess: t("admin.data_exchange.imports.action_success"),
  cancelReasonPrompt: t("admin.data_exchange.imports.cancel_reason_prompt"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let batch: Awaited<ReturnType<typeof getImportBatchById>> = null;
let rows: Awaited<ReturnType<typeof listStagedRows>> = [];
let totalRows = 0;
let reconciliation: Awaited<ReturnType<typeof listReconciliationReports>> = [];
let loadError = false;
let notFound = false;
let descriptorDenied = false;

if (CAN_READ && batchId) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      batch = await getImportBatchById(tx, context.tenantId, batchId);
      if (!batch) return;

      // `context.permissions` is NOT the whole gate the API applies:
      // `authorizeInTransaction` denies `403 MODULE_DISABLED` before it ever
      // looks at RBAC, and `fetchGrantedPermissionKeys` (which builds the SSR
      // permission set) never filters disabled modules out. So the `CAN_*`
      // constants above are all still true for a tenant that has switched
      // `data_exchange` off — the page would render staged rows while every
      // route answered 403 (PR #839 security review, second parity finding).
      if (
        !(await resolveModuleEnabled(tx, context.tenantId, "data_exchange"))
      ) {
        descriptorDenied = true;
        batch = null;
        return;
      }

      const descriptor = resolveImportDescriptor(batch.importKey);

      // An unresolvable descriptor (owning module disabled/removed via
      // `module_management` after staging) DENIES — it does not fall back to
      // `maskAllFields`. Nothing left in the registry can say who may read
      // this batch, so masking the values while still rendering the batch's
      // metadata would leave it strictly more exposed than while its module
      // ran. The preview route answers 409 for exactly this state; this page
      // renders the denied notice.
      if (!descriptor) {
        descriptorDenied = true;
        batch = null;
        return;
      }

      // The OWNING module's own permission, on top of the generic
      // `data_exchange.imports.read` gate above — the same check the six API
      // routes make with `authorizeExchangeDescriptorPermission` (a malformed
      // key, and a key whose module this tenant disabled, both fail closed
      // there and here).
      //
      // MUST stay awaited: this returns a Promise, and an un-awaited Promise
      // is truthy, so a dropped `await` here inverts the gate into a silent
      // fail-OPEN. `tsc` does not check `.astro`, so nothing but this comment
      // and the integration test guards that.
      if (
        !(await isDescriptorPermissionGranted(
          tx,
          context.tenantId,
          context.permissions,
          descriptor.requiredPermission
        ))
      ) {
        descriptorDenied = true;
        batch = null;
        return;
      }

      const policy = descriptor.sensitiveFields;

      // Default-deny, same as the route: a descriptor declaring no policy
      // masks everything — including `naturalKey`, which is the only staged
      // VALUE this table actually renders.
      let project: (row: StagedRowRow) => StagedRowRow = maskAllFields;
      if (policy) {
        // The descriptor's OWN permission, never a generic data_exchange one.
        // Goes through the same helper as `requiredPermission` above rather
        // than reading `context.permissions` directly: the route's raw-value
        // gate is `authorizeDescriptorPermissionKey`, which resolves module
        // state too, so a bare `permissions.has()` here would unmask values
        // the route masks once the declaring module is disabled.
        const canSeeRaw =
          policy.fieldNames.length === 0 ||
          (policy.rawValuePermission !== undefined &&
            (await isDescriptorPermissionGranted(
              tx,
              context.tenantId,
              context.permissions,
              policy.rawValuePermission
            )));
        project = canSeeRaw
          ? (row) => row
          : (row) => maskSensitiveFields(row, policy);
      }

      const fetchedRows = await listStagedRows(tx, context.tenantId, batchId, {
        offset: 0,
        limit: 50
      });
      rows = fetchedRows.map(project);
      totalRows = await countStagedRows(tx, context.tenantId, batchId);
      reconciliation = await listReconciliationReports(
        tx,
        context.tenantId,
        "import",
        batchId
      );
    });
    if (!batch && !descriptorDenied) notFound = true;
  } catch (error) {
    logAdminPageError(
      "admin/data-exchange/imports/[id].astro: failed to load batch",
      error,
      {
        correlationId: Astro.locals.correlationId
      }
    );
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.data_exchange.imports.detail_title")}>
  {
    (!CAN_READ || descriptorDenied) && (
      <StateNotice
        kind="denied"
        title={t("admin.data_exchange.access_denied_title")}
        body={t("admin.data_exchange.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && notFound && (
      <StateNotice
        kind="empty"
        title={t("common.not_found_title")}
        body={t("common.not_found_body")}
      />
    )
  }
  {
    CAN_READ && !loadError && batch && (
      <div class="config-manager" data-batch-id={batch.id}>
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        <dl class="summary-grid">
          <dt>{t("admin.data_exchange.imports.col_import_key")}</dt>
          <dd>{batch.importKey}</dd>
          <dt>{t("admin.data_exchange.imports.col_status")}</dt>
          <dd>{batch.status}</dd>
          <dt>{t("admin.data_exchange.imports.summary_totals")}</dt>
          <dd>
            {t("admin.data_exchange.imports.summary_created")}:{" "}
            {batch.createdCount},{" "}
            {t("admin.data_exchange.imports.summary_updated")}:{" "}
            {batch.updatedCount},{" "}
            {t("admin.data_exchange.imports.summary_skipped")}:{" "}
            {batch.skippedCount},{" "}
            {t("admin.data_exchange.imports.summary_conflict")}:{" "}
            {batch.conflictCount},{" "}
            {t("admin.data_exchange.imports.summary_invalid")}:{" "}
            {batch.invalidCount},{" "}
            {t("admin.data_exchange.imports.summary_failed")}:{" "}
            {batch.failedCount}
          </dd>
        </dl>

        <div class="action-row">
          {CAN_POST && batch.status === "previewed" && (
            <button type="button" id="commit-button">
              {t("admin.data_exchange.imports.commit_button")}
            </button>
          )}
          {CAN_RETRY &&
            ["partially_committed", "failed"].includes(batch.status) && (
              <button type="button" id="retry-button">
                {t("admin.data_exchange.imports.retry_button")}
              </button>
            )}
          {CAN_MANAGE && batch.status === "committing" && !batch.pausedAt && (
            <button type="button" id="pause-button">
              {t("admin.data_exchange.imports.pause_button")}
            </button>
          )}
          {CAN_MANAGE && batch.status === "committing" && batch.pausedAt && (
            <button type="button" id="resume-button">
              {t("admin.data_exchange.imports.resume_button")}
            </button>
          )}
          {CAN_CANCEL &&
            ["staged", "validating", "previewed", "failed"].includes(
              batch.status
            ) && (
              <button type="button" id="cancel-button">
                {t("admin.data_exchange.imports.cancel_button")}
              </button>
            )}
        </div>

        <h2>{t("admin.data_exchange.imports.preview_heading")}</h2>
        {rows.length === 0 ? (
          <p class="empty-state">{t("admin.data_exchange.imports.no_rows")}</p>
        ) : (
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">#</th>
                <th scope="col">
                  {t("admin.data_exchange.imports.col_natural_key")}
                </th>
                <th scope="col">
                  {t("admin.data_exchange.imports.col_proposed_action")}
                </th>
                <th scope="col">
                  {t("admin.data_exchange.imports.col_commit_status")}
                </th>
                <th scope="col">
                  {t("admin.data_exchange.imports.col_errors")}
                </th>
              </tr>
            </thead>
            <tbody>
              {rows.map((row) => (
                <tr>
                  <td>{row.rowNumber}</td>
                  <td>{row.naturalKey ?? "—"}</td>
                  <td>{row.proposedAction ?? "—"}</td>
                  <td>{row.commitStatus}</td>
                  <td>
                    {row.validationErrors && row.validationErrors.length > 0
                      ? row.validationErrors
                          .map((e) => `${e.field}: ${e.message}`)
                          .join("; ")
                      : "—"}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
        <p class="pagination-note">
          {t("admin.data_exchange.imports.showing_rows", {
            count: rows.length,
            total: totalRows
          })}
        </p>

        {reconciliation.length > 0 && (
          <>
            <h2>{t("admin.data_exchange.imports.reconciliation_heading")}</h2>
            <ul>
              {reconciliation.map((report) => (
                <li>
                  {report.createdAt.toISOString()} —{" "}
                  {t("admin.data_exchange.imports.source_count")}:{" "}
                  {report.sourceCount},{" "}
                  {t("admin.data_exchange.imports.processed_count")}:{" "}
                  {report.processedCount},{" "}
                  {report.mismatch
                    ? t("admin.data_exchange.imports.mismatch")
                    : t("admin.data_exchange.imports.matched")}
                </li>
              ))}
            </ul>
          </>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
  }
  .action-banner[data-variant="success"] {
    background: var(--color-success-surface, #e6f4ea);
    color: var(--color-success-strong, #1e7e34);
  }
  .action-banner[data-variant="error"] {
    background: var(--color-danger-surface, #fdecea);
    color: var(--color-danger-strong);
  }
  .summary-grid {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--sp-1) var(--sp-3);
  }
  .action-row {
    display: flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .action-row button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--radius-sm);
    cursor: pointer;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
  }
  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../../lib/ui/admin-form-client";

  interface Strings {
    actionSuccess: string;
    cancelReasonPrompt: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const container = document.querySelector<HTMLElement>(
    ".config-manager[data-batch-id]"
  );
  const batchId = container?.dataset.batchId;

  async function runAction(
    button: HTMLButtonElement,
    path: string,
    body: unknown = {}
  ) {
    if (!batchId || button.disabled) return;
    const unlock = lockElement(button, strings.pleaseWait);
    try {
      const result = await submitJson(
        `/api/v1/data-exchange/imports/${batchId}/${path}`,
        "POST",
        body,
        strings,
        { "Idempotency-Key": newIdempotencyKey() }
      );
      if (result.ok) {
        showBanner("action-banner", strings.actionSuccess, "success");
        reloadAfterDelay();
      } else {
        showBanner("action-banner", result.message, "error");
      }
    } finally {
      unlock();
    }
  }

  document
    .getElementById("commit-button")
    ?.addEventListener("click", (event) =>
      runAction(event.currentTarget as HTMLButtonElement, "commit")
    );
  document
    .getElementById("retry-button")
    ?.addEventListener("click", (event) =>
      runAction(event.currentTarget as HTMLButtonElement, "retry")
    );
  document
    .getElementById("pause-button")
    ?.addEventListener("click", (event) =>
      runAction(event.currentTarget as HTMLButtonElement, "pause")
    );
  document
    .getElementById("resume-button")
    ?.addEventListener("click", (event) =>
      runAction(event.currentTarget as HTMLButtonElement, "resume")
    );
  document
    .getElementById("cancel-button")
    ?.addEventListener("click", (event) => {
      const reason = window.prompt(strings.cancelReasonPrompt);
      if (!reason) return;
      runAction(event.currentTarget as HTMLButtonElement, "cancel", { reason });
    });
</script>
