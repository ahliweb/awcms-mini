---
/**
 * Export jobs admin screen (Issue #752, epic #738 platform-evolution
 * Wave 3) — trigger/list/cancel/download + inline reconciliation. Same
 * SSR-load + client-action-via-fetch pattern as `imports.astro`.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { listExportJobs } from "../../../modules/data-exchange/application/export-job-directory";
import { listReconciliationReports } from "../../../modules/data-exchange/application/reconciliation-service";
import { listModules } from "../../../modules";
import { collectExchangeDescriptors } from "../../../modules/data-exchange/domain/exchange-registry";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/data-exchange/exports.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("data_exchange", "exports", "read")
);
const CAN_CREATE = context.permissions.has(
  permissionKey("data_exchange", "exports", "create")
);
const CAN_CANCEL = context.permissions.has(
  permissionKey("data_exchange", "exports", "cancel")
);
const CAN_DOWNLOAD = context.permissions.has(
  permissionKey("data_exchange", "export_downloads", "read")
);

const clientStrings = {
  createSuccess: t("admin.data_exchange.exports.create_success"),
  cancelSuccess: t("admin.data_exchange.exports.cancel_success"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let jobs: Awaited<ReturnType<typeof listExportJobs>> = [];
let exportDescriptorKeys: string[] = [];
let reconciliationByJob = new Map<string, boolean>();
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      jobs = await listExportJobs(tx, context.tenantId);
      for (const job of jobs) {
        if (job.status !== "completed") continue;
        const reports = await listReconciliationReports(
          tx,
          context.tenantId,
          "export",
          job.id
        );
        reconciliationByJob.set(
          job.id,
          reports.some((report) => report.mismatch)
        );
      }
    });
    exportDescriptorKeys = collectExchangeDescriptors(listModules())
      .filter(
        (descriptor) =>
          descriptor.direction === "export" || descriptor.direction === "both"
      )
      .map((descriptor) => descriptor.key);
  } catch (error) {
    logAdminPageError(
      "admin/data-exchange/exports.astro: failed to load export jobs",
      error,
      {
        correlationId: Astro.locals.correlationId
      }
    );
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.data_exchange.exports.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.data_exchange.access_denied_title")}
        body={t("admin.data_exchange.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="config-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        {jobs.length === 0 ? (
          <p class="empty-state">{t("admin.data_exchange.exports.no_rows")}</p>
        ) : (
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">
                  {t("admin.data_exchange.exports.col_export_key")}
                </th>
                <th scope="col">
                  {t("admin.data_exchange.exports.col_status")}
                </th>
                <th scope="col">{t("admin.data_exchange.exports.col_rows")}</th>
                <th scope="col">
                  {t("admin.data_exchange.exports.col_reconciliation")}
                </th>
                <th scope="col">
                  {t("admin.data_exchange.exports.col_actions")}
                </th>
              </tr>
            </thead>
            <tbody>
              {jobs.map((job) => (
                <tr data-id={job.id}>
                  <td>{job.exportKey}</td>
                  <td>{job.status}</td>
                  <td>{job.rowCount ?? "—"}</td>
                  <td>
                    {job.status === "completed"
                      ? reconciliationByJob.get(job.id)
                        ? t(
                            "admin.data_exchange.exports.reconciliation_mismatch"
                          )
                        : t("admin.data_exchange.exports.reconciliation_ok")
                      : "—"}
                  </td>
                  <td>
                    {job.status === "completed" && CAN_DOWNLOAD && (
                      <a
                        href={`/api/v1/data-exchange/exports/${job.id}/download`}
                      >
                        {t("admin.data_exchange.exports.download_link")}
                      </a>
                    )}{" "}
                    {CAN_CANCEL &&
                      ["queued", "running"].includes(job.status) && (
                        <button
                          type="button"
                          class="cancel-button"
                          data-id={job.id}
                        >
                          {t("admin.data_exchange.exports.cancel_button")}
                        </button>
                      )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}

        {CAN_CREATE && (
          <details class="create-config">
            <summary>{t("admin.data_exchange.exports.create_summary")}</summary>
            <form id="create-form" class="create-config-form">
              <label>
                {t("admin.data_exchange.exports.field_export_key")}
                <input
                  type="text"
                  name="exportKey"
                  required
                  list="export-descriptor-keys"
                />
                <datalist id="export-descriptor-keys">
                  {exportDescriptorKeys.map((key) => (
                    <option value={key} />
                  ))}
                </datalist>
              </label>
              <label>
                {t("admin.data_exchange.exports.field_format")}
                <select name="format" required>
                  <option value="csv">CSV</option>
                  <option value="json">JSON</option>
                </select>
              </label>
              <button type="submit">
                {t("admin.data_exchange.exports.create_submit")}
              </button>
            </form>
          </details>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
  }
  .action-banner[data-variant="success"] {
    background: color-mix(
      in srgb,
      var(--color-success) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-success);
  }
  .action-banner[data-variant="error"] {
    background: color-mix(
      in srgb,
      var(--color-danger) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-danger);
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
  }
  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }
  .cancel-button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
  }
  .create-config {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }
  .create-config summary {
    cursor: pointer;
    font-weight: 600;
  }
  .create-config-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 480px;
    margin-top: var(--sp-2);
  }
  .create-config-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }
  .create-config-form input,
  .create-config-form select {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }
  .create-config-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }
  input:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    createSuccess: string;
    cancelSuccess: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE_URL = "/api/v1/data-exchange/exports";

  document
    .getElementById("create-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);

      try {
        const formData = new FormData(form);
        const result = await submitJson(
          BASE_URL,
          "POST",
          {
            exportKey: formData.get("exportKey"),
            format: formData.get("format")
          },
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );

        if (result.ok) {
          showBanner("action-banner", strings.createSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  document
    .querySelectorAll<HTMLButtonElement>(".cancel-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}/cancel`,
            "POST",
            {},
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.cancelSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
</script>
