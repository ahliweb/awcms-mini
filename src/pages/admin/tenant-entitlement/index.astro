---
/**
 * Tenant entitlement admin screen (Issue #871, epic #868 SaaS control plane,
 * ADR-0022). Operates ONLY on the CURRENT tenant's RLS context (no cross-tenant
 * path param — ADR-0022 §6 no soft super-tenant). Three sections: the resolved
 * EFFECTIVE entitlement (features/modules/quotas + source explanation),
 * ASSIGNMENTS (subscribe to a published offer, suspend/resume/cancel), and
 * OVERRIDES (operator grant/deny, reason-bound + optionally time-bound, revoke).
 *
 * `tenant_entitlement` is `defaultTenantState: "disabled"`, so the SSR
 * permission gate (`ssr-session.ts`) strips `tenant_entitlement.*` keys for any
 * tenant that has not explicitly enabled the module — the denied notice renders
 * for them. The effective resolution NEVER exposes an operator's free-text
 * reason (tenant-facing shape only); the overrides table (operator-gated) does.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import StatusBadge from "../../../components/ui/StatusBadge.astro";
import type { StatusBadgeVariant } from "../../../components/ui/StatusBadge.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { listModules } from "../../../modules";
import { createServiceCatalogReadPort } from "../../../modules/service-catalog/application/service-catalog-read-port-adapter";
import { resolveTenantEntitlement } from "../../../modules/tenant-entitlement/application/entitlement-resolution";
import type { EffectiveEntitlement } from "../../../modules/tenant-entitlement/domain/resolution";
import {
  listAssignments,
  listOverrides,
  type EntitlementAssignmentDto,
  type EntitlementOverrideDto
} from "../../../modules/tenant-entitlement/application/entitlement-directory";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/tenant-entitlement/index.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("tenant_entitlement", "entitlement", "read")
);
const CAN_READ_ASSIGNMENTS = context.permissions.has(
  permissionKey("tenant_entitlement", "assignments", "read")
);
const CAN_ASSIGN = context.permissions.has(
  permissionKey("tenant_entitlement", "assignments", "assign")
);
const CAN_UPDATE_ASSIGNMENT = context.permissions.has(
  permissionKey("tenant_entitlement", "assignments", "update")
);
const CAN_REVOKE_ASSIGNMENT = context.permissions.has(
  permissionKey("tenant_entitlement", "assignments", "revoke")
);
const CAN_READ_OVERRIDES = context.permissions.has(
  permissionKey("tenant_entitlement", "overrides", "read")
);
const CAN_OVERRIDE = context.permissions.has(
  permissionKey("tenant_entitlement", "overrides", "override")
);
const CAN_REVOKE_OVERRIDE = context.permissions.has(
  permissionKey("tenant_entitlement", "overrides", "revoke")
);

const clientStrings = {
  assignSuccess: t("admin.tenant_entitlement.assign_success"),
  transitionSuccess: t("admin.tenant_entitlement.transition_success"),
  overrideSuccess: t("admin.tenant_entitlement.override_success"),
  revokeSuccess: t("admin.tenant_entitlement.revoke_success"),
  reasonPrompt: t("admin.tenant_entitlement.reason_prompt"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let entitlement: EffectiveEntitlement | null = null;
let assignments: EntitlementAssignmentDto[] = [];
let overrides: EntitlementOverrideDto[] = [];
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      const deps = {
        catalogPort: createServiceCatalogReadPort(tx),
        moduleDescriptors: listModules()
      };
      entitlement = await resolveTenantEntitlement(
        tx,
        context.tenantId,
        deps,
        new Date()
      );
      if (CAN_READ_ASSIGNMENTS) {
        assignments = await listAssignments(tx, context.tenantId);
      }
      if (CAN_READ_OVERRIDES) {
        overrides = await listOverrides(tx, context.tenantId);
      }
    });
  } catch (error) {
    logAdminPageError(
      "admin/tenant-entitlement/index.astro: failed to resolve entitlement",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}

function decisionVariant(allowed: boolean): StatusBadgeVariant {
  return allowed ? "success" : "danger";
}

function assignmentStatusVariant(status: string): StatusBadgeVariant {
  if (status === "active") return "success";
  if (status === "suspended") return "warning";
  return "neutral";
}

type DecisionRow = { key: string; allowed: boolean; sourceKind: string };

function decisionRows(
  map: Record<string, { allowed: boolean; source: { kind: string } }>
): DecisionRow[] {
  return Object.keys(map)
    .sort()
    .map((key) => ({
      key,
      allowed: map[key]!.allowed,
      sourceKind: map[key]!.source.kind
    }));
}

const featureRows = entitlement ? decisionRows(entitlement.features) : [];
const moduleRows = entitlement ? decisionRows(entitlement.modules) : [];
const quotaRows = entitlement
  ? Object.keys(entitlement.quotas)
      .sort()
      .map((key) => ({ key, ...entitlement!.quotas[key]! }))
  : [];
---

<AdminLayout title={t("admin.tenant_entitlement.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.tenant_entitlement.access_denied_title")}
        body={t("admin.tenant_entitlement.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && entitlement && (
      <div class="entitlement-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        {/* ---------- EFFECTIVE ENTITLEMENT ---------- */}
        <section class="panel">
          <h2>{t("admin.tenant_entitlement.effective_heading")}</h2>
          <p class="meta">
            {t("admin.tenant_entitlement.status_label")}:{" "}
            <StatusBadge
              label={entitlement.status}
              variant={
                entitlement.status === "resolved" ? "success" : "warning"
              }
            />
            {" · "}
            {t("admin.tenant_entitlement.snapshot_label")}:
            <code>{entitlement.snapshotHash.slice(0, 12)}</code>
          </p>

          <h3>{t("admin.tenant_entitlement.features_heading")}</h3>
          {featureRows.length === 0 ? (
            <p class="empty">{t("admin.tenant_entitlement.none")}</p>
          ) : (
            <div class="table-scroll">
              <table>
                <thead>
                  <tr>
                    <th>{t("admin.tenant_entitlement.col_key")}</th>
                    <th>{t("admin.tenant_entitlement.col_allowed")}</th>
                    <th>{t("admin.tenant_entitlement.col_source")}</th>
                  </tr>
                </thead>
                <tbody>
                  {featureRows.map((row) => (
                    <tr>
                      <td>
                        <code>{row.key}</code>
                      </td>
                      <td>
                        <StatusBadge
                          label={String(row.allowed)}
                          variant={decisionVariant(row.allowed)}
                        />
                      </td>
                      <td>{row.sourceKind}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          <h3>{t("admin.tenant_entitlement.modules_heading")}</h3>
          {moduleRows.length === 0 ? (
            <p class="empty">{t("admin.tenant_entitlement.none")}</p>
          ) : (
            <div class="table-scroll">
              <table>
                <thead>
                  <tr>
                    <th>{t("admin.tenant_entitlement.col_key")}</th>
                    <th>{t("admin.tenant_entitlement.col_allowed")}</th>
                    <th>{t("admin.tenant_entitlement.col_source")}</th>
                  </tr>
                </thead>
                <tbody>
                  {moduleRows.map((row) => (
                    <tr>
                      <td>
                        <code>{row.key}</code>
                      </td>
                      <td>
                        <StatusBadge
                          label={String(row.allowed)}
                          variant={decisionVariant(row.allowed)}
                        />
                      </td>
                      <td>{row.sourceKind}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          <h3>{t("admin.tenant_entitlement.quotas_heading")}</h3>
          {quotaRows.length === 0 ? (
            <p class="empty">{t("admin.tenant_entitlement.none")}</p>
          ) : (
            <div class="table-scroll">
              <table>
                <thead>
                  <tr>
                    <th>{t("admin.tenant_entitlement.col_key")}</th>
                    <th>{t("admin.tenant_entitlement.col_allowed")}</th>
                    <th>{t("admin.tenant_entitlement.col_limit")}</th>
                    <th>{t("admin.tenant_entitlement.col_source")}</th>
                  </tr>
                </thead>
                <tbody>
                  {quotaRows.map((row) => (
                    <tr>
                      <td>
                        <code>{row.key}</code>
                      </td>
                      <td>
                        <StatusBadge
                          label={String(row.allowed)}
                          variant={decisionVariant(row.allowed)}
                        />
                      </td>
                      <td>
                        {row.isUnlimited
                          ? t("admin.tenant_entitlement.unlimited")
                          : `${row.limit ?? 0} ${row.unit ?? ""}`}
                      </td>
                      <td>{row.source.kind}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>

        {/* ---------- ASSIGNMENTS ---------- */}
        {CAN_READ_ASSIGNMENTS && (
          <section class="panel">
            <h2>{t("admin.tenant_entitlement.assignments_heading")}</h2>
            {CAN_ASSIGN && (
              <form id="assign-form" class="inline-form">
                <label>
                  {t("admin.tenant_entitlement.field_plan_key")}
                  <input name="planKey" required pattern="[a-z][a-z0-9_]*" />
                </label>
                <label>
                  {t("admin.tenant_entitlement.field_offer_version")}
                  <input name="offerVersion" type="number" min="1" required />
                </label>
                <label>
                  {t("admin.tenant_entitlement.field_effective_to")}
                  <input name="effectiveTo" type="datetime-local" />
                </label>
                <button type="submit">
                  {t("admin.tenant_entitlement.assign_button")}
                </button>
              </form>
            )}
            {assignments.length === 0 ? (
              <p class="empty">{t("admin.tenant_entitlement.none")}</p>
            ) : (
              <div class="table-scroll">
                <table>
                  <thead>
                    <tr>
                      <th>{t("admin.tenant_entitlement.col_plan")}</th>
                      <th>{t("admin.tenant_entitlement.col_status")}</th>
                      <th>{t("admin.tenant_entitlement.col_current")}</th>
                      <th>{t("admin.tenant_entitlement.col_actions")}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {assignments.map((assignment) => (
                      <tr data-assignment-id={assignment.id}>
                        <td>
                          <code>{assignment.planKey}</code> v
                          {assignment.offerVersion}
                        </td>
                        <td>
                          <StatusBadge
                            label={assignment.status}
                            variant={assignmentStatusVariant(assignment.status)}
                          />
                        </td>
                        <td>{assignment.isCurrent ? "✓" : ""}</td>
                        <td class="actions">
                          {CAN_UPDATE_ASSIGNMENT &&
                            assignment.status === "active" && (
                              <button
                                class="transition-button"
                                data-to="suspended"
                                type="button"
                              >
                                {t("admin.tenant_entitlement.suspend_button")}
                              </button>
                            )}
                          {CAN_UPDATE_ASSIGNMENT &&
                            assignment.status === "suspended" && (
                              <button
                                class="transition-button"
                                data-to="active"
                                type="button"
                              >
                                {t("admin.tenant_entitlement.resume_button")}
                              </button>
                            )}
                          {CAN_REVOKE_ASSIGNMENT &&
                            assignment.status !== "canceled" && (
                              <button
                                class="transition-button danger"
                                data-to="canceled"
                                type="button"
                              >
                                {t("admin.tenant_entitlement.cancel_button")}
                              </button>
                            )}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </section>
        )}

        {/* ---------- OVERRIDES ---------- */}
        {CAN_READ_OVERRIDES && (
          <section class="panel">
            <h2>{t("admin.tenant_entitlement.overrides_heading")}</h2>
            {CAN_OVERRIDE && (
              <form id="override-form" class="inline-form">
                <label>
                  {t("admin.tenant_entitlement.field_target_kind")}
                  <select name="targetKind">
                    <option value="feature">feature</option>
                    <option value="module">module</option>
                    <option value="quota">quota</option>
                  </select>
                </label>
                <label>
                  {t("admin.tenant_entitlement.field_target_key")}
                  <input name="targetKey" required />
                </label>
                <label>
                  {t("admin.tenant_entitlement.field_effect")}
                  <select name="effect">
                    <option value="grant">grant</option>
                    <option value="deny">deny</option>
                  </select>
                </label>
                <label>
                  {t("admin.tenant_entitlement.field_reason")}
                  <input name="reason" required maxlength="500" />
                </label>
                <label>
                  {t("admin.tenant_entitlement.field_effective_to")}
                  <input name="effectiveTo" type="datetime-local" />
                </label>
                <button type="submit">
                  {t("admin.tenant_entitlement.override_button")}
                </button>
              </form>
            )}
            {overrides.length === 0 ? (
              <p class="empty">{t("admin.tenant_entitlement.none")}</p>
            ) : (
              <div class="table-scroll">
                <table>
                  <thead>
                    <tr>
                      <th>{t("admin.tenant_entitlement.col_target")}</th>
                      <th>{t("admin.tenant_entitlement.col_effect")}</th>
                      <th>{t("admin.tenant_entitlement.col_effective_to")}</th>
                      <th>{t("admin.tenant_entitlement.col_status")}</th>
                      <th>{t("admin.tenant_entitlement.col_actions")}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {overrides.map((override) => (
                      <tr data-override-id={override.id}>
                        <td>
                          {override.targetKind}:
                          <code>{override.targetKey}</code>
                        </td>
                        <td>{override.effect}</td>
                        <td>{override.effectiveTo ?? "—"}</td>
                        <td>
                          <StatusBadge
                            label={
                              override.isActive
                                ? t("admin.tenant_entitlement.active")
                                : t("admin.tenant_entitlement.revoked")
                            }
                            variant={override.isActive ? "success" : "neutral"}
                          />
                        </td>
                        <td class="actions">
                          {CAN_REVOKE_OVERRIDE && override.isActive && (
                            <button
                              class="revoke-override-button danger"
                              type="button"
                            >
                              {t("admin.tenant_entitlement.revoke_button")}
                            </button>
                          )}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </section>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .entitlement-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-4);
    box-shadow: var(--shadow-sm);
  }
  .panel h2 {
    margin-top: 0;
  }
  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
  }
  /* State-triggered entrance: the banner is `hidden` on SSR load and only
     revealed by `showBanner` after a mutation — never SSR-visible content, so
     the opacity fade is safe. Motion tokens; neutralised under reduced-motion. */
  .action-banner:not([hidden]) {
    animation: awcms-slide-up-in var(--motion-duration-base)
      var(--motion-ease-out);
  }
  .action-banner[data-variant="success"] {
    background: color-mix(
      in srgb,
      var(--color-success) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-success);
  }
  .action-banner[data-variant="error"] {
    background: color-mix(
      in srgb,
      var(--color-danger) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-danger);
  }
  /* Wide tables scroll inside their own container instead of forcing the whole
     page to scroll horizontally at 320px (doc 14 §Responsif). */
  .table-scroll {
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: var(--sp-2);
  }
  th,
  td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--fs-sm);
    vertical-align: top;
  }
  th {
    color: var(--color-text-muted);
    font-weight: 600;
  }
  /* Subtle row hover so wide tables are easier to scan (transition via motion
     tokens; neutralised under reduced-motion). */
  tbody tr {
    transition: background-color var(--motion-duration-fast)
      var(--motion-ease-standard);
  }
  tbody tr:hover {
    background: var(--color-surface-2);
  }
  .inline-form {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    align-items: end;
    margin-bottom: var(--sp-3);
  }
  .inline-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
    flex: 1 1 200px;
    min-width: 0;
  }
  .inline-form input,
  .inline-form select {
    width: 100%;
    min-width: 0;
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }
  .inline-form button[type="submit"] {
    flex: 0 0 auto;
    min-height: 44px;
    padding: var(--sp-2) var(--sp-4);
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    font-size: var(--fs-sm);
    font-weight: 600;
    cursor: pointer;
  }
  .inline-form button[type="submit"]:hover:not(:disabled) {
    box-shadow: var(--shadow-md);
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .actions button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface-2);
    color: var(--color-text);
    font-size: var(--fs-sm);
    cursor: pointer;
  }
  .actions button:hover:not(:disabled) {
    border-color: var(--color-primary);
  }
  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }
  button.danger {
    color: var(--color-danger);
  }
  .actions button.danger:hover:not(:disabled) {
    border-color: var(--color-danger-strong);
  }
  button:disabled {
    cursor: not-allowed;
    opacity: 0.7;
  }
  input:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    assignSuccess: string;
    transitionSuccess: string;
    overrideSuccess: string;
    revokeSuccess: string;
    reasonPrompt: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE = "/api/v1/tenant-entitlement";

  function toIso(value: FormDataEntryValue | null): string | null {
    const s = typeof value === "string" ? value.trim() : "";
    if (!s) return null;
    const date = new Date(s);
    return Number.isNaN(date.getTime()) ? null : date.toISOString();
  }

  // ---- assign ----
  document
    .getElementById("assign-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);
      try {
        const data = new FormData(form);
        const result = await submitJson(
          `${BASE}/assignments`,
          "POST",
          {
            planKey: data.get("planKey"),
            offerVersion: Number(data.get("offerVersion")),
            effectiveTo: toIso(data.get("effectiveTo"))
          },
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );
        if (result.ok) {
          showBanner("action-banner", strings.assignSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  // ---- assignment transition (suspend/resume/cancel) ----
  document
    .querySelectorAll<HTMLButtonElement>(".transition-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        const row = button.closest<HTMLElement>("[data-assignment-id]");
        const assignmentId = row?.dataset.assignmentId ?? "";
        const toStatus = button.dataset.to ?? "";
        let reason: string | null = null;
        if (toStatus !== "active") {
          reason = window.prompt(strings.reasonPrompt) ?? null;
          if (reason === null) return;
        }
        const unlock = lockElement(button, strings.pleaseWait);
        try {
          const result = await submitJson(
            `${BASE}/assignments/${encodeURIComponent(assignmentId)}`,
            "PATCH",
            { status: toStatus, reason },
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );
          if (result.ok) {
            showBanner("action-banner", strings.transitionSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });

  // ---- create override ----
  document
    .getElementById("override-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);
      try {
        const data = new FormData(form);
        const result = await submitJson(
          `${BASE}/overrides`,
          "POST",
          {
            targetKind: data.get("targetKind"),
            targetKey: data.get("targetKey"),
            effect: data.get("effect"),
            reason: data.get("reason"),
            effectiveTo: toIso(data.get("effectiveTo"))
          },
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );
        if (result.ok) {
          showBanner("action-banner", strings.overrideSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  // ---- revoke override ----
  document
    .querySelectorAll<HTMLButtonElement>(".revoke-override-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        const row = button.closest<HTMLElement>("[data-override-id]");
        const overrideId = row?.dataset.overrideId ?? "";
        const reason = window.prompt(strings.reasonPrompt) ?? null;
        if (reason === null) return;
        const unlock = lockElement(button, strings.pleaseWait);
        try {
          const result = await submitJson(
            `${BASE}/overrides/${encodeURIComponent(overrideId)}/revoke`,
            "POST",
            { reason },
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );
          if (result.ok) {
            showBanner("action-banner", strings.revokeSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
</script>
