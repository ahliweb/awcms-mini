---
/**
 * Reference value sets admin screen (Issue #750, epic #738
 * platform-evolution Wave 3). Same "SSR list load, client-side create/
 * deprecate/restore via fetch" pattern
 * `admin/organization-structure/legal-entities.astro` establishes.
 * Writes affect the GLOBAL baseline shared by every tenant (ADR-0021 §8).
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { listReferenceValueSets } from "../../../modules/reference-data/application/value-set-directory";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/reference-data/value-sets.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("reference_data", "value_sets", "read")
);
const CAN_CREATE = context.permissions.has(
  permissionKey("reference_data", "value_sets", "create")
);
const CAN_DELETE = context.permissions.has(
  permissionKey("reference_data", "value_sets", "delete")
);
const CAN_RESTORE = context.permissions.has(
  permissionKey("reference_data", "value_sets", "restore")
);

const clientStrings = {
  createSuccess: t("admin.reference_data.value_sets.create_success"),
  deprecateSuccess: t("admin.reference_data.value_sets.deprecate_success"),
  restoreSuccess: t("admin.reference_data.value_sets.restore_success"),
  deprecateReasonPrompt: t(
    "admin.reference_data.value_sets.deprecate_reason_prompt"
  ),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let valueSets: Awaited<ReturnType<typeof listReferenceValueSets>> = [];
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      valueSets = await listReferenceValueSets(tx);
    });
  } catch (error) {
    logAdminPageError(
      "admin/reference-data/value-sets.astro: failed to load value sets",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.reference_data.value_sets.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.reference_data.access_denied_title")}
        body={t("admin.reference_data.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="config-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        {valueSets.length === 0 ? (
          <p class="empty-state">
            {t("admin.reference_data.value_sets.no_rows")}
          </p>
        ) : (
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">
                  {t("admin.reference_data.value_sets.col_key")}
                </th>
                <th scope="col">
                  {t("admin.reference_data.value_sets.col_name")}
                </th>
                <th scope="col">
                  {t("admin.reference_data.value_sets.col_scope")}
                </th>
                <th scope="col">
                  {t("admin.reference_data.value_sets.col_status")}
                </th>
                <th scope="col">
                  {t("admin.reference_data.value_sets.col_actions")}
                </th>
              </tr>
            </thead>
            <tbody>
              {valueSets.map((valueSet) => (
                <tr data-key={valueSet.key}>
                  <td>
                    <a
                      href={`/admin/reference-data/codes?valueSet=${encodeURIComponent(valueSet.key)}`}
                    >
                      {valueSet.key}
                    </a>
                  </td>
                  <td>{valueSet.name}</td>
                  <td>{valueSet.scope}</td>
                  <td>{valueSet.status}</td>
                  <td>
                    {CAN_DELETE && valueSet.status === "active" && (
                      <button
                        type="button"
                        class="deprecate-button"
                        data-key={valueSet.key}
                      >
                        {t("admin.reference_data.value_sets.deprecate_button")}
                      </button>
                    )}
                    {CAN_RESTORE && valueSet.status === "deprecated" && (
                      <button
                        type="button"
                        class="restore-button"
                        data-key={valueSet.key}
                      >
                        {t("admin.reference_data.value_sets.restore_button")}
                      </button>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}

        {CAN_CREATE && (
          <details class="create-config">
            <summary>
              {t("admin.reference_data.value_sets.create_summary")}
            </summary>
            <form id="create-form" class="create-config-form">
              <label>
                {t("admin.reference_data.value_sets.field_key")}
                <input
                  type="text"
                  name="key"
                  required
                  maxlength="100"
                  pattern="^[a-z][a-z0-9_]*$"
                />
              </label>
              <label>
                {t("admin.reference_data.value_sets.field_name")}
                <input type="text" name="name" required maxlength="200" />
              </label>
              <label>
                {t("admin.reference_data.value_sets.field_description")}
                <input type="text" name="description" maxlength="2000" />
              </label>
              <label>
                {t("admin.reference_data.value_sets.field_override_policy")}
                <select name="overridePolicy">
                  <option value="none">none</option>
                  <option value="tenant_extend">tenant_extend</option>
                  <option value="tenant_override">tenant_override</option>
                  <option value="tenant_extend_and_override">
                    tenant_extend_and_override
                  </option>
                </select>
              </label>
              <button type="submit">
                {t("admin.reference_data.value_sets.create_submit")}
              </button>
            </form>
          </details>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
  }
  .action-banner[data-variant="success"] {
    background: color-mix(
      in srgb,
      var(--color-success) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-success);
  }
  .action-banner[data-variant="error"] {
    background: color-mix(
      in srgb,
      var(--color-danger) 15%,
      var(--color-surface)
    );
    border: 1px solid var(--color-danger);
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
  }
  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }
  .deprecate-button,
  .restore-button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .deprecate-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
  }
  .restore-button {
    background: var(--color-primary-strong);
    border: none;
    color: var(--color-primary-contrast);
  }
  .create-config {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }
  .create-config summary {
    cursor: pointer;
    font-weight: 600;
  }
  .create-config-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 480px;
    margin-top: var(--sp-2);
  }
  .create-config-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }
  .create-config-form input,
  .create-config-form select {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }
  .create-config-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }
  input:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    createSuccess: string;
    deprecateSuccess: string;
    restoreSuccess: string;
    deprecateReasonPrompt: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE_URL = "/api/v1/reference-data/value-sets";

  document
    .getElementById("create-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);

      try {
        const formData = new FormData(form);
        const result = await submitJson(
          BASE_URL,
          "POST",
          {
            key: formData.get("key"),
            name: formData.get("name"),
            description: formData.get("description") || null,
            overridePolicy: formData.get("overridePolicy")
          },
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );

        if (result.ok) {
          showBanner("action-banner", strings.createSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  document
    .querySelectorAll<HTMLButtonElement>(".deprecate-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const reason = window.prompt(strings.deprecateReasonPrompt);
        if (!reason) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/${encodeURIComponent(button.dataset.key ?? "")}`,
            "DELETE",
            { reason },
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.deprecateSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>(".restore-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/${encodeURIComponent(button.dataset.key ?? "")}/restore`,
            "POST",
            {},
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.restoreSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
</script>
