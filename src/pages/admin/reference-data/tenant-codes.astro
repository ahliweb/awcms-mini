---
/**
 * Tenant reference-code overrides/extensions admin screen (Issue #750,
 * epic #738 platform-evolution Wave 3). Query param `valueSet` selects
 * which value set's tenant overrides to manage. Writes ONLY to the
 * caller's own tenant-scoped table (RLS FORCE) — never the global
 * baseline (ADR-0021 §8).
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import {
  fetchReferenceValueSetByKey,
  listReferenceValueSets
} from "../../../modules/reference-data/application/value-set-directory";
import { listTenantReferenceCodes } from "../../../modules/reference-data/application/tenant-code-directory";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/reference-data/tenant-codes.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("reference_data", "tenant_codes", "read")
);
const CAN_CREATE = context.permissions.has(
  permissionKey("reference_data", "tenant_codes", "create")
);
const CAN_DELETE = context.permissions.has(
  permissionKey("reference_data", "tenant_codes", "delete")
);
const CAN_RESTORE = context.permissions.has(
  permissionKey("reference_data", "tenant_codes", "restore")
);

const selectedValueSetKey = Astro.url.searchParams.get("valueSet") ?? "";

const clientStrings = {
  createSuccess: t("admin.reference_data.tenant_codes.create_success"),
  deprecateSuccess: t("admin.reference_data.tenant_codes.deprecate_success"),
  restoreSuccess: t("admin.reference_data.tenant_codes.restore_success"),
  deprecateReasonPrompt: t(
    "admin.reference_data.tenant_codes.deprecate_reason_prompt"
  ),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let valueSetOptions: Awaited<ReturnType<typeof listReferenceValueSets>> = [];
let tenantCodes: Awaited<ReturnType<typeof listTenantReferenceCodes>> = [];
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      valueSetOptions = await listReferenceValueSets(tx);
      if (selectedValueSetKey) {
        const valueSet = await fetchReferenceValueSetByKey(
          tx,
          selectedValueSetKey
        );
        if (valueSet) {
          tenantCodes = await listTenantReferenceCodes(tx, context.tenantId, {
            valueSetId: valueSet.id,
            includeDeprecated: CAN_RESTORE
          });
        }
      }
    });
  } catch (error) {
    logAdminPageError(
      "admin/reference-data/tenant-codes.astro: failed to load tenant codes",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}
---

<AdminLayout title={t("admin.reference_data.tenant_codes.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.reference_data.access_denied_title")}
        body={t("admin.reference_data.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="config-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify({
            ...clientStrings,
            valueSet: selectedValueSetKey
          })}
        />

        <form method="get" class="select-value-set-form">
          <label>
            {t("admin.reference_data.tenant_codes.select_value_set_label")}
            <select name="valueSet" onchange="this.form.submit()">
              <option value="">--</option>
              {valueSetOptions.map((vs) => (
                <option
                  value={vs.key}
                  selected={vs.key === selectedValueSetKey}
                >
                  {vs.key} ({vs.name}, {vs.overridePolicy})
                </option>
              ))}
            </select>
          </label>
        </form>

        {selectedValueSetKey && (
          <>
            {tenantCodes.length === 0 ? (
              <p class="empty-state">
                {t("admin.reference_data.tenant_codes.no_rows")}
              </p>
            ) : (
              <table class="data-table">
                <thead>
                  <tr>
                    <th scope="col">
                      {t("admin.reference_data.tenant_codes.col_code")}
                    </th>
                    <th scope="col">
                      {t("admin.reference_data.tenant_codes.col_kind")}
                    </th>
                    <th scope="col">
                      {t("admin.reference_data.tenant_codes.col_label")}
                    </th>
                    <th scope="col">
                      {t("admin.reference_data.tenant_codes.col_status")}
                    </th>
                    <th scope="col">
                      {t("admin.reference_data.tenant_codes.col_actions")}
                    </th>
                  </tr>
                </thead>
                <tbody>
                  {tenantCodes.map((tc) => (
                    <tr data-id={tc.id}>
                      <td>{tc.code}</td>
                      <td>{tc.baseCodeId ? "override" : "extension"}</td>
                      <td>
                        {tc.labels.find((l) => l.locale === "en")?.label ??
                          tc.code}
                      </td>
                      <td>{tc.deprecatedAt ? "deprecated" : "active"}</td>
                      <td>
                        {CAN_DELETE && !tc.deprecatedAt && (
                          <button
                            type="button"
                            class="deprecate-button"
                            data-id={tc.id}
                          >
                            {t(
                              "admin.reference_data.tenant_codes.deprecate_button"
                            )}
                          </button>
                        )}
                        {CAN_RESTORE && tc.deprecatedAt && (
                          <button
                            type="button"
                            class="restore-button"
                            data-id={tc.id}
                          >
                            {t(
                              "admin.reference_data.tenant_codes.restore_button"
                            )}
                          </button>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}

            {CAN_CREATE && (
              <details class="create-config">
                <summary>
                  {t("admin.reference_data.tenant_codes.create_summary")}
                </summary>
                <form id="create-form" class="create-config-form">
                  <label>
                    {t("admin.reference_data.tenant_codes.field_base_code")}
                    <input
                      type="text"
                      name="baseCodeId"
                      placeholder={t(
                        "admin.reference_data.tenant_codes.field_base_code_placeholder"
                      )}
                    />
                  </label>
                  <label>
                    {t("admin.reference_data.tenant_codes.field_code")}
                    <input type="text" name="code" required maxlength="64" />
                  </label>
                  <label>
                    {t("admin.reference_data.tenant_codes.field_label_en")}
                    <input
                      type="text"
                      name="labelEn"
                      required
                      maxlength="300"
                    />
                  </label>
                  <label>
                    {t("admin.reference_data.tenant_codes.field_label_id")}
                    <input type="text" name="labelId" maxlength="300" />
                  </label>
                  <button type="submit">
                    {t("admin.reference_data.tenant_codes.create_submit")}
                  </button>
                </form>
              </details>
            )}
          </>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
  }
  .action-banner[data-variant="success"] {
    background: var(--color-success-surface, #e6f4ea);
    color: var(--color-success-strong, #1e7e34);
  }
  .action-banner[data-variant="error"] {
    background: var(--color-danger-surface, #fdecea);
    color: var(--color-danger-strong);
  }
  .select-value-set-form select {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
  }
  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }
  .deprecate-button,
  .restore-button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .deprecate-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
  }
  .restore-button {
    background: var(--color-primary-strong);
    border: none;
    color: var(--color-primary-contrast);
  }
  .create-config {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }
  .create-config summary {
    cursor: pointer;
    font-weight: 600;
  }
  .create-config-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 480px;
    margin-top: var(--sp-2);
  }
  .create-config-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }
  .create-config-form input {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }
  .create-config-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }
  input:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    createSuccess: string;
    deprecateSuccess: string;
    restoreSuccess: string;
    deprecateReasonPrompt: string;
    networkError: string;
    pleaseWait: string;
    valueSet: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE_URL = "/api/v1/reference-data/tenant-codes";

  document
    .getElementById("create-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);

      try {
        const formData = new FormData(form);
        const labels = [
          { locale: "en", label: formData.get("labelEn"), description: null }
        ];
        if (formData.get("labelId")) {
          labels.push({
            locale: "id",
            label: formData.get("labelId"),
            description: null
          });
        }
        const baseCodeId = formData.get("baseCodeId");

        const result = await submitJson(
          BASE_URL,
          "POST",
          {
            valueSet: strings.valueSet,
            baseCodeId: baseCodeId ? baseCodeId : null,
            code: formData.get("code"),
            labels
          },
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );

        if (result.ok) {
          showBanner("action-banner", strings.createSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  document
    .querySelectorAll<HTMLButtonElement>(".deprecate-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const reason = window.prompt(strings.deprecateReasonPrompt);
        if (!reason) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}`,
            "DELETE",
            { reason },
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.deprecateSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>(".restore-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}/restore`,
            "POST",
            {},
            strings,
            { "Idempotency-Key": newIdempotencyKey() }
          );

          if (result.ok) {
            showBanner("action-banner", strings.restoreSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
</script>
