---
/**
 * Inbound webhook endpoints admin screen (Issue #754, epic #738
 * platform-evolution Wave 3). Same "SSR list load, client-side create/
 * pause/resume/delete/rotate-secret via fetch" pattern
 * `admin/organization-structure/legal-entities.astro` establishes.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";
import StateNotice from "../../../components/ui/StateNotice.astro";
import { getDatabaseClient } from "../../../lib/database/client";
import { withTenant } from "../../../lib/database/tenant-context";
import { permissionKey } from "../../../modules/identity-access/domain/access-control";
import { listIntegrationEndpoints } from "../../../modules/integration-hub/application/endpoint-directory";
import { listInboundIntegrationAdapters } from "../../../modules/integration-hub/infrastructure/adapter-registry";
import { createTranslator } from "../../../lib/i18n/translate";
import { logAdminPageError } from "../../../lib/logging/error-log";
import { buildClientErrorMessages } from "../../../lib/i18n/error-messages";

const context = Astro.locals.ssrContext;

if (!context) {
  throw new Error(
    "admin/integration-hub/endpoints.astro rendered without Astro.locals.ssrContext — src/middleware.ts should have redirected to /login before this page ever runs."
  );
}

const t = await createTranslator(Astro.locals.locale);

const CAN_READ = context.permissions.has(
  permissionKey("integration_hub", "endpoints", "read")
);
const CAN_CREATE = context.permissions.has(
  permissionKey("integration_hub", "endpoints", "create")
);
const CAN_DELETE = context.permissions.has(
  permissionKey("integration_hub", "endpoints", "delete")
);
const CAN_MANAGE =
  context.permissions.has(
    permissionKey("integration_hub", "endpoints", "enable")
  ) &&
  context.permissions.has(
    permissionKey("integration_hub", "endpoints", "disable")
  );

const clientStrings = {
  createSuccess: t("admin.integration_hub.endpoints.create_success"),
  deleteSuccess: t("admin.integration_hub.endpoints.delete_success"),
  pauseSuccess: t("admin.integration_hub.endpoints.pause_success"),
  resumeSuccess: t("admin.integration_hub.endpoints.resume_success"),
  deleteReasonPrompt: t("admin.integration_hub.endpoints.delete_reason_prompt"),
  networkError: t("common.network_error"),
  pleaseWait: t("common.please_wait"),
  errorMessages: buildClientErrorMessages(t)
};

let endpoints: Awaited<ReturnType<typeof listIntegrationEndpoints>> = [];
let loadError = false;

if (CAN_READ) {
  try {
    await withTenant(getDatabaseClient(), context.tenantId, async (tx) => {
      endpoints = await listIntegrationEndpoints(tx, context.tenantId);
    });
  } catch (error) {
    logAdminPageError(
      "admin/integration-hub/endpoints.astro: failed to load endpoints",
      error,
      { correlationId: Astro.locals.correlationId }
    );
    loadError = true;
  }
}

const inboundAdapters = listInboundIntegrationAdapters();
---

<AdminLayout title={t("admin.integration_hub.endpoints.title")}>
  {
    !CAN_READ && (
      <StateNotice
        kind="denied"
        title={t("admin.integration_hub.access_denied_title")}
        body={t("admin.integration_hub.access_denied_body")}
      />
    )
  }
  {
    CAN_READ && loadError && (
      <StateNotice
        kind="error"
        title={t("common.error_title")}
        body={t("common.error_body")}
        retryLabel={t("common.retry")}
        retryHref={Astro.url.pathname}
      />
    )
  }
  {
    CAN_READ && !loadError && (
      <div class="config-manager">
        <div id="action-banner" class="action-banner" role="alert" hidden />
        <script
          type="application/json"
          id="i18n-strings"
          set:html={JSON.stringify(clientStrings)}
        />

        {endpoints.length === 0 ? (
          <p class="empty-state">
            {t("admin.integration_hub.endpoints.no_rows")}
          </p>
        ) : (
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">
                  {t("admin.integration_hub.endpoints.col_name")}
                </th>
                <th scope="col">
                  {t("admin.integration_hub.endpoints.col_adapter")}
                </th>
                <th scope="col">
                  {t("admin.integration_hub.endpoints.col_status")}
                </th>
                <th scope="col">
                  {t("admin.integration_hub.endpoints.col_actions")}
                </th>
              </tr>
            </thead>
            <tbody>
              {endpoints.map((endpoint) => (
                <tr data-id={endpoint.id}>
                  <td>{endpoint.displayName}</td>
                  <td>{endpoint.adapterKey}</td>
                  <td>{endpoint.status}</td>
                  <td>
                    {CAN_MANAGE && endpoint.status === "active" && (
                      <button
                        type="button"
                        class="pause-button"
                        data-id={endpoint.id}
                      >
                        {t("admin.integration_hub.endpoints.pause_button")}
                      </button>
                    )}
                    {CAN_MANAGE && endpoint.status === "paused" && (
                      <button
                        type="button"
                        class="resume-button"
                        data-id={endpoint.id}
                      >
                        {t("admin.integration_hub.endpoints.resume_button")}
                      </button>
                    )}
                    {CAN_DELETE && (
                      <button
                        type="button"
                        class="delete-button"
                        data-id={endpoint.id}
                      >
                        {t("admin.integration_hub.endpoints.delete_button")}
                      </button>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}

        {CAN_CREATE && (
          <details class="create-config">
            <summary>
              {t("admin.integration_hub.endpoints.create_summary")}
            </summary>
            <form id="create-form" class="create-config-form">
              <label>
                {t("admin.integration_hub.endpoints.field_display_name")}
                <input
                  type="text"
                  name="displayName"
                  required
                  maxlength="200"
                />
              </label>
              <label>
                {t("admin.integration_hub.endpoints.field_adapter_key")}
                <select name="adapterKey" required>
                  {inboundAdapters.map((adapter) => (
                    <option value={adapter.adapterKey}>
                      {adapter.displayName}
                    </option>
                  ))}
                </select>
              </label>
              <label>
                {t("admin.integration_hub.endpoints.field_secret_reference")}
                <input
                  type="text"
                  name="secretReference"
                  required
                  placeholder="env:MY_WEBHOOK_SECRET"
                  maxlength="200"
                />
              </label>
              <button type="submit">
                {t("admin.integration_hub.endpoints.create_submit")}
              </button>
            </form>
          </details>
        )}
      </div>
    )
  }
</AdminLayout>

<style>
  .config-manager {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .action-banner {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-sm);
  }
  .action-banner[data-variant="success"] {
    background: var(--color-success-surface, #e6f4ea);
    color: var(--color-success-strong, #1e7e34);
  }
  .action-banner[data-variant="error"] {
    background: var(--color-danger-surface, #fdecea);
    color: var(--color-danger-strong);
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
  }
  .data-table th,
  .data-table td {
    text-align: left;
    padding: var(--sp-2);
    border-bottom: 1px solid var(--color-border);
  }
  .pause-button,
  .resume-button,
  .delete-button {
    min-height: 44px;
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
    margin-inline-end: var(--sp-1);
  }
  .pause-button,
  .delete-button {
    background: var(--color-surface-2);
    border: 1px solid var(--color-danger-strong);
    color: var(--color-danger-strong);
  }
  .resume-button {
    background: var(--color-primary-strong);
    border: none;
    color: var(--color-primary-contrast);
  }
  .create-config {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--sp-3);
  }
  .create-config summary {
    cursor: pointer;
    font-weight: 600;
  }
  .create-config-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    max-width: 480px;
    margin-top: var(--sp-2);
  }
  .create-config-form label {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    font-size: var(--fs-sm);
  }
  .create-config-form input,
  .create-config-form select {
    padding: var(--sp-1) var(--sp-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }
  .create-config-form button {
    align-self: flex-start;
    background: var(--color-primary-strong);
    color: var(--color-primary-contrast);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--sp-1) var(--sp-3);
    min-height: 44px;
    cursor: pointer;
  }
  input:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script>
  import {
    lockElement,
    newIdempotencyKey,
    readClientStrings,
    reloadAfterDelay,
    showBanner,
    submitJson
  } from "../../../lib/ui/admin-form-client";

  interface Strings {
    createSuccess: string;
    deleteSuccess: string;
    pauseSuccess: string;
    resumeSuccess: string;
    deleteReasonPrompt: string;
    networkError: string;
    pleaseWait: string;
    errorMessages?: Record<string, string>;
  }

  const strings = readClientStrings<Strings>();
  const BASE_URL = "/api/v1/integration-hub/endpoints";

  document
    .getElementById("create-form")
    ?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const form = event.target as HTMLFormElement;
      const button = form.querySelector<HTMLButtonElement>(
        'button[type="submit"]'
      );
      if (!button || button.disabled) return;
      const unlock = lockElement(button, strings.pleaseWait);

      try {
        const formData = new FormData(form);
        const result = await submitJson(
          BASE_URL,
          "POST",
          {
            displayName: formData.get("displayName"),
            adapterKey: formData.get("adapterKey"),
            secretReference: formData.get("secretReference")
          },
          strings,
          { "Idempotency-Key": newIdempotencyKey() }
        );

        if (result.ok) {
          showBanner("action-banner", strings.createSuccess, "success");
          reloadAfterDelay();
        } else {
          showBanner("action-banner", result.message, "error");
        }
      } finally {
        unlock();
      }
    });

  function wireAction(
    selector: string,
    buildUrl: (id: string) => string,
    successMessage: string,
    idempotent: boolean
  ) {
    document.querySelectorAll<HTMLButtonElement>(selector).forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const headers = idempotent
            ? { "Idempotency-Key": newIdempotencyKey() }
            : undefined;
          const result = await submitJson(
            buildUrl(button.dataset.id!),
            "POST",
            {},
            strings,
            headers
          );

          if (result.ok) {
            showBanner("action-banner", successMessage, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
  }

  wireAction(
    ".pause-button",
    (id) => `${BASE_URL}/${id}/pause`,
    strings.pauseSuccess,
    false
  );
  wireAction(
    ".resume-button",
    (id) => `${BASE_URL}/${id}/resume`,
    strings.resumeSuccess,
    false
  );

  document
    .querySelectorAll<HTMLButtonElement>(".delete-button")
    .forEach((button) => {
      button.addEventListener("click", async () => {
        if (button.disabled) return;
        const reason = window.prompt(strings.deleteReasonPrompt);
        if (!reason) return;
        const unlock = lockElement(button, strings.pleaseWait);

        try {
          const result = await submitJson(
            `${BASE_URL}/${button.dataset.id}`,
            "DELETE",
            { reason },
            strings
          );

          if (result.ok) {
            showBanner("action-banner", strings.deleteSuccess, "success");
            reloadAfterDelay();
          } else {
            showBanner("action-banner", result.message, "error");
          }
        } finally {
          unlock();
        }
      });
    });
</script>
