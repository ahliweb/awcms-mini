<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AWCMS Mini</title>
  </head>
  <body>
    <main>
      <h1>AWCMS Mini</h1>
      <p>
        The EmDash host runtime is wired. Open the <a href="/_emdash/">admin panel</a>
        after database setup to continue bootstrapping the site.
      </p>
    </main>

    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
