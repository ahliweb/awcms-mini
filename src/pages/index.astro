      }

      main {
        max-width: 42rem;
        padding: 2rem;
        text-align: center;
      }

      h1 {
        font-size: 2.25rem;
        margin-bottom: 0.75rem;
      }

      p {
        color: #475569;
        font-size: 1.0625rem;
        line-height: 1.6;
      }

      a {
        color: #0f172a;
        font-weight: 600;
      }
    </style>
