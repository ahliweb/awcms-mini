---
import { listModules } from "../modules";

const modules = listModules();
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AWCMS Mini</title>
  </head>
  <body>
    <main>
      <h1>AWCMS Mini</h1>
      <p>Bun + Astro 7 modular monolith baseline.</p>
      <ul>
        {modules.map((module) => <li><strong>{module.key}</strong>: {module.description}</li>)}
      </ul>
    </main>
  </body>
</html>
