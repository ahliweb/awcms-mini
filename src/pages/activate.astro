---
import { getDatabase } from "../db/index.mjs";
import { getRuntimeConfig } from "../config/runtime.mjs";
import { UserInviteError, createUserService } from "../services/users/service.mjs";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const status = Astro.url.searchParams.get("status") ?? "";
const errorCode = Astro.url.searchParams.get("error") ?? "";

const errorMessages = {
  INVALID_TOKEN: "The activation link is invalid.",
  EXPIRED_TOKEN: "The activation link has expired.",
  INVALID_USER: "This invited account is no longer available.",
  ALREADY_ACTIVE: "This account has already been activated.",
  INVALID_PASSWORD: "Password must be at least 8 characters.",
  REQUEST_VERIFICATION_FAILED: "Request verification failed. Please try again.",
};

const runtimeConfig = getRuntimeConfig();
const turnstileSiteKey = runtimeConfig.turnstile?.siteKey ?? null;

let activation = null;
let errorMessage = errorMessages[errorCode] ?? "";

if (!status && token) {
  try {
    activation = await createUserService({ database: getDatabase() }).getInviteActivation(token);
  } catch (error) {
    if (error instanceof UserInviteError) {
      errorMessage = errorMessages[error.code] ?? error.message;
    } else {
      throw error;
    }
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Activate Account</title>
  </head>
  <body>
    <main>
      <section class="panel">
        <p class="eyebrow">AWCMS Mini</p>
        <h1>Activate your account</h1>
        {status === "success" ? (
          <>
            <p class="copy">Your account is active. You can now sign in through the admin login flow.</p>
            <a class="button" href="/_emdash/">Open admin</a>
          </>
        ) : errorMessage ? (
          <>
            <p class="copy error">{errorMessage}</p>
            <a class="text-link" href="/">Return home</a>
          </>
        ) : activation ? (
          <>
            <p class="copy">
              Finishing activation for <strong>{activation.user.email}</strong>. This link expires on
              <strong> {new Date(activation.expires_at).toLocaleString()}</strong>.
            </p>
            <form method="POST" action="/api/activate" class="form">
              <input type="hidden" name="token" value={token} />
              <label>
                <span>Display name</span>
                <input
                  type="text"
                  name="display_name"
                  value={activation.user.display_name ?? ""}
                  autocomplete="name"
                />
              </label>
              <label>
                <span>Password</span>
                <input type="password" name="password" minlength="8" required autocomplete="new-password" />
              </label>
              {turnstileSiteKey ? <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-action="invite_activation"></div> : null}
              <button class="button" type="submit">Activate account</button>
            </form>
          </>
        ) : (
          <p class="copy">Use the activation link from your invite to finish setting up your account.</p>
        )}
      </section>
    </main>

    {turnstileSiteKey ? <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script> : null}

    <style>
      :global(*) {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%);
        color: #0f172a;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        padding: 24px;
      }

      main {
        width: min(100%, 480px);
      }

      .panel {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
        padding: 32px;
      }

      .eyebrow {
        margin: 0 0 12px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 12px;
        color: #6366f1;
        font-weight: 700;
      }

      h1 {
        margin: 0 0 12px;
        font-size: 34px;
        line-height: 1.1;
      }

      .copy {
        margin: 0 0 24px;
        color: #475569;
        line-height: 1.6;
      }

      .error {
        color: #b91c1c;
      }

      .form {
        display: grid;
        gap: 16px;
      }

      label {
        display: grid;
        gap: 8px;
        color: #334155;
        font-weight: 600;
      }

      input {
        width: 100%;
        border: 1px solid #cbd5e1;
        border-radius: 14px;
        padding: 12px 14px;
        font: inherit;
        background: #fff;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: 999px;
        padding: 12px 18px;
        background: #111827;
        color: #fff;
        font: inherit;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
      }

      .text-link {
        color: #1d4ed8;
        font-weight: 600;
      }
    </style>
  </body>
</html>
